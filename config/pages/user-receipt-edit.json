{
  "id": "user-receipt-edit",
  "type": "page",
  "route": "/users/[user_id]/receipts/[receipt_id]/edit",
  "state": {
    "loading": false,
    "saving": false,
    "saved": false,
    "sentSuccessfully": false,
    "receipt_id": "{$location.routeParams.receipt_id}",
    "saveResult": null,
    "userData": {
      "id": "",
      "first_name": "",
      "last_name": "",
      "email": "",
      "fullName": ""
    },
    "receiptData": {
      "id": "",
      "registration_date": "",
      "purchase_date": "",
      "retail_chain_id": "",
      "moderation_status": "",
      "comment": "",
      "registrationDateFormatted": "",
      "purchaseDateFormatted": "",
      "retail_chains": [],
      "statuses": []
    },
    "products": {
      "value": [],
      "columns": [],
      "totalRecords": 0
    }
  },
  "meta": { "title": "Модерация чека — CRM Platform" },
  "shortcuts": {
    "autoModerate": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "setProperty",
            "params": { "target": "state.saveResult", "value": null }
          },
          {
            "type": "sendRequest",
            "params": {
              "url": "/api/receipts/{$location.routeParams.receipt_id}/check",
              "method": "POST",
              "target": "state.saveResult",
              "onSuccess": [
                {
                  "type": "showToast",
                  "params": {
                    "severity": "success",
                    "summary": "Автомодерация",
                    "message": "Проверка выполнена"
                  }
                }
              ],
              "onError": [
                {
                  "type": "showToast",
                  "params": {
                    "severity": "error",
                    "summary": "Ошибка",
                    "message": "Ошибка при проверке"
                  }
                }
              ]
            }
          }
        ]
      }
    },
    "saveReceipt": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "setProperty",
            "params": {
              "target": "state.saving",
              "value": true
            }
          },
          {
            "type": "setProperty",
            "params": {
              "target": "state.saveResult",
              "value": null
            }
          },
          {
            "type": "sendRequest",
            "params": {
              "url": "/api/receipts/{$location.routeParams.receipt_id}",
              "method": "PATCH",
              "target": "state.saveResult",
              "data": {
                "retail_chain_id": "{$state.receiptData.retail_chain_id}",
                "moderation_status": "{$state.receiptData.moderation_status}",
                "comment": "{$state.receiptData.comment}"
              },
              "onSuccess": [
                {
                  "type": "setProperty",
                  "params": {
                    "target": "state.saving",
                    "value": false
                  }
                },
                {
                  "type": "setProperty",
                  "params": {
                    "target": "state.saved",
                    "value": true
                  }
                },
                {
                  "type": "setProperty",
                  "params": {
                    "target": "state.sentSuccessfully",
                    "value": true
                  }
                }
              ],
              "onError": [
                {
                  "type": "setProperty",
                  "params": {
                    "target": "state.saving",
                    "value": false
                  }
                },
                {
                  "type": "setProperty",
                  "params": {
                    "target": "state.sentSuccessfully",
                    "value": false
                  }
                },
                {
                  "type": "showToast",
                  "params": {
                    "severity": "error",
                    "summary": "Ошибка",
                    "message": "Не удалось сохранить чек"
                  }
                }
              ]
            }
          }
        ]
      }
    }
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}",
      "method": "GET",
      "target": "state.userData"
    },
    {
      "url": "{$config.baseURL}/api/receipts/{$location.routeParams.receipt_id}",
      "method": "GET",
      "target": "state.receiptData"
    },
    {
      "url": "{$config.baseURL}/api/receipts/{$location.routeParams.receipt_id}/products",
      "method": "GET",
      "target": "state.products"
    }
  ],
  "sections": [
    {
      "id": "breadcrumbSection",
      "type": "section",
      "className": "",
      "blocks": [
        {
          "id": "breadcrumbBlock",
          "type": "block",
          "components": [
            {
              "id": "breadcrumb",
              "type": "component",
              "componentType": "Breadcrumb",
              "className": "border-none p-0",
              "props": {
                "home": { "icon": "pi pi-home", "url": "/" },
                "model": [
                  { "label": "Участники", "route": "/users" },
                  {
                    "label": "@state.userData.fullName",
                    "route": "/users/{@state.userData.id}"
                  },
                  {
                    "label": "Чеки",
                    "route": "/users/{@state.userData.id}/receipts"
                  },
                  {
                    "label": "Чек №{@state.receiptData.id}",
                    "route": "/users/{@state.userData.id}/receipts/{@state.receiptData.id}"
                  },
                  { "label": "Модерация" }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "formMainSection",
      "type": "section",
      "className": "",
      "grid": {
        "cols": ["col-12 lg:col-6", "col-12 lg:col-6"],
        "padding": "p-2"
      },
      "blocks": [
        {
          "id": "infoBlock",
          "type": "block",
          "wrapper": {
            "component": "Panel",
            "props": {
              "header": "Информация о чеке"
            }
          },
          "className": "flex flex-column gap-3",
          "components": [
            {
              "id": "userNameGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Участник",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "userName",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.userData.fullName"
                    }
                  }
                ]
              }
            },
            {
              "id": "userEmailGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Email",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "userEmail",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.userData.email"
                    }
                  }
                ]
              }
            },
            {
              "id": "registrationDateGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Дата регистрации",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "registrationDate",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.receiptData.registrationDateFormatted"
                    }
                  }
                ]
              }
            },
            {
              "id": "purchaseDateGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Дата покупки",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "purchaseDate",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.receiptData.purchaseDateFormatted"
                    }
                  }
                ]
              }
            }
          ]
        },
        {
          "id": "editBlock",
          "type": "block",
          "wrapper": {
            "component": "Panel",
            "props": {
              "header": "Модерация"
            }
          },
          "className": "flex flex-column",
          "components": [
            {
              "id": "retailChainGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "flex flex-column gap-1 mb-2",
              "props": {
                "label": "Торговая сеть",
                "labelClassName": "font-bold text-sm",
                "components": [
                  {
                    "id": "retailChainDropdown",
                    "type": "component",
                    "componentType": "Dropdown",
                    "props": {
                      "options": "@state.receiptData.retail_chains",
                      "value": "@state.receiptData.retail_chain_id",
                      "optionLabel": "name",
                      "optionValue": "id",
                      "placeholder": "Выберите торговую сеть",
                      "className": "w-full"
                    },
                    "events": [
                      {
                        "type": "onChange",
                        "commands": [
                          {
                            "type": "setProperty",
                            "params": {
                              "source": "event.value",
                              "target": "state.receiptData.retail_chain_id"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            {
              "id": "moderationStatusGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "flex flex-column gap-1 mb-2",
              "props": {
                "label": "Статус модерации",
                "labelClassName": "font-bold text-sm",
                "components": [
                  {
                    "id": "moderationStatusDropdown",
                    "type": "component",
                    "componentType": "Dropdown",
                    "props": {
                      "options": "@state.receiptData.statuses",
                      "value": "@state.receiptData.moderation_status",
                      "optionLabel": "name",
                      "optionValue": "id",
                      "placeholder": "Выберите статус",
                      "className": "w-full"
                    },
                    "events": [
                      {
                        "type": "onChange",
                        "commands": [
                          {
                            "type": "setProperty",
                            "params": {
                              "source": "event.value",
                              "target": "state.receiptData.moderation_status"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            {
              "id": "commentGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "flex flex-column gap-1 mb-2",
              "props": {
                "label": "Комментарий",
                "labelClassName": "font-bold text-sm",
                "components": [
                  {
                    "id": "commentInput",
                    "type": "component",
                    "componentType": "InputTextarea",
                    "props": {
                      "value": "@state.receiptData.comment",
                      "rows": 3,
                      "autoResize": true,
                      "className": "w-full"
                    },
                    "events": [
                      {
                        "type": "onChange",
                        "commands": [
                          {
                            "type": "setProperty",
                            "params": {
                              "source": "event.value",
                              "target": "state.receiptData.comment"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "productsSection",
      "type": "section",
      "className": "mb-5",
      "blocks": [
        {
          "id": "productsBlock",
          "type": "block",
          "components": [
            {
              "id": "productsTable",
              "type": "component",
              "componentType": "DataTable",
              "props": {
                "value": "@state.products.value",
                "columns": "@state.products.columns",
                "paginator": false,
                "size": "small"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "buttonsSection",
      "type": "section",
      "className": "flex justify-content-center",
      "blocks": [
        {
          "id": "buttonsBlock",
          "type": "block",
          "wrapper": {
            "showHeader": false,
            "component": "Panel",
            "props": {
              "className": "flex-grow-1",
              "pt": {
                "content": {
                  "style": { "background": "var(--surface-50) !important" }
                }
              }
            }
          },
          "className": "flex flex-wrap gap-3 justify-content-center md:justify-content-start",
          "components": [
            {
              "id": "btnAutoModerate",
              "type": "component",
              "componentType": "Button",
              "props": {
                "label": "Автомодерация",
                "icon": "pi pi-search",
                "severity": "info",
                "outlined": true
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": ["autoModerate"]
                }
              ]
            },
            {
              "id": "btnSaveAndGo",
              "type": "component",
              "componentType": "Button",
              "props": {
                "label": "Сохранить",
                "icon": "pi pi-check",
                "severity": "success",
                "disabled": "@state.saving"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    "saveReceipt",
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/users/{$location.routeParams.user_id}/receipts/{$location.routeParams.receipt_id}",
                        "condition": "{$state.sentSuccessfully}"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "btnApply",
              "type": "component",
              "componentType": "Button",
              "props": {
                "label": "Применить",
                "icon": "pi pi-check",
                "severity": "success",
                "outlined": true,
                "disabled": "@state.saving"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    "saveReceipt",
                    {
                      "type": "showToast",
                      "params": {
                        "severity": "success",
                        "summary": "Успешно",
                        "message": "Чек сохранен",
                        "condition": "{$state.sentSuccessfully}"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "btnCancel",
              "type": "component",
              "componentType": "Button",
              "props": {
                "label": "Отменить изменения",
                "icon": "pi pi-times",
                "severity": "secondary",
                "outlined": true
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/users/{$location.routeParams.user_id}/receipts/{$location.routeParams.receipt_id}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
