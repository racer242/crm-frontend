{
  "id": "profile",
  "type": "page",
  "route": "/profile",
  "state": {
    "loading": false,
    "initialized": true,
    "user": {
      "id": "{$cookie.user_data.id}",
      "login": "{$cookie.user_data.login}",
      "email": "{$cookie.user_data.email}",
      "name": "{$cookie.user_data.name}",
      "avatar": "{$cookie.user_data.avatar}",
      "role": "{$cookie.user_data.role}",
      "groups": "{$cookie.user_data.groups}"
    }
  },
  "meta": {
    "title": "Профиль — CRM Platform"
  },
  "sections": [
    {
      "id": "breadcrumbSection",
      "type": "section",
      "className": "",
      "blocks": [
        {
          "id": "breadcrumbBlock",
          "type": "block",
          "components": [
            {
              "id": "breadcrumb",
              "type": "component",
              "componentType": "Breadcrumb",
              "className": "border-none p-0",
              "props": {
                "home": { "icon": "pi pi-home", "url": "/" },
                "model": [{ "label": "Профиль {@state.user.name}" }]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "mainSection",
      "type": "section",
      "className": "flex justify-content-center",
      "blocks": [
        {
          "id": "profileBlock",
          "type": "block",
          "wrapper": {
            "component": "Panel",
            "props": {
              "className": "w-full",
              "header": "Профиль"
            }
          },
          "className": "flex flex-column align-items-center gap-1",
          "components": [
            {
              "id": "userAvatarNameGroup",
              "type": "component",
              "componentType": "LayoutGroup",
              "className": "flex flex-column md:flex-row gap-3 justify-content-center align-items-center my-3 lg:my-6",
              "props": {
                "components": [
                  {
                    "id": "userAvatar",
                    "type": "component",
                    "componentType": "Avatar",
                    "props": {
                      "initials": "@state.user.name",
                      "shape": "circle",
                      "size": "xlarge"
                    }
                  },
                  {
                    "id": "userName",
                    "type": "component",
                    "componentType": "Text",
                    "props": {
                      "value": "@state.user.name",
                      "level": 1
                    },
                    "className": "text-center md:text-left"
                  }
                ]
              }
            },
            {
              "id": "userDivider1",
              "type": "component",
              "componentType": "Divider",
              "className": "w-full"
            },
            {
              "id": "userIdGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "ID",
                "labelClassName": "text-sm col-6 text-right",
                "containerClassName": "col-6",
                "components": [
                  {
                    "id": "userId",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.user.id"
                    }
                  }
                ]
              }
            },
            {
              "id": "userEmailGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Email",
                "labelClassName": "text-sm col-6 text-right",
                "containerClassName": "col-6",
                "components": [
                  {
                    "id": "userEmail",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "style": { "wordBreak": "break-all" },
                    "props": {
                      "value": "@state.user.email"
                    }
                  }
                ]
              }
            },
            {
              "id": "userLoginGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Логин",
                "labelClassName": "text-sm col-6 text-right",
                "containerClassName": "col-6",
                "components": [
                  {
                    "id": "userLogin",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "style": { "wordBreak": "break-all" },
                    "props": {
                      "value": "@state.user.login"
                    }
                  }
                ]
              }
            },
            {
              "id": "userRoleGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Роль",
                "labelClassName": "text-sm col-6 text-right",
                "containerClassName": "col-6",
                "components": [
                  {
                    "id": "userRole",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.user.role"
                    }
                  }
                ]
              }
            },
            {
              "id": "logoutDivider",
              "type": "component",
              "componentType": "Divider",
              "className": "w-full"
            },
            {
              "id": "btnLogout",
              "type": "component",
              "componentType": "Button",
              "className": "self-center",
              "props": {
                "label": "Выйти",
                "icon": "pi pi-sign-out",
                "severity": "danger",
                "size": "small"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/api/auth/logout"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
