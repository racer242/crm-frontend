{
  "id": "profile",
  "type": "page",
  "route": "/profile",
  "state": {
    "loading": false,
    "initialized": true,
    "user": {
      "id": "",
      "login": "",
      "email": "",
      "name": "",
      "avatar": "",
      "role": "",
      "groups": []
    }
  },
  "meta": {
    "title": "Профиль — CRM Platform"
  },
  "sections": [
    {
      "id": "breadcrumbSection",
      "type": "section",
      "className": "",
      "blocks": [
        {
          "id": "breadcrumbBlock",
          "type": "block",
          "components": [
            {
              "id": "breadcrumb",
              "type": "component",
              "componentType": "Breadcrumb",
              "className": "border-none p-0",
              "props": {
                "home": { "icon": "pi pi-home", "url": "/" },
                "model": [{ "label": "Профиль" }]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "mainSection",
      "type": "section",
      "className": "flex justify-content-center",
      "blocks": [
        {
          "id": "profileBlock",
          "type": "block",
          "wrapper": {
            "component": "Panel",
            "props": {
              "header": "Профиль"
            }
          },
          "className": "w-full md:w-6 flex flex-column gap-3",
          "components": [
            {
              "id": "userNameGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Имя",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "userName",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.user.name"
                    }
                  }
                ]
              }
            },
            {
              "id": "userEmailGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Email",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "userEmail",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "style": { "wordBreak": "break-all" },
                    "props": {
                      "value": "@state.user.email"
                    }
                  }
                ]
              }
            },
            {
              "id": "userLoginGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Логин",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "userLogin",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.user.login"
                    }
                  }
                ]
              }
            },
            {
              "id": "userRoleGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Роль",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "userRole",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.user.role"
                    }
                  }
                ]
              }
            },
            {
              "id": "userIdGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "ID",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "userId",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.user.id"
                    }
                  }
                ]
              }
            },
            {
              "id": "logoutDivider",
              "type": "component",
              "componentType": "Divider",
              "className": "w-full"
            },
            {
              "id": "btnLogout",
              "type": "component",
              "componentType": "Button",
              "className": "self-center",
              "props": {
                "label": "Выйти",
                "icon": "pi pi-sign-out",
                "severity": "danger",
                "size": "small"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/api/auth/logout"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
