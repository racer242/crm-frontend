{
  "id": "user-prize-edit",
  "type": "page",
  "route": "/users/[user_id]/prizes/[prize_id]/edit",
  "state": {
    "loading": false,
    "saving": false,
    "userData": {
      "id": "",
      "first_name": "",
      "last_name": "",
      "email": "",
      "fullName": ""
    },
    "prizeData": {
      "id": "",
      "prize_name": "",
      "win_date": "",
      "retail_chain_id": "",
      "status": "",
      "comment": ""
    },
    "formData": {
      "win_date": "",
      "prize_type_id": "",
      "retail_chain_id": "",
      "status": "",
      "comment": ""
    },
    "prizeTypes": [],
    "retailChains": []
  },
  "meta": { "title": "Редактирование приза — CRM Platform" },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}",
      "method": "GET",
      "target": "state.userData"
    },
    {
      "url": "{$config.baseURL}/api/prizes/{$location.routeParams.prize_id}",
      "method": "GET",
      "target": "state.prizeData"
    }
  ],
  "shortcuts": {
    "savePrize": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "setProperty",
            "params": { "target": "state.saving", "value": true }
          },
          {
            "type": "sendRequest",
            "params": {
              "url": "/api/prizes/{$location.routeParams.prize_id}",
              "method": "PATCH",
              "data": "{$state.formData}",
              "onSuccess": [
                {
                  "type": "setProperty",
                  "params": { "target": "state.saving", "value": false }
                },
                {
                  "type": "showToast",
                  "params": {
                    "severity": "success",
                    "summary": "Успешно",
                    "detail": "Приз сохранен"
                  }
                },
                {
                  "type": "navigate",
                  "params": {
                    "url": "/users/{$location.routeParams.user_id}/prizes/{$location.routeParams.prize_id}"
                  }
                }
              ],
              "onError": [
                {
                  "type": "setProperty",
                  "params": { "target": "state.saving", "value": false }
                },
                {
                  "type": "showToast",
                  "params": {
                    "severity": "error",
                    "summary": "Ошибка",
                    "detail": "Не удалось сохранить приз"
                  }
                }
              ]
            }
          }
        ]
      }
    }
  },
  "sections": [
    {
      "id": "breadcrumbSection",
      "type": "section",
      "className": "",
      "blocks": [
        {
          "id": "breadcrumbBlock",
          "type": "block",
          "components": [
            {
              "id": "breadcrumb",
              "type": "component",
              "componentType": "Breadcrumb",
              "className": "border-none p-0",
              "props": {
                "home": { "icon": "pi pi-home", "url": "/" },
                "model": [
                  { "label": "Участники", "route": "/users" },
                  {
                    "label": "@state.userData.fullName",
                    "route": "/users/{@state.userData.id}"
                  },
                  {
                    "label": "Призы",
                    "route": "/users/{@state.userData.id}/prizes"
                  },
                  {
                    "label": "@state.prizeData.prize_name",
                    "route": "/users/{@state.userData.id}/prizes/{@state.prizeData.id}"
                  },
                  { "label": "Редактирование" }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "mainLayout",
      "type": "section",
      "className": "flex mb-5",
      "grid": { "cols": ["col-12"], "padding": "p-2" },
      "blocks": [
        {
          "id": "formBlock",
          "type": "block",
          "wrapper": {
            "component": "Panel",
            "props": { "header": "Редактирование приза" }
          },
          "className": "flex flex-column gap-3",
          "components": [
            {
              "id": "userInfoGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Участник",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "userInfo",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": { "value": "@state.userData.fullName" }
                  }
                ]
              }
            },
            {
              "id": "userEmailGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Email",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "userEmail",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": { "value": "@state.userData.email" }
                  }
                ]
              }
            },
            {
              "id": "prizeNameGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Вид приза",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "prizeName",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": { "value": "@state.prizeData.prize_name" }
                  }
                ]
              }
            },
            {
              "id": "winDateGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Дата выигрыша",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "winDateInput",
                    "type": "component",
                    "componentType": "Calendar",
                    "props": {
                      "value": "@state.formData.win_date",
                      "dateFormat": "dd.mm.yy",
                      "showIcon": true,
                      "className": "w-full"
                    },
                    "events": [
                      {
                        "type": "onChange",
                        "commands": [
                          {
                            "type": "setProperty",
                            "params": {
                              "source": "event.value",
                              "target": "state.formData.win_date"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            {
              "id": "retailChainGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Торговая сеть",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "retailChainDropdown",
                    "type": "component",
                    "componentType": "Dropdown",
                    "props": {
                      "options": "@state.retailChains",
                      "value": "@state.formData.retail_chain_id",
                      "optionLabel": "name",
                      "optionValue": "id",
                      "placeholder": "Выберите торговую сеть",
                      "className": "w-full"
                    },
                    "events": [
                      {
                        "type": "onChange",
                        "commands": [
                          {
                            "type": "setProperty",
                            "params": {
                              "source": "event.value",
                              "target": "state.formData.retail_chain_id"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            {
              "id": "statusGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Статус",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "statusDropdown",
                    "type": "component",
                    "componentType": "Dropdown",
                    "props": {
                      "options": [
                        { "id": "pending", "name": "Ожидает" },
                        { "id": "approved", "name": "Одобрен" },
                        { "id": "delivered", "name": "Доставлен" },
                        { "id": "rejected", "name": "Отклонен" }
                      ],
                      "value": "@state.formData.status",
                      "optionLabel": "name",
                      "optionValue": "id",
                      "placeholder": "Выберите статус",
                      "className": "w-full"
                    },
                    "events": [
                      {
                        "type": "onChange",
                        "commands": [
                          {
                            "type": "setProperty",
                            "params": {
                              "source": "event.value",
                              "target": "state.formData.status"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            {
              "id": "commentGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-start mb-2",
              "props": {
                "label": "Комментарий",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "commentInput",
                    "type": "component",
                    "componentType": "InputTextarea",
                    "props": {
                      "value": "@state.formData.comment",
                      "rows": 3,
                      "autoResize": true,
                      "className": "w-full"
                    },
                    "events": [
                      {
                        "type": "onChange",
                        "commands": [
                          {
                            "type": "setProperty",
                            "params": {
                              "source": "event.value",
                              "target": "state.formData.comment"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "buttonsSection",
      "type": "section",
      "className": "flex justify-content-center",
      "blocks": [
        {
          "id": "buttonsBlock",
          "type": "block",
          "className": "flex flex-wrap gap-3 justify-content-center",
          "components": [
            {
              "id": "btnSave",
              "type": "component",
              "componentType": "Button",
              "props": {
                "label": "Сохранить",
                "icon": "pi pi-check",
                "severity": "success",
                "disabled": "@state.saving"
              },
              "events": [{ "type": "onClick", "commands": ["savePrize"] }]
            },
            {
              "id": "btnCancel",
              "type": "component",
              "componentType": "Button",
              "props": {
                "label": "Отменить",
                "icon": "pi pi-times",
                "severity": "secondary",
                "outlined": true
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/users/{$location.routeParams.user_id}/prizes/{$location.routeParams.prize_id}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
