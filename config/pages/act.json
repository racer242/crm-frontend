{
  "id": "act",
  "type": "page",
  "route": "/acts/[act_id]",
  "state": {
    "loading": false,
    "initialized": true,
    "saveResult": null,
    "actData": {
      "user_id": "",
      "user_name": "",
      "user_email": "",
      "issue_date": "",
      "prize_name": "",
      "status": "",
      "document_blank_url": "",
      "signed_scan_url": "",
      "issueDateFormatted": "",
      "statusLabel": "",
      "statusSeverity": "",
      "prize_id": "",
      "act_issue_date": "",
      "prize_variants": [],
      "statuses": []
    }
  },
  "meta": {
    "title": "Акт — CRM Platform"
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/acts/{$location.routeParams.act_id}",
      "method": "GET",
      "target": "state.actData"
    }
  ],
  "shortcuts": {
    "deleteAct": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "setProperty",
            "params": {
              "target": "state.saveResult",
              "value": null
            }
          },
          {
            "type": "confirm",
            "params": {
              "message": "Вы уверены, что хотите удалить этот акт?",
              "onConfirm": [
                {
                  "type": "sendRequest",
                  "params": {
                    "url": "/api/acts/{$location.routeParams.act_id}",
                    "method": "DELETE",
                    "target": "state.saveResult",
                    "onSuccess": [
                      {
                        "type": "showToast",
                        "params": {
                          "severity": "success",
                          "summary": "Успешно",
                          "message": "Акт удален"
                        }
                      },
                      {
                        "type": "navigate",
                        "params": { "url": "/acts" }
                      }
                    ],
                    "onError": [
                      {
                        "type": "showToast",
                        "params": {
                          "severity": "error",
                          "summary": "Ошибка",
                          "message": "Не удалось удалить акт"
                        }
                      }
                    ]
                  }
                }
              ],
              "onCancel": []
            }
          }
        ]
      }
    }
  },
  "sections": [
    {
      "id": "breadcrumbSection",
      "type": "section",
      "className": "",
      "blocks": [
        {
          "id": "breadcrumbBlock",
          "type": "block",
          "components": [
            {
              "id": "breadcrumb",
              "type": "component",
              "componentType": "Breadcrumb",
              "className": "border-none p-0",
              "props": {
                "home": { "icon": "pi pi-home", "url": "/" },
                "model": [
                  { "label": "Акты", "route": "/acts" },
                  { "label": "@state.actData.prize_name" }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "mainLayout",
      "type": "section",
      "className": "flex mb-5",
      "grid": {
        "cols": ["col-12 lg:col-8", "col-12 lg:col-4"],
        "padding": "p-2"
      },
      "blocks": [
        {
          "id": "actDetailsBlock",
          "type": "block",
          "wrapper": {
            "component": "Panel",
            "props": { "header": "Информация об акте" }
          },
          "className": "flex flex-column gap-3",
          "components": [
            {
              "id": "issueDateGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Дата выдачи",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "issueDate",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": { "value": "@state.actData.issueDateFormatted" }
                  }
                ]
              }
            },
            {
              "id": "prizeGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Приз",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "prizeName",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": { "value": "@state.actData.prize_name" }
                  }
                ]
              }
            },
            {
              "id": "statusGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Статус",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "statusTag",
                    "type": "component",
                    "componentType": "Tag",
                    "className": "text-sm px-2 py-1",
                    "props": {
                      "value": "@state.actData.statusLabel",
                      "severity": "@state.actData.statusSeverity"
                    }
                  }
                ]
              }
            },
            {
              "id": "documentBlankGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Бланк документа",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "documentBlankLink",
                    "type": "component",
                    "componentType": "Button",
                    "props": {
                      "label": "Скачать",
                      "icon": "pi pi-download",
                      "size": "small",
                      "severity": "info",
                      "outlined": true
                    },
                    "events": [
                      {
                        "type": "onClick",
                        "commands": [
                          {
                            "type": "log",
                            "params": {
                              "message": "Download {$state.actData.document_blank_url}",
                              "condition": "{$state.actData.document_blank_url}"
                            }
                          },
                          {
                            "type": "showToast",
                            "params": {
                              "severity": "warn",
                              "summary": "Бланк отсутствует",
                              "message": "Бланк документа для данного акта не загружен",
                              "condition": {
                                "value": "{$state.actData.document_blank_url}",
                                "not": true
                              }
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            {
              "id": "signedScanGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Фото подписанного скана",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "signedScanLink",
                    "type": "component",
                    "componentType": "Button",
                    "props": {
                      "label": "Скачать",
                      "icon": "pi pi-download",
                      "size": "small",
                      "severity": "info",
                      "outlined": true
                    },
                    "events": [
                      {
                        "type": "onClick",
                        "commands": [
                          {
                            "type": "log",
                            "params": {
                              "message": "Download {$state.actData.signed_scan_url}",
                              "condition": "{$state.actData.signed_scan_url}"
                            }
                          },
                          {
                            "type": "showToast",
                            "params": {
                              "severity": "warn",
                              "summary": "Скан отсутствует",
                              "message": "Фото подписанного скана для данного акта не загружено",
                              "condition": {
                                "value": "{$state.actData.signed_scan_url}",
                                "not": true
                              }
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            }
          ]
        },
        {
          "id": "extraDetailsBlock",
          "type": "block",
          "className": "flex flex-column gap-3",
          "components": [
            {
              "id": "userInfoPanel",
              "type": "component",
              "componentType": "Panel",
              "className": "flex flex-column gap-3",
              "props": {
                "header": "Участник",
                "components": [
                  {
                    "id": "userNameGroup",
                    "type": "component",
                    "componentType": "LabelledGroup",
                    "className": "w-full grid align-items-center mb-2",
                    "props": {
                      "label": "Имя",
                      "labelClassName": "text-sm col-4 text-right",
                      "containerClassName": "col-8",
                      "components": [
                        {
                          "id": "userNameLink",
                          "type": "component",
                          "componentType": "Text",
                          "className": "m-0 font-bold text-lg text-primary",
                          "props": { "value": "@state.actData.user_name" },
                          "events": [
                            {
                              "type": "onClick",
                              "commands": [
                                {
                                  "type": "navigate",
                                  "params": {
                                    "url": "/users/{@state.actData.user_id}"
                                  }
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  },
                  {
                    "id": "userEmailGroup",
                    "type": "component",
                    "componentType": "LabelledGroup",
                    "className": "w-full grid align-items-center mb-2",
                    "props": {
                      "label": "Email",
                      "labelClassName": "text-sm col-4 text-right",
                      "containerClassName": "col-8",
                      "components": [
                        {
                          "id": "userEmailLink",
                          "type": "component",
                          "componentType": "Text",
                          "className": "m-0 font-bold text-lg text-primary",
                          "props": { "value": "@state.actData.user_email" },
                          "events": [
                            {
                              "type": "onClick",
                              "commands": [
                                {
                                  "type": "executeCommand",
                                  "params": {
                                    "command": "window.open('mailto:{@state.actData.user_email}', '_blank')"
                                  }
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  }
                ]
              }
            },
            {
              "id": "prizeInfoPanel",
              "type": "component",
              "componentType": "Panel",
              "className": "flex flex-column gap-3",
              "props": {
                "header": "Приз",
                "components": [
                  {
                    "id": "prizeNameGroup",
                    "type": "component",
                    "componentType": "LabelledGroup",
                    "className": "w-full grid align-items-center mb-2",
                    "props": {
                      "label": "Название",
                      "labelClassName": "text-sm col-4 text-right",
                      "containerClassName": "col-8",
                      "components": [
                        {
                          "id": "prizeNameText",
                          "type": "component",
                          "componentType": "Text",
                          "className": "m-0 font-bold text-lg",
                          "props": { "value": "@state.actData.prize_name" }
                        }
                      ]
                    }
                  },
                  {
                    "id": "prizeLinkBtn",
                    "type": "component",
                    "componentType": "Button",
                    "props": {
                      "icon": "pi pi-gift",
                      "label": "Перейти к призу",
                      "size": "small",
                      "severity": "info",
                      "outlined": true,
                      "className": "w-full"
                    },
                    "events": [
                      {
                        "type": "onClick",
                        "commands": [
                          {
                            "type": "navigate",
                            "params": {
                              "url": "/prizes/#{state.actData.prize_id}"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "buttonsSection",
      "type": "section",
      "className": "flex justify-content-center",
      "blocks": [
        {
          "id": "buttonsBlock",
          "type": "block",
          "wrapper": {
            "showHeader": false,
            "component": "Panel",
            "props": {
              "className": "flex-grow-1",
              "pt": {
                "content": {
                  "style": { "background": "var(--surface-50) !important" }
                }
              }
            }
          },
          "className": "flex flex-wrap gap-3 justify-content-center md:justify-content-start",
          "components": [
            {
              "id": "btnEdit",
              "type": "component",
              "componentType": "Button",
              "props": {
                "icon": "pi pi-pencil",
                "label": "Редактировать",
                "size": "small",
                "severity": "info"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/acts/{#location.routeParams.act_id}/edit"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "btnDelete",
              "type": "component",
              "componentType": "Button",
              "props": {
                "icon": "pi pi-trash",
                "label": "Удалить",
                "size": "small",
                "severity": "danger",
                "outlined": true
              },
              "events": [{ "type": "onClick", "commands": ["deleteAct"] }]
            }
          ]
        }
      ]
    }
  ]
}
