{
  "id": "user-receipts",
  "type": "page",
  "route": "/users/[user_id]/receipts",
  "state": {
    "loading": false,
    "initialized": true,
    "filtersVisible": false,
    "userData": {
      "id": "",
      "fullName": ""
    },
    "receipts": {
      "value": [],
      "columns": [],
      "totalRecords": 0,
      "rows": 10,
      "first": 0,
      "sortField": "",
      "sortOrder": 1,
      "filters": [],
      "search": ""
    }
  },
  "meta": {
    "title": "Чеки участника — CRM Platform"
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}",
      "method": "GET",
      "target": "state.userData"
    },
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}/receipts",
      "data": {
        "first": "{$location.params.first}",
        "rows": "{$location.params.rows}",
        "sortField": "{$location.params.sortField}",
        "sortOrder": "{$location.params.sortOrder}",
        "search": "{$location.params.search}",
        "filters": "{$location.params.filters}"
      },
      "method": "GET",
      "target": "state.receipts"
    }
  ],
  "shortcuts": {
    "requestUserReceipts": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "sendRequest",
            "params": {
              "url": "/api/users/{$location.routeParams.user_id}/receipts",
              "method": "GET",
              "target": "state.receipts",
              "data": {
                "event": "{$event}",
                "first": "{$state.receipts.first}",
                "rows": "{$state.receipts.rows}",
                "sortField": "{$state.receipts.sortField}",
                "sortOrder": "{$state.receipts.sortOrder}",
                "search": "{$state.receipts.search}",
                "filters": "{$state.receipts.filters}"
              },
              "format": { "$ref": "../system/list-request-format.json" }
            }
          },
          {
            "type": "mergeUrlParams",
            "params": {
              "values": {
                "first": "{$state.receipts.first}",
                "rows": "{$state.receipts.rows}",
                "sortField": "{$state.receipts.sortField}",
                "sortOrder": "{$state.receipts.sortOrder}",
                "search": "{$state.receipts.search}",
                "filters": "{$state.receipts.filters}"
              },
              "format": [
                {
                  "prop": "filters",
                  "type": "PopIfHasNullProps",
                  "params": { "props": ["value"] }
                },
                {
                  "prop": "filters",
                  "type": "RemoveProps",
                  "params": { "props": ["name", "type", "opts"] }
                }
              ]
            }
          }
        ]
      }
    }
  },
  "sections": [
    {
      "id": "breadcrumbSection",
      "type": "section",
      "className": "",
      "blocks": [
        {
          "id": "breadcrumbBlock",
          "type": "block",
          "components": [
            {
              "id": "breadcrumb",
              "type": "component",
              "componentType": "Breadcrumb",
              "className": "border-none p-0",
              "props": {
                "home": { "icon": "pi pi-home", "url": "/" },
                "model": [
                  { "label": "Участники", "route": "/users" },
                  {
                    "label": "@state.userData.fullName",
                    "route": "/users/{@state.userData.id}"
                  },
                  { "label": "Чеки" }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "menuSection",
      "type": "section",
      "blocks": [
        {
          "id": "menuBlock",
          "type": "block",
          "className": "w-full",
          "components": [
            {
              "id": "menubar",
              "type": "component",
              "componentType": "Menubar",
              "props": {
                "activeItemId": "production",
                "pt": { "menu": { "className": "gap-1" } },
                "$ref": "../menus/user.json"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "receiptsFilters",
      "type": "section",
      "className": "flex flex-column gap-3 mb-3",
      "blocks": [
        {
          "id": "receiptsSearchBlock",
          "type": "block",
          "className": "w-full flex gap-3",
          "components": [
            {
              "id": "receiptsSearchInput",
              "type": "component",
              "className": "w-full p-inputtext-sm mb-0",
              "componentType": "InputTextWithThrottle",
              "props": {
                "placeholder": "Быстрый поиск...",
                "throttleDelay": 500,
                "value": "@state.receipts.search"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.receipts.search"
                      }
                    },
                    "requestUserReceipts"
                  ]
                }
              ]
            },
            {
              "id": "receiptsToggleFilters",
              "type": "component",
              "componentType": "Button",
              "className": "min-w-max flex-grow-0 px-3",
              "props": {
                "icon": "pi pi-filter",
                "severity": "primary",
                "outlined": true,
                "size": "small",
                "label": "Фильтры"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "receiptsActiveFilterBlock",
          "type": "block",
          "wrapper": {
            "className": "w-full"
          },
          "components": [
            {
              "id": "receiptsActiveFilterChips",
              "type": "component",
              "componentType": "ActiveFiltersBar",
              "props": {
                "value": "@state.receipts.filters"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.receipts.filters"
                      }
                    },
                    "requestUserReceipts"
                  ]
                }
              ]
            },
            {
              "id": "receiptsFilterDrawer",
              "type": "component",
              "componentType": "FiltersPanel",
              "props": {
                "value": "@state.receipts.filters",
                "visible": "@state.filtersVisible",
                "position": "right",
                "header": "Фильтры"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.receipts.filters"
                      }
                    },
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    },
                    "requestUserReceipts"
                  ]
                },
                {
                  "type": "onHide",
                  "commands": [
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "receiptsTableSection",
      "type": "section",
      "blocks": [
        {
          "id": "receiptsTableBlock",
          "type": "block",
          "className": "w-full",
          "components": [
            {
              "id": "receiptsTable",
              "type": "component",
              "componentType": "DataTable",
              "props": {
                "value": "@state.receipts.value",
                "columns": "@state.receipts.columns",
                "totalRecords": "@state.receipts.totalRecords",
                "rows": "@state.receipts.rows",
                "first": "@state.receipts.first",
                "sortField": "@state.receipts.sortField",
                "sortOrder": "@state.receipts.sortOrder",
                "paginator": true,
                "lazy": true,
                "size": "normal",
                "selectionMode": "single",
                "rowsPerPageOptions": [5, 10, 25, 50]
              },
              "events": [
                {
                  "type": "onPage",
                  "commands": ["requestUserReceipts"]
                },
                {
                  "type": "onSort",
                  "commands": ["requestUserReceipts"]
                },
                {
                  "type": "onRowClick",
                  "commands": [
                    {
                      "type": "log",
                      "params": {
                        "message": "{$event.data}"
                      }
                    },
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/users/{$location.routeParams.user_id}/receipts/{$event.data._rowId}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
