{
  "id": "user-codes",
  "type": "page",
  "route": "/users/[user_id]/codes",
  "state": {
    "loading": false,
    "initialized": true,
    "filtersVisible": false,
    "isEditDialogVisible": false,
    "saveResult": null,
    "userData": {
      "id": "",
      "fullName": ""
    },
    "codes": {
      "value": [],
      "columns": [],
      "totalRecords": 0,
      "rows": 10,
      "first": 0,
      "sortField": "",
      "sortOrder": 1,
      "filters": [],
      "search": ""
    },
    "editingCode": {
      "id": "",
      "code": "",
      "date": ""
    }
  },
  "meta": {
    "title": "Коды участника — CRM Platform"
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}",
      "method": "GET",
      "target": "state.userData"
    },
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}/codes",
      "data": {
        "first": "{$location.params.first}",
        "rows": "{$location.params.rows}",
        "sortField": "{$location.params.sortField}",
        "sortOrder": "{$location.params.sortOrder}",
        "search": "{$location.params.search}",
        "filters": "{$location.params.filters}"
      },
      "method": "GET",
      "target": "state.codes"
    }
  ],
  "shortcuts": {
    "openEditCodeDialog": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "setProperty",
            "params": {
              "source": "{#row._rowId}",
              "target": "state.editingCode.id"
            }
          },
          {
            "type": "setProperty",
            "params": {
              "source": "{#row.code}",
              "target": "state.editingCode.code"
            }
          },
          {
            "type": "setProperty",
            "params": {
              "source": "{#row.date}",
              "target": "state.editingCode.date"
            }
          },
          {
            "type": "setProperty",
            "params": {
              "target": "state.isEditDialogVisible",
              "value": true
            }
          }
        ]
      }
    },
    "saveCode": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "setProperty",
            "params": {
              "target": "state.saveResult",
              "value": null
            }
          },
          {
            "type": "sendRequest",
            "params": {
              "url": "/api/codes/{$state.editingCode.id}",
              "method": "PATCH",
              "target": "state.saveResult",
              "data": {
                "code": "{$state.editingCode.code}",
                "date": "{$state.editingCode.date}"
              },
              "onSuccess": [
                {
                  "type": "setProperty",
                  "params": {
                    "target": "state.isEditDialogVisible",
                    "value": false
                  }
                },
                {
                  "type": "showToast",
                  "params": {
                    "severity": "success",
                    "summary": "Успешно",
                    "message": "Код обновлен"
                  }
                },
                {
                  "type": "executeShortcut",
                  "params": {
                    "shortcut": "requestUserCodes"
                  }
                }
              ],
              "onError": [
                {
                  "type": "showToast",
                  "params": {
                    "severity": "error",
                    "summary": "Ошибка",
                    "message": "Не удалось сохранить код"
                  }
                }
              ]
            }
          }
        ]
      }
    },
    "requestUserCodes": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "sendRequest",
            "params": {
              "url": "/api/users/{$location.routeParams.user_id}/codes",
              "method": "GET",
              "target": "state.codes",
              "data": {
                "event": "{$event}",
                "first": "{$state.codes.first}",
                "rows": "{$state.codes.rows}",
                "sortField": "{$state.codes.sortField}",
                "sortOrder": "{$state.codes.sortOrder}",
                "search": "{$state.codes.search}",
                "filters": "{$state.codes.filters}"
              }
            }
          },
          {
            "type": "mergeUrlParams",
            "params": {
              "values": {
                "first": "{$state.codes.first}",
                "rows": "{$state.codes.rows}",
                "sortField": "{$state.codes.sortField}",
                "sortOrder": "{$state.codes.sortOrder}",
                "search": "{$state.codes.search}",
                "filters": "{$state.codes.filters}"
              },
              "format": [
                {
                  "prop": "filters",
                  "type": "PopIfHasNullProps",
                  "params": { "props": ["value"] }
                },
                {
                  "prop": "filters",
                  "type": "RemoveProps",
                  "params": { "props": ["name", "type", "opts"] }
                }
              ]
            }
          }
        ]
      }
    }
  },
  "sections": [
    {
      "id": "breadcrumbSection",
      "type": "section",
      "className": "",
      "blocks": [
        {
          "id": "breadcrumbBlock",
          "type": "block",
          "components": [
            {
              "id": "breadcrumb",
              "type": "component",
              "componentType": "Breadcrumb",
              "className": "border-none p-0",
              "props": {
                "home": { "icon": "pi pi-home", "url": "/" },
                "model": [
                  { "label": "Участники", "route": "/users" },
                  {
                    "label": "@state.userData.fullName",
                    "route": "/users/{@state.userData.id}"
                  },
                  { "label": "Коды" }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "menuSection",
      "type": "section",
      "blocks": [
        {
          "id": "menuBlock",
          "type": "block",
          "className": "w-full",
          "components": [
            {
              "id": "menubar",
              "type": "component",
              "componentType": "Menubar",
              "props": {
                "activeItemId": "production",
                "activeSubitemId": "codes",
                "pt": { "menu": { "className": "gap-1" } },
                "$ref": "../menus/user.json"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "codesFilters",
      "type": "section",
      "className": "flex flex-column gap-3 mb-3",
      "blocks": [
        {
          "id": "codesSearchBlock",
          "type": "block",
          "className": "w-full flex gap-3",
          "components": [
            {
              "id": "codesSearchInput",
              "type": "component",
              "className": "w-full p-inputtext-sm mb-0",
              "componentType": "InputTextWithThrottle",
              "props": {
                "placeholder": "Быстрый поиск...",
                "throttleDelay": 500,
                "value": "@state.codes.search"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.codes.search"
                      }
                    },
                    "requestUserCodes"
                  ]
                }
              ]
            },
            {
              "id": "codesToggleFilters",
              "type": "component",
              "componentType": "Button",
              "className": "min-w-max flex-grow-0 px-3",
              "props": {
                "icon": "pi pi-filter",
                "severity": "primary",
                "outlined": true,
                "size": "small",
                "label": "Фильтры"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "codesBtnAdd",
              "type": "component",
              "componentType": "Button",
              "className": "min-w-max flex-grow-0 px-3",
              "props": {
                "icon": "pi pi-plus",
                "severity": "success",
                "size": "small",
                "label": "Добавить"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "showToast",
                      "params": {
                        "severity": "info",
                        "message": "Заглушка"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "codesActiveFilterBlock",
          "type": "block",
          "wrapper": {
            "className": "w-full"
          },
          "components": [
            {
              "id": "codesActiveFilterChips",
              "type": "component",
              "componentType": "ActiveFiltersBar",
              "props": {
                "value": "@state.codes.filters"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.codes.filters"
                      }
                    },
                    "requestUserCodes"
                  ]
                }
              ]
            },
            {
              "id": "codesFilterDrawer",
              "type": "component",
              "componentType": "FiltersPanel",
              "props": {
                "value": "@state.codes.filters",
                "visible": "@state.filtersVisible",
                "position": "right",
                "header": "Фильтры"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.codes.filters"
                      }
                    },
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    },
                    "requestUserCodes"
                  ]
                },
                {
                  "type": "onHide",
                  "commands": [
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "codesTableSection",
      "type": "section",
      "className": "mb-0",
      "blocks": [
        {
          "id": "codesTableBlock",
          "type": "block",
          "className": "w-full",
          "components": [
            {
              "id": "codesTable",
              "type": "component",
              "componentType": "DataTable",
              "props": {
                "value": "@state.codes.value",
                "columns": "@state.codes.columns",
                "totalRecords": "@state.codes.totalRecords",
                "rows": "@state.codes.rows",
                "first": "@state.codes.first",
                "sortField": "@state.codes.sortField",
                "sortOrder": "@state.codes.sortOrder",
                "paginator": true,
                "lazy": true,
                "size": "normal",
                "rowsPerPageOptions": [5, 10, 25, 50],
                "customColumns": [
                  {
                    "field": "actions",
                    "order": -1,
                    "body": [
                      {
                        "componentType": "Button",
                        "props": {
                          "icon": "pi pi-pencil",
                          "link": true,
                          "size": "small",
                          "pt": { "label": { "className": "font-normal" } }
                        },
                        "events": [
                          {
                            "type": "onClick",
                            "commands": ["openEditCodeDialog"]
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              "events": [
                {
                  "type": "onPage",
                  "commands": ["requestUserCodes"]
                },
                {
                  "type": "onSort",
                  "commands": ["requestUserCodes"]
                }
              ]
            },
            {
              "id": "editCodeDialog",
              "type": "component",
              "componentType": "Dialog",
              "props": {
                "header": "Редактирование кода",
                "visible": "@state.isEditDialogVisible",
                "modal": true,
                "closable": true,
                "draggable": false,
                "resizable": false,
                "style": { "width": "450px" },
                "containerClassName": "flex flex-column gap-3 pt-3",
                "components": [
                  {
                    "id": "dateGroup",
                    "type": "component",
                    "componentType": "LabelledGroup",
                    "className": "flex flex-column gap-1",
                    "props": {
                      "label": "Дата регистрации",
                      "components": [
                        {
                          "id": "dateInput",
                          "type": "component",
                          "componentType": "Calendar",
                          "props": {
                            "value": "@state.editingCode.date",
                            "dateFormat": "dd.mm.yy",
                            "showIcon": true,
                            "className": "w-full"
                          },
                          "events": [
                            {
                              "type": "onChange",
                              "commands": [
                                {
                                  "type": "setProperty",
                                  "params": {
                                    "source": "event.value",
                                    "target": "state.editingCode.date"
                                  }
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  },
                  {
                    "id": "codeGroup",
                    "type": "component",
                    "componentType": "LabelledGroup",
                    "className": "flex flex-column gap-1",
                    "props": {
                      "label": "Код",
                      "components": [
                        {
                          "id": "codeInput",
                          "type": "component",
                          "componentType": "InputText",
                          "props": {
                            "value": "@state.editingCode.code",
                            "className": "w-full"
                          },
                          "events": [
                            {
                              "type": "onChange",
                              "commands": [
                                {
                                  "type": "setProperty",
                                  "params": {
                                    "source": "event.value",
                                    "target": "state.editingCode.code"
                                  }
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  },
                  {
                    "id": "dialogButtons",
                    "type": "component",
                    "componentType": "LayoutGroup",
                    "className": "flex justify-content-end gap-2 mt-3",
                    "props": {
                      "spacing": "gap-2",
                      "components": [
                        {
                          "id": "btnCancelCode",
                          "type": "component",
                          "componentType": "Button",
                          "props": {
                            "label": "Отмена",
                            "icon": "pi pi-times",
                            "severity": "secondary",
                            "outlined": true,
                            "size": "small"
                          },
                          "events": [
                            {
                              "type": "onClick",
                              "commands": [
                                {
                                  "type": "setProperty",
                                  "params": {
                                    "target": "state.isEditDialogVisible",
                                    "value": false
                                  }
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "id": "btnSaveCode",
                          "type": "component",
                          "componentType": "Button",
                          "props": {
                            "label": "Сохранить",
                            "icon": "pi pi-check",
                            "severity": "success",
                            "size": "small"
                          },
                          "events": [
                            {
                              "type": "onClick",
                              "commands": ["saveCode"]
                            }
                          ]
                        }
                      ]
                    }
                  }
                ]
              },
              "events": [
                {
                  "type": "onHide",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "target": "state.isEditDialogVisible",
                        "value": false
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
