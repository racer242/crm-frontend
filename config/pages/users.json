{
  "id": "users",
  "type": "page",
  "route": "/users",
  "state": {
    "loading": false,
    "initialized": true,
    "filtersVisible": false,
    "users": {
      "value": [],
      "columns": [],
      "totalRecords": 10,
      "rows": 10,
      "first": 0,
      "sortField": "",
      "sortOrder": 1,
      "filters": [],
      "search": ""
    }
  },
  "meta": {
    "title": "Участники — CRM Platform"
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/users",
      "data": {
        "first": "{$location.params.first}",
        "rows": "{$location.params.rows}",
        "sortField": "{$location.params.sortField}",
        "sortOrder": "{$location.params.sortOrder}",
        "search": "{$location.params.search}",
        "filters": "{$location.params.filters}"
      },
      "method": "GET",
      "target": "state.users"
    }
  ],
  "shortcuts": {
    "requestUsers": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "log",
            "params": {
              "message": {
                "event": "{$event}",
                "data": "{$state.users}",
                "toSend": {
                  "event": "{$event}",
                  "first": "{$state.users.first}",
                  "rows": "{$state.users.rows}",
                  "sortField": "{$state.users.sortField}",
                  "sortOrder": "{$state.users.sortOrder}",
                  "search": "{$state.users.search}",
                  "filters": "{$state.users.filters}"
                }
              }
            }
          },
          {
            "type": "sendRequest",
            "params": {
              "url": "/api/users",
              "method": "GET",
              "target": "state.users",
              "data": {
                "event": "{$event}",
                "first": "{$state.users.first}",
                "rows": "{$state.users.rows}",
                "sortField": "{$state.users.sortField}",
                "sortOrder": "{$state.users.sortOrder}",
                "search": "{$state.users.search}",
                "filters": "{$state.users.filters}"
              },
              "format": { "$ref": "../system/list-request-format.json" },
              "onSuccess": [
                {
                  "type": "log",
                  "params": {
                    "message": {
                      "success": "{$event}"
                    }
                  }
                }
              ],
              "onError": [
                {
                  "type": "log",
                  "params": {
                    "message": {
                      "error": "{$event}"
                    }
                  }
                }
              ]
            }
          },
          {
            "type": "mergeUrlParams",
            "params": {
              "values": {
                "first": "{$state.users.first}",
                "rows": "{$state.users.rows}",
                "sortField": "{$state.users.sortField}",
                "sortOrder": "{$state.users.sortOrder}",
                "search": "{$state.users.search}",
                "filters": "{$state.users.filters}"
              },
              "format": [
                {
                  "prop": "filters",
                  "type": "PopIfHasNullProps",
                  "params": { "props": ["value"] }
                },
                {
                  "prop": "filters",
                  "type": "RemoveProps",
                  "params": { "props": ["name", "type", "opts"] }
                }
              ]
            }
          }
        ]
      }
    }
  },
  "sections": [
    {
      "id": "usersHeader",
      "type": "section",
      "className": "flex",
      "blocks": [
        {
          "id": "usersTitle",
          "type": "block",
          "components": [
            {
              "id": "usersPageTitle",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "Участники",
                "level": 1
              }
            }
          ]
        }
      ]
    },
    {
      "id": "usersFilters",
      "type": "section",
      "className": "flex flex-column gap-3 mb-3",
      "blocks": [
        {
          "id": "searchBlock",
          "type": "block",
          "className": "w-full flex gap-3",
          "components": [
            {
              "id": "searchInput",
              "type": "component",
              "className": "w-full p-inputtext-sm mb-0",
              "componentType": "InputTextWithThrottle",
              "props": {
                "placeholder": "Быстрый поиск...",
                "throttleDelay": 500,
                "value": "@state.users.search"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.users.search"
                      }
                    },
                    "requestUsers"
                  ]
                }
              ]
            },
            {
              "id": "toggleFilters",
              "type": "component",
              "componentType": "Button",
              "className": "min-w-max flex-grow-0 px-3",
              "props": {
                "icon": "pi pi-filter",
                "severity": "primary",
                "outlined": true,
                "size": "small",
                "label": "Фильтры"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "activeFilterBlock",
          "type": "block",
          "wrapper": {
            "className": "w-full"
          },
          "components": [
            {
              "id": "activeFilterChips",
              "type": "component",
              "componentType": "ActiveFiltersBar",
              "props": {
                "value": "@state.users.filters"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.users.filters"
                      }
                    },
                    "requestUsers"
                  ]
                }
              ]
            },
            {
              "id": "filterDrawer",
              "type": "component",
              "componentType": "FiltersPanel",
              "props": {
                "value": "@state.users.filters",
                "visible": "@state.filtersVisible",
                "position": "right",
                "header": "Фильтры"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.users.filters"
                      }
                    },
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    },
                    "requestUsers"
                  ]
                },
                {
                  "type": "onHide",
                  "commands": [
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "usersTableSection",
      "type": "section",
      "blocks": [
        {
          "id": "usersTableBlock",
          "type": "block",
          "className": "w-full",
          "components": [
            {
              "id": "usersTable",
              "type": "component",
              "componentType": "DataTable",
              "props": {
                "value": "@state.users.value",
                "columns": "@state.users.columns",
                "totalRecords": "@state.users.totalRecords",
                "rows": "@state.users.rows",
                "first": "@state.users.first",
                "sortField": "@state.users.sortField",
                "sortOrder": "@state.users.sortOrder",
                "paginator": true,
                "lazy": true,
                "size": "normal",
                "selectionMode": "single",
                "rowsPerPageOptions": [5, 10, 25, 50],
                "customColumns": [
                  {
                    "field": "email",
                    "header": "Email",
                    "sortable": true,
                    "body": [
                      {
                        "id": "sendButton",
                        "componentType": "Button",
                        "props": {
                          "icon": "pi pi-envelope",
                          "label": "{#field}",
                          "link": true,
                          "size": "small",
                          "pt": { "label": { "className": "font-normal" } }
                        },
                        "events": [
                          {
                            "type": "onClick",
                            "commands": [
                              {
                                "type": "navigate",
                                "params": {
                                  "url": "mailto:{#field}"
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              "events": [
                {
                  "type": "onPage",
                  "commands": ["requestUsers"]
                },
                {
                  "type": "onSort",
                  "commands": ["requestUsers"]
                },
                {
                  "type": "onRowClick",
                  "commands": [
                    {
                      "type": "log",
                      "params": {
                        "message": "{$event}"
                      }
                    },
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/users/{$event.data.id}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
