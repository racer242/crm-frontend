{
  "id": "users",
  "type": "page",
  "route": "/users",
  "state": {
    "loading": false,
    "initialized": true,
    "filtersVisible": false,
    "users": {
      "value": [],
      "columns": [],
      "totalRecords": 10,
      "rows": 10,
      "first": 0,
      "sortField": "",
      "sortOrder": 1,
      "filters": [],
      "search": ""
    }
  },
  "meta": {
    "title": "Участники — CRM Platform"
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/mocks/api/users/users.json",
      "method": "GET",
      "target": "state.users",
      "adapter": "stats.users.js"
    }
  ],
  "sections": [
    {
      "id": "usersHeader",
      "type": "section",
      "layout": {
        "type": "flex",
        "direction": "row",
        "justifyContent": "between"
      },
      "blocks": [
        {
          "id": "usersTitle",
          "type": "block",
          "components": [
            {
              "id": "usersPageTitle",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "Участники",
                "level": 1
              }
            }
          ]
        }
      ]
    },
    {
      "id": "usersFilters",
      "type": "section",
      "className": "flex flex-wrap gap-3",
      "blocks": [
        {
          "id": "searchBlock",
          "type": "block",
          "className": "w-full",
          "wrapper": {
            "className": "flex-grow-1"
          },
          "components": [
            {
              "id": "searchInput",
              "type": "component",
              "className": "w-full p-inputtext-sm",
              "componentType": "InputTextWithThrottle",
              "props": {
                "placeholder": "Быстрый поиск...",
                "throttleDelay": 500,
                "value": "@state.users.search"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.users.search"
                      }
                    },
                    {
                      "type": "log",
                      "params": {
                        "message": {
                          "event": { "search": "{$event.value}" },
                          "data": "{$state.users}"
                        }
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "filterBlock",
          "type": "block",
          "wrapper": {
            "className": "flex-initial"
          },
          "className": "flex flex-row gap-3 p-inputtext-sm justify-content-end",
          "components": [
            {
              "id": "toggleFilters",
              "type": "component",
              "componentType": "Button",
              "className": "min-w-max flex-grow-0 px-3",
              "props": {
                "icon": "pi pi-filter",
                "severity": "primary",
                "outlined": true,
                "size": "small",
                "label": "Фильтры"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "btnImportUsers",
              "type": "component",
              "componentType": "Button",
              "className": "min-w-max flex-grow-0 px-3",
              "props": {
                "icon": "pi pi-file-import",
                "severity": "primary",
                "outlined": true,
                "size": "small"
              }
            }
          ]
        },
        {
          "id": "activeFilterBlock",
          "type": "block",
          "wrapper": {
            "className": "w-full"
          },
          "components": [
            {
              "id": "activeFilterChips",
              "type": "component",
              "componentType": "ActiveFiltersBar",
              "props": {
                "value": "@state.users.filters"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.users.filters"
                      }
                    },
                    {
                      "type": "log",
                      "params": {
                        "message": {
                          "event": { "filters": "{$event.value}" },
                          "data": "{$state.users}"
                        }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "filterDrawer",
              "type": "component",
              "componentType": "FiltersPanel",
              "props": {
                "value": "@state.users.filters",
                "visible": "@state.filtersVisible",
                "position": "right",
                "header": "Фильтры"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.users.filters"
                      }
                    },
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    },
                    {
                      "type": "log",
                      "params": {
                        "message": {
                          "event": { "filters": "{$event.value}" },
                          "data": "{$state.users}"
                        }
                      }
                    }
                  ]
                },
                {
                  "type": "onHide",
                  "commands": [
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "usersTableSection",
      "type": "section",
      "blocks": [
        {
          "id": "usersTableBlock",
          "type": "block",
          "components": [
            {
              "id": "usersTable",
              "type": "component",
              "componentType": "DataTable",
              "props": {
                "value": "@state.users.value",
                "columns": "@state.users.columns",
                "totalRecords": "@state.users.totalRecords",
                "rows": "@state.users.rows",
                "first": "@state.users.first",
                "sortField": "@state.users.sortField",
                "sortOrder": "@state.users.sortOrder",
                "paginator": true,
                "lazy": true
              },
              "events": [
                {
                  "type": "onPage",
                  "commands": [
                    {
                      "type": "log",
                      "params": {
                        "message": {
                          "event": "{$event}",
                          "data": "{$state.users}"
                        }
                      }
                    }
                  ]
                },
                {
                  "type": "onSort",
                  "commands": [
                    {
                      "type": "log",
                      "params": {
                        "message": {
                          "event": "{$event}",
                          "data": "{$state.users}"
                        }
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
