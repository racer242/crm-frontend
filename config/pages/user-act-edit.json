{
  "id": "user-act-edit",
  "type": "page",
  "route": "/users/[user_id]/acts/[act_id]/edit",
  "state": {
    "loading": false,
    "saving": false,
    "saved": false,
    "sentSuccessfully": false,
    "userData": {
      "id": "",
      "first_name": "",
      "last_name": "",
      "email": "",
      "fullName": ""
    },
    "actData": {
      "id": "",
      "user_id": "",
      "issue_date": "",
      "prize_name": "",
      "status": "",
      "document_blank_url": "",
      "signed_scan_url": "",
      "issueDateFormatted": "",
      "statusLabel": "",
      "statusSeverity": "",
      "prize_id": "",
      "act_issue_date": "",
      "prize_variants": [],
      "statuses": []
    }
  },
  "meta": {
    "title": "Редактирование акта — CRM Platform"
  },
  "shortcuts": {
    "saveAct": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "setProperty",
            "params": {
              "target": "state.saving",
              "value": true
            }
          },
          {
            "type": "setProperty",
            "params": {
              "target": "state.saveResult",
              "value": null
            }
          },
          {
            "type": "sendRequest",
            "params": {
              "url": "/api/acts/{$location.routeParams.act_id}",
              "method": "PATCH",
              "data": {
                "issue_date": "{$state.actData.issue_date}",
                "status": "{$state.actData.status}"
              },
              "onSuccess": [
                {
                  "type": "setProperty",
                  "params": {
                    "target": "state.saving",
                    "value": false
                  }
                },
                {
                  "type": "setProperty",
                  "params": {
                    "target": "state.saved",
                    "value": true
                  }
                },
                {
                  "type": "setProperty",
                  "params": {
                    "target": "state.sentSuccessfully",
                    "value": true
                  }
                }
              ],
              "onError": [
                {
                  "type": "setProperty",
                  "params": {
                    "target": "state.saving",
                    "value": false
                  }
                },
                {
                  "type": "setProperty",
                  "params": {
                    "target": "state.sentSuccessfully",
                    "value": false
                  }
                },
                {
                  "type": "showToast",
                  "params": {
                    "severity": "error",
                    "summary": "Ошибка",
                    "message": "Не удалось сохранить акт"
                  }
                }
              ]
            }
          }
        ]
      }
    }
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}",
      "method": "GET",
      "target": "state.userData"
    },
    {
      "url": "{$config.baseURL}/api/acts/{$location.routeParams.act_id}",
      "method": "GET",
      "target": "state.actData"
    }
  ],
  "sections": [
    {
      "id": "breadcrumbSection",
      "type": "section",
      "className": "",
      "blocks": [
        {
          "id": "breadcrumbBlock",
          "type": "block",
          "components": [
            {
              "id": "breadcrumb",
              "type": "component",
              "componentType": "Breadcrumb",
              "className": "border-none p-0",
              "props": {
                "home": { "icon": "pi pi-home", "url": "/" },
                "model": [
                  { "label": "Участники", "route": "/users" },
                  {
                    "label": "@state.userData.fullName",
                    "route": "/users/{@state.userData.id}"
                  },
                  {
                    "label": "Акты",
                    "route": "/users/{@state.userData.id}/acts"
                  },
                  {
                    "label": "@state.actData.prize_name",
                    "route": "/users/{@state.userData.id}/acts/{@state.actData.id}"
                  },
                  { "label": "Редактирование" }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "formMainSection",
      "type": "section",
      "className": "",
      "grid": {
        "cols": ["col-12 lg:col-6", "col-12 lg:col-6"],
        "padding": "p-2"
      },
      "blocks": [
        {
          "id": "infoBlock",
          "type": "block",
          "wrapper": {
            "component": "Panel",
            "props": {
              "header": "Информация об акте"
            }
          },
          "className": "flex flex-column",
          "components": [
            {
              "id": "userNameGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "flex flex-column gap-1 mb-2",
              "props": {
                "label": "Участник",
                "labelClassName": "font-bold text-sm",
                "components": [
                  {
                    "id": "userName",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.userData.fullName"
                    }
                  }
                ]
              }
            },
            {
              "id": "userEmailGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "flex flex-column gap-1 mb-2",
              "props": {
                "label": "Email",
                "labelClassName": "font-bold text-sm",
                "components": [
                  {
                    "id": "userEmail",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.userData.email"
                    }
                  }
                ]
              }
            },
            {
              "id": "prizeNameGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "flex flex-column gap-1 mb-2",
              "props": {
                "label": "Приз",
                "labelClassName": "font-bold text-sm",
                "components": [
                  {
                    "id": "prizeName",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.actData.prize_name"
                    }
                  }
                ]
              }
            }
          ]
        },
        {
          "id": "editBlock",
          "type": "block",
          "wrapper": {
            "component": "Panel",
            "props": {
              "header": "Редактирование"
            }
          },
          "className": "flex flex-column",
          "components": [
            {
              "id": "issueDateGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "flex flex-column gap-1 mb-2",
              "props": {
                "label": "Дата выдачи",
                "labelClassName": "font-bold text-sm",
                "components": [
                  {
                    "id": "issueDateInput",
                    "type": "component",
                    "componentType": "Calendar",
                    "props": {
                      "value": "@state.actData.issue_date",
                      "dateFormat": "dd.mm.yy",
                      "showIcon": true,
                      "className": "w-full"
                    },
                    "events": [
                      {
                        "type": "onChange",
                        "commands": [
                          {
                            "type": "setProperty",
                            "params": {
                              "source": "event.value",
                              "target": "state.actData.issue_date"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            {
              "id": "statusGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "flex flex-column gap-1 mb-2",
              "props": {
                "label": "Статус",
                "labelClassName": "font-bold text-sm",
                "components": [
                  {
                    "id": "statusDropdown",
                    "type": "component",
                    "componentType": "Dropdown",
                    "props": {
                      "options": "@state.actData.statuses",
                      "value": "@state.actData.status",
                      "optionLabel": "name",
                      "optionValue": "id",
                      "placeholder": "Выберите статус",
                      "className": "w-full"
                    },
                    "events": [
                      {
                        "type": "onChange",
                        "commands": [
                          {
                            "type": "setProperty",
                            "params": {
                              "source": "event.value",
                              "target": "state.actData.status"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "buttonsSection",
      "type": "section",
      "className": "flex justify-content-center",
      "blocks": [
        {
          "id": "buttonsBlock",
          "type": "block",
          "wrapper": {
            "showHeader": false,
            "component": "Panel",
            "props": {
              "className": "flex-grow-1",
              "pt": {
                "content": {
                  "style": { "background": "var(--surface-50) !important" }
                }
              }
            }
          },
          "className": "flex flex-wrap gap-3 justify-content-center md:justify-content-start",
          "components": [
            {
              "id": "btnSaveAndGo",
              "type": "component",
              "componentType": "Button",
              "props": {
                "label": "Сохранить",
                "icon": "pi pi-check",
                "severity": "success",
                "disabled": "@state.saving"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    "saveAct",
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/users/{$location.routeParams.user_id}/acts/{$location.routeParams.act_id}",
                        "condition": "{$state.sentSuccessfully}"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "btnApply",
              "type": "component",
              "componentType": "Button",
              "props": {
                "label": "Применить",
                "icon": "pi pi-check",
                "severity": "success",
                "outlined": true,
                "disabled": "@state.saving"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    "saveAct",
                    {
                      "type": "showToast",
                      "params": {
                        "severity": "success",
                        "summary": "Успешно",
                        "message": "Данные акта сохранены",
                        "condition": "{$state.sentSuccessfully}"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "btnCancel",
              "type": "component",
              "componentType": "Button",
              "props": {
                "label": "Отменить изменения",
                "icon": "pi pi-times",
                "severity": "secondary",
                "outlined": true
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/users/{$location.routeParams.user_id}/acts/{$location.routeParams.act_id}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
