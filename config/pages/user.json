{
  "id": "user",
  "type": "page",
  "route": "/users/[user_id]",
  "state": {
    "loading": false,
    "initialized": true,
    "userData": {
      "id": "",
      "bot_id": "",
      "first_name": "",
      "last_name": "",
      "email": "",
      "phone": "",
      "reg_date": "",
      "auth_date": "",
      "referral": "",
      "city": "",
      "ip": "",
      "is_blocked": false,
      "block_reason": "",
      "groups": [],
      "points": 0,
      "prizes": 0,
      "receipts": 0,
      "codes": 0,
      "gtins": 0,
      "products": 0,
      "messages": 0,
      "fullName": "",
      "initials": "",
      "regDateFormatted": "",
      "authDateFormatted": "",
      "groupList": [],
      "groupsText": "",
      "statusLabel": "",
      "statusSeverity": ""
    }
  },
  "meta": {
    "title": "Участник — CRM Platform"
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}",
      "method": "GET",
      "target": "state.userData",
      "adapter": "user.response.js"
    }
  ],
  "sections": [
    {
      "id": "breadcrumbSection",
      "type": "section",
      "className": "",
      "blocks": [
        {
          "id": "userTitleBlock",
          "type": "block",
          "components": [
            {
              "id": "breadcrumb",
              "type": "component",
              "componentType": "Breadcrumb",
              "className": "border-none p-0",
              "props": {
                "home": { "icon": "pi pi-home", "url": "/" },
                "model": [
                  { "label": "Участники", "route": "/users" },
                  { "label": "@state.userData.fullName" }
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "id": "statsRowSection",
      "type": "section",
      "className": "flex flex-column",
      "blocks": [
        {
          "id": "statCardsBlock",
          "type": "block",
          "className": "mb-5",
          "grid": {
            "cols": [
              "col-6 lg:col-3",
              "col-6 lg:col-3",
              "col-6 lg:col-3",
              "col-6 lg:col-3"
            ],
            "padding": "p-2"
          },
          "components": [
            {
              "id": "activityReceipts",
              "type": "component",
              "componentType": "StatCard",
              "className": "h-full",
              "props": {
                "title": "Чеки",
                "subTitle": "проверены",
                "value": "@state.userData.receipts",
                "icon": "pi pi-receipt"
              }
            },
            {
              "id": "activityCodes",
              "type": "component",
              "componentType": "StatCard",
              "className": "h-full",
              "props": {
                "title": "Коды",
                "value": "@state.userData.codes",
                "icon": "pi pi-star"
              },
              "state": {}
            },
            {
              "id": "activityGtins",
              "type": "component",
              "componentType": "StatCard",
              "className": "h-full",
              "props": {
                "title": "Коды ЧЗ",
                "value": "@state.userData.gtins",
                "icon": "pi pi-qrcode"
              },
              "state": {}
            },
            {
              "id": "activityProducts",
              "type": "component",
              "componentType": "StatCard",
              "className": "h-full",
              "props": {
                "title": "Продукты",
                "value": "@state.userData.products",
                "icon": "pi pi-shopping-cart"
              },
              "state": {}
            }
          ]
        }
      ]
    },
    {
      "id": "mainLayout",
      "type": "section",
      "className": "mb-5",
      "grid": {
        "cols": ["col-12 md:col-6", "col-12 md:col-6"],
        "padding": "p-2"
      },
      "blocks": [
        {
          "id": "leftColumnBlock",
          "type": "block",
          "wrapper": {
            "component": "Panel",
            "props": {
              "header": "Профиль"
            }
          },
          "className": "flex flex-column align-items-center gap-1",
          "components": [
            {
              "id": "userAvatarNameGroup",
              "type": "component",
              "componentType": "LayoutGroup",
              "className": "flex flex-column md:flex-row gap-3 justify-content-center align-items-center",
              "props": {
                "components": [
                  {
                    "id": "userAvatar",
                    "type": "component",
                    "componentType": "Avatar",
                    "props": {
                      "label": "@state.userData.initials",
                      "shape": "circle",
                      "size": "xlarge"
                    },
                    "state": {}
                  },
                  {
                    "id": "userFullName",
                    "type": "component",
                    "componentType": "Text",
                    "props": {
                      "value": "@state.userData.fullName",
                      "level": 1
                    },
                    "className": "text-center md:text-left",
                    "state": {}
                  }
                ]
              }
            },
            {
              "id": "userDivider1",
              "type": "component",
              "componentType": "Divider",
              "className": "w-full"
            },
            {
              "id": "userEmailGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Email",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "userEmail",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.userData.email"
                    },
                    "state": {}
                  }
                ]
              }
            },
            {
              "id": "userPhoneGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Телефон",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "userPhone",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.userData.phone"
                    },
                    "state": {}
                  }
                ]
              }
            },
            {
              "id": "userCityGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center",
              "props": {
                "label": "Город",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "userCity",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.userData.city"
                    },
                    "state": {}
                  }
                ]
              }
            },
            {
              "id": "userDivider2",
              "type": "component",
              "componentType": "Divider",
              "className": "w-full"
            },
            {
              "id": "btnEditUser",
              "type": "component",
              "componentType": "Button",
              "props": {
                "icon": "pi pi-pencil",
                "label": "Редактировать",
                "size": "small",
                "severity": "info",
                "outlined": true
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "log",
                      "params": {
                        "message": "{$state}"
                      }
                    }
                  ]
                }
              ],
              "state": {}
            }
          ]
        },
        {
          "id": "rightColumnBlock",
          "type": "block",
          "className": "flex flex-column",
          "components": [
            {
              "id": "detailsTable",
              "type": "component",
              "componentType": "DataTable",
              "className": "mb-4",
              "props": {
                "showHeaders": false,
                "value": [
                  { "label": "ID", "value": "@state.userData.id" },
                  { "label": "Telegram ID", "value": "@state.userData.bot_id" },
                  { "label": "Реферал", "value": "@state.userData.referral" },
                  { "label": "IP", "value": "@state.userData.ip" },
                  {
                    "label": "Дата регистрации",
                    "value": "@state.userData.regDateFormatted"
                  },
                  {
                    "label": "Дата авторизации",
                    "value": "@state.userData.authDateFormatted"
                  }
                ],
                "columns": [{ "field": "label" }, { "field": "value" }]
              },
              "state": {}
            },
            {
              "id": "userStatusGroup",
              "type": "component",
              "componentType": "Panel",
              "props": {
                "showHeaders": false,
                "containerClassName": "flex flex-column gap-3 justify-content-center align-items-center",
                "components": [
                  {
                    "id": "blockStatusTag",
                    "type": "component",
                    "componentType": "Tag",
                    "props": {
                      "value": "@state.userData.statusLabel",
                      "severity": "@state.userData.statusSeverity"
                    },
                    "state": {}
                  },
                  {
                    "id": "blockReasonField",
                    "type": "component",
                    "componentType": "Text",
                    "props": {
                      "value": "@state.userData.block_reason"
                    }
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "achievementsSection",
      "type": "section",
      "className": "mb-4",
      "blocks": [
        {
          "id": "achievementsTitle",
          "type": "block",
          "components": [
            {
              "id": "achievementsHeading",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "Достижения",
                "level": 2
              },
              "state": {}
            }
          ]
        },
        {
          "id": "achievementsGrid",
          "type": "block",
          "grid": {
            "cols": ["col-6", "col-6"],
            "padding": "p-1"
          },
          "components": [
            {
              "id": "achievementPoints",
              "type": "component",
              "componentType": "Card",
              "props": {
                "header": "Баллы",
                "subheader": "@state.userData.points"
              },
              "state": {}
            },
            {
              "id": "achievementPrizes",
              "type": "component",
              "componentType": "Card",
              "props": {
                "header": "Призы",
                "subheader": "@state.userData.prizes"
              },
              "state": {}
            }
          ]
        }
      ]
    },
    {
      "id": "activitySection",
      "type": "section",
      "blocks": [
        {
          "id": "activityTitle",
          "type": "block",
          "components": [
            {
              "id": "activityHeading",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "Активность",
                "level": 2
              },
              "state": {}
            }
          ]
        }
      ]
    }
  ]
}
