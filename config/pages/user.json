{
  "id": "user",
  "type": "page",
  "route": "/users/[user_id]",
  "state": {
    "loading": false,
    "initialized": true
  },
  "meta": {
    "title": "Пользователь CRM"
  },
  "sections": [
    {
      "id": "settingsHeader",
      "type": "section",
      "state": {
        "visible": true
      },
      "blocks": [
        {
          "id": "settingsTitle",
          "type": "block",
          "state": {},
          "components": [
            {
              "id": "settingsPageTitle",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "Пользователь",
                "level": 1
              },
              "state": {}
            }
          ]
        }
      ]
    },
    {
      "id": "userForm",
      "type": "section",
      "state": {
        "visible": true
      },
      "blocks": [
        {
          "id": "profileForm",
          "type": "block",
          "state": {
            "formData": {}
          },
          "wrapper": {
            "component": "Card",
            "props": {
              "header": "Profile Settings"
            }
          },
          "components": [
            {
              "id": "displayName",
              "type": "component",
              "componentType": "InputText",
              "props": {
                "placeholder": "Display name"
              },
              "state": {
                "value": "Admin User"
              }
            },
            {
              "id": "email",
              "type": "component",
              "componentType": "InputText",
              "props": {
                "placeholder": "Email address"
              },
              "state": {
                "value": "admin@crm.com"
              }
            },
            {
              "id": "bio",
              "type": "component",
              "componentType": "InputTextarea",
              "props": {
                "placeholder": "Bio",
                "rows": 3
              },
              "state": {
                "value": "System administrator"
              }
            },
            {
              "id": "avatar",
              "type": "component",
              "componentType": "Avatar",
              "props": {
                "label": "AU",
                "shape": "circle",
                "size": "xlarge",
                "style": {
                  "backgroundColor": "#6366f1"
                }
              },
              "state": {}
            },
            {
              "id": "chip1",
              "type": "component",
              "componentType": "Chip",
              "props": {
                "label": "Admin",
                "icon": "pi pi-user"
              },
              "state": {}
            },
            {
              "id": "chip2",
              "type": "component",
              "componentType": "Chip",
              "props": {
                "label": "Verified",
                "icon": "pi pi-check-circle"
              },
              "state": {}
            }
          ]
        },
        {
          "id": "notificationSettings",
          "type": "block",
          "state": {},
          "wrapper": {
            "component": "Card",
            "props": {
              "header": "Notifications"
            }
          },
          "components": [
            {
              "id": "emailNotif",
              "type": "component",
              "componentType": "InputSwitch",
              "props": {
                "label": "Email notifications"
              },
              "state": {
                "value": true
              }
            },
            {
              "id": "smsNotif",
              "type": "component",
              "componentType": "InputSwitch",
              "props": {
                "label": "SMS notifications"
              },
              "state": {
                "value": false
              }
            },
            {
              "id": "pushNotif",
              "type": "component",
              "componentType": "InputSwitch",
              "props": {
                "label": "Push notifications"
              },
              "state": {
                "value": true
              }
            },
            {
              "id": "notifFrequency",
              "type": "component",
              "componentType": "Dropdown",
              "props": {
                "options": [
                  {
                    "label": "Instant",
                    "value": "instant"
                  },
                  {
                    "label": "Daily digest",
                    "value": "daily"
                  },
                  {
                    "label": "Weekly digest",
                    "value": "weekly"
                  }
                ]
              },
              "state": {
                "value": "instant"
              }
            }
          ]
        }
      ]
    }
  ]
}
