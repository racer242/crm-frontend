{
  "id": "user",
  "type": "page",
  "route": "/users/[user_id]",
  "state": {
    "loading": false,
    "initialized": true,
    "userData": {
      "id": "",
      "bot_id": "",
      "first_name": "",
      "last_name": "",
      "email": "",
      "phone": "",
      "reg_date": "",
      "auth_date": "",
      "referral": "",
      "city": "",
      "ip": "",
      "is_blocked": false,
      "block_reason": "",
      "groups": [],
      "points": 0,
      "prizes": 0,
      "receipts": 0,
      "codes": 0,
      "gtins": 0,
      "products": 0,
      "messages": 0,
      "fullName": "",
      "initials": "",
      "regDateFormatted": "",
      "authDateFormatted": "",
      "groupList": [],
      "groupsText": "",
      "statusLabel": "",
      "statusSeverity": ""
    }
  },
  "meta": {
    "title": "Участник — CRM Platform"
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}",
      "method": "GET",
      "target": "state.userData",
      "adapter": "user.response.js"
    }
  ],
  "sections": [
    {
      "id": "breadcrumbSection",
      "type": "section",
      "className": "",
      "blocks": [
        {
          "id": "userTitleBlock",
          "type": "block",
          "components": [
            {
              "id": "breadcrumb",
              "type": "component",
              "componentType": "Breadcrumb",
              "className": "border-none p-0",
              "props": {
                "home": { "icon": "pi pi-home", "url": "/" },
                "model": [
                  { "label": "Участники", "route": "/users" },
                  { "label": "Участник" }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "userHeader",
      "type": "section",
      "layout": {
        "type": "flex",
        "direction": "row",
        "justifyContent": "between"
      },
      "className": "mb-4 align-items-center",
      "blocks": [
        {
          "id": "userTitleBlock",
          "type": "block",
          "components": [
            {
              "id": "userPageTitle",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "Участник",
                "level": 1
              }
            }
          ]
        },
        {
          "id": "userActionButtons",
          "type": "block",
          "wrapper": {
            "className": "max-w-min"
          },
          "components": [
            {
              "id": "btnEditUser",
              "type": "component",
              "componentType": "Button",
              "props": {
                "icon": "pi pi-pencil",
                "label": "Редактировать",
                "size": "small",
                "severity": "info",
                "outlined": true
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "log",
                      "params": {
                        "message": "{$state}"
                      }
                    }
                  ]
                }
              ],
              "state": {}
            }
          ]
        }
      ]
    },
    {
      "id": "statsRow",
      "type": "section",
      "className": "gap-1",
      "blocks": [
        {
          "id": "statCard1",
          "type": "block",
          "className": "flex flex-row",
          "components": [
            {
              "id": "activityReceipts",
              "type": "component",
              "componentType": "StatCard",
              "className": "w-1",
              "props": {
                "title": "Чеки",
                "value": "@state.userData.receipts",
                "icon": "pi pi-users"
              }
            },
            {
              "id": "activityCodes",
              "type": "component",
              "componentType": "Card",
              "props": {
                "title": "Коды",
                "subTitle": "@state.userData.codes"
              },
              "state": {}
            },
            {
              "id": "activityGtins",
              "type": "component",
              "componentType": "Card",
              "props": {
                "title": "Коды ЧЗ",
                "subTitle": "@state.userData.gtins"
              },
              "state": {}
            },
            {
              "id": "activityProducts",
              "type": "component",
              "componentType": "Card",
              "props": {
                "title": "Продукты",
                "subTitle": "@state.userData.products"
              },
              "state": {}
            }
          ]
        },
        {
          "id": "statCard3",
          "type": "block",
          "wrapper": {
            "component": "Card",
            "props": {
              "title": "Pending Orders"
            }
          },
          "components": [
            {
              "id": "sv3",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "42",
                "level": 1
              },
              "state": {}
            }
          ]
        }
      ]
    },
    {
      "id": "mainLayout",
      "type": "section",
      "className": "grid",
      "blocks": [
        {
          "id": "leftColumn",
          "type": "block",
          "wrapper": {
            "className": "col-12 md:col-4",
            "component": "Panel",
            "props": {
              "header": "Профиль"
            }
          },
          "className": "gap-1",
          "components": [
            {
              "id": "userAvatar",
              "type": "component",
              "componentType": "Avatar",
              "props": {
                "label": "@state.userData.initials",
                "shape": "circle",
                "size": "xlarge"
              },
              "state": {}
            },
            {
              "id": "userFullName",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "@state.userData.fullName",
                "level": 2
              },
              "state": {}
            },
            {
              "id": "userDivider1",
              "type": "component",
              "componentType": "Divider",
              "className": "w-full",
              "props": {},
              "state": {}
            },
            {
              "id": "userEmail",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "@state.userData.email"
              },
              "state": {}
            },
            {
              "id": "userPhone",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "@state.userData.phone"
              },
              "state": {}
            },
            {
              "id": "userCity",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "@state.userData.city"
              },
              "state": {}
            }
          ]
        },
        {
          "id": "rightColumn",
          "type": "block",
          "className": "col-12 md:col-8",
          "components": [
            {
              "id": "detailsCard",
              "type": "block",
              "className": "mb-4",
              "wrapper": {
                "component": "Card",
                "props": {
                  "header": "Детали"
                }
              },
              "components": [
                {
                  "id": "detailId",
                  "type": "component",
                  "componentType": "Text",
                  "props": {
                    "value": "ID: {@state.userData.id}"
                  },
                  "state": {}
                },
                {
                  "id": "detailBotId",
                  "type": "component",
                  "componentType": "Text",
                  "props": {
                    "value": "Telegram ID: {@state.userData.bot_id}"
                  },
                  "state": {}
                },
                {
                  "id": "detailReferral",
                  "type": "component",
                  "componentType": "Text",
                  "props": {
                    "value": "Реферал: {@state.userData.referral}"
                  },
                  "state": {}
                },
                {
                  "id": "detailIp",
                  "type": "component",
                  "componentType": "Text",
                  "props": {
                    "value": "IP: {@state.userData.ip}"
                  },
                  "state": {}
                },
                {
                  "id": "detailRegDate",
                  "type": "component",
                  "componentType": "Text",
                  "props": {
                    "value": "Регистрация: {@state.userData.regDateFormatted}"
                  },
                  "state": {}
                },
                {
                  "id": "detailAuthDate",
                  "type": "component",
                  "componentType": "Text",
                  "props": {
                    "value": "Авторизация: {@state.userData.authDateFormatted}"
                  },
                  "state": {}
                }
              ]
            },
            {
              "id": "statusCard",
              "type": "block",
              "wrapper": {
                "component": "Card",
                "props": {
                  "header": "Статус"
                }
              },
              "components": [
                {
                  "id": "blockStatusTag",
                  "type": "component",
                  "componentType": "Tag",
                  "props": {
                    "value": "@state.userData.statusLabel",
                    "severity": "@state.userData.statusSeverity"
                  },
                  "state": {}
                },
                {
                  "id": "blockReasonField",
                  "type": "component",
                  "componentType": "Text",
                  "props": {
                    "value": "Причина: {@state.userData.block_reason}"
                  },
                  "visible": {
                    "conditions": [
                      {
                        "path": "state.userData.isBlocked",
                        "operator": "==",
                        "value": true
                      }
                    ],
                    "defaultVisible": false
                  },
                  "state": {}
                },
                {
                  "id": "messagesCount",
                  "type": "component",
                  "componentType": "Text",
                  "props": {
                    "value": "Сообщения: {@state.userData.messages}"
                  },
                  "state": {}
                },
                {
                  "id": "groupsSection",
                  "type": "component",
                  "componentType": "Text",
                  "props": {
                    "value": "@state.userData.groupsText"
                  },
                  "state": {}
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "achievementsSection",
      "type": "section",
      "className": "mb-4",
      "blocks": [
        {
          "id": "achievementsTitle",
          "type": "block",
          "components": [
            {
              "id": "achievementsHeading",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "Достижения",
                "level": 2
              },
              "state": {}
            }
          ]
        },
        {
          "id": "achievementsGrid",
          "type": "block",
          "className": "grid",
          "components": [
            {
              "id": "achievementPoints",
              "type": "component",
              "componentType": "Card",
              "props": {
                "header": "Баллы",
                "subheader": "@state.userData.points"
              },
              "state": {}
            },
            {
              "id": "achievementPrizes",
              "type": "component",
              "componentType": "Card",
              "props": {
                "header": "Призы",
                "subheader": "@state.userData.prizes"
              },
              "state": {}
            }
          ]
        }
      ]
    },
    {
      "id": "activitySection",
      "type": "section",
      "blocks": [
        {
          "id": "activityTitle",
          "type": "block",
          "components": [
            {
              "id": "activityHeading",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "Активность",
                "level": 2
              },
              "state": {}
            }
          ]
        }
      ]
    }
  ]
}
