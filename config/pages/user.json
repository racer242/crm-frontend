{
  "id": "user",
  "type": "page",
  "route": "/users/[user_id]",
  "state": {
    "loading": false,
    "initialized": true,
    "userData": {
      "id": "—",
      "bot_id": "—",
      "first_name": "",
      "last_name": "",
      "email": "—",
      "phone": "—",
      "reg_date": null,
      "auth_date": null,
      "referral": "—",
      "city": "—",
      "ip": "—",
      "is_blocked": false,
      "block_reason": "",
      "groups": [],
      "points": 0,
      "prizes": 0,
      "receipts": 0,
      "codes": 0,
      "gtins": 0,
      "products": 0,
      "messages": 0,
      "full_name": "—",
      "initials": "?",
      "reg_date_formatted": "—",
      "auth_date_formatted": "—",
      "groups_text": "—",
      "groups_badges": [],
      "status_label": "Активен",
      "status_severity": "success",
      "status_icon": "pi pi-check-circle",
      "stats": []
    }
  },
  "meta": {
    "title": "Пользователь — CRM Platform"
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}",
      "method": "GET",
      "target": "state.userData",
      "adapter": "user.response.js"
    }
  ],
  "events": [
    {
      "type": "onLoad",
      "commands": [
        {
          "type": "log",
          "params": {
            "level": "info",
            "message": "Загружена страница пользователя {$location.routeParams.user_id}"
          }
        }
      ]
    }
  ],
  "shortcuts": {
    "blockUser": {
      "type": "sendRequest",
      "params": {
        "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}",
        "method": "PATCH",
        "data": {
          "is_blocked": true,
          "block_reason": ""
        },
        "target": "state.userData",
        "adapter": "user.response.js"
      }
    },
    "unblockUser": {
      "type": "sendRequest",
      "params": {
        "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}",
        "method": "PATCH",
        "data": {
          "is_blocked": false
        },
        "target": "state.userData",
        "adapter": "user.response.js"
      }
    }
  },
  "sections": [
    {
      "id": "userHeader",
      "type": "section",
      "layout": {
        "type": "flex",
        "direction": "row",
        "justifyContent": "between",
        "alignItems": "center"
      },
      "className": "flex-wrap",
      "blocks": [
        {
          "id": "userTitleBlock",
          "type": "block",
          "components": [
            {
              "id": "userPageTitle",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "Пользователь",
                "level": 1
              },
              "state": {}
            }
          ]
        },
        {
          "id": "userActionButtons",
          "type": "block",
          "className": "flex flex-row gap-2 flex-wrap",
          "components": [
            {
              "id": "btnEditUser",
              "type": "component",
              "componentType": "Button",
              "props": {
                "icon": "pi pi-pencil",
                "label": "Редактировать",
                "size": "small",
                "severity": "info",
                "outlined": true
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "log",
                      "params": {
                        "message": "Редактирование пользователя {$location.routeParams.user_id}"
                      }
                    }
                  ]
                }
              ],
              "state": {}
            },
            {
              "id": "btnBlockUser",
              "type": "component",
              "componentType": "Button",
              "props": {
                "icon": "pi pi-lock",
                "label": "Заблокировать",
                "size": "small",
                "severity": "danger",
                "outlined": true
              },
              "visible": {
                "conditions": [
                  {
                    "path": "state.userData.is_blocked",
                    "operator": "==",
                    "value": false
                  }
                ],
                "defaultVisible": false
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "confirm",
                      "params": {
                        "header": "Подтверждение",
                        "message": "Вы уверены, что хотите заблокировать этого пользователя?",
                        "icon": "pi pi-exclamation-triangle"
                      },
                      "onConfirm": ["blockUser"],
                      "onCancel": [
                        {
                          "type": "log",
                          "params": {
                            "message": "Блокировка отменена"
                          }
                        }
                      ]
                    }
                  ]
                }
              ],
              "state": {}
            },
            {
              "id": "btnUnblockUser",
              "type": "component",
              "componentType": "Button",
              "props": {
                "icon": "pi pi-lock-open",
                "label": "Разблокировать",
                "size": "small",
                "severity": "success",
                "outlined": true
              },
              "visible": {
                "conditions": [
                  {
                    "path": "state.userData.is_blocked",
                    "operator": "==",
                    "value": true
                  }
                ],
                "defaultVisible": false
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "confirm",
                      "params": {
                        "header": "Подтверждение",
                        "message": "Вы уверены, что хотите разблокировать этого пользователя?",
                        "icon": "pi pi-exclamation-triangle"
                      },
                      "onConfirm": ["unblockUser"],
                      "onCancel": [
                        {
                          "type": "log",
                          "params": {
                            "message": "Разблокировка отменена"
                          }
                        }
                      ]
                    }
                  ]
                }
              ],
              "state": {}
            },
            {
              "id": "btnManageGroups",
              "type": "component",
              "componentType": "Button",
              "props": {
                "icon": "pi pi-users",
                "label": "Группы",
                "size": "small",
                "severity": "contrast",
                "outlined": true
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "log",
                      "params": {
                        "message": "Управление группами пользователя {$location.routeParams.user_id}"
                      }
                    }
                  ]
                }
              ],
              "state": {}
            }
          ]
        }
      ]
    },
    {
      "id": "userInfoGrid",
      "type": "section",
      "className": "grid",
      "blocks": [
        {
          "id": "profileCard",
          "type": "block",
          "className": "col-12 md:col-6 lg:col-4",
          "wrapper": {
            "component": "Card",
            "props": {
              "header": "Основная информация"
            }
          },
          "components": [
            {
              "id": "userAvatar",
              "type": "component",
              "componentType": "Avatar",
              "props": {
                "label": "@state.userData.initials",
                "shape": "circle",
                "size": "xlarge",
                "style": {
                  "backgroundColor": "#6366f1",
                  "color": "#ffffff",
                  "fontWeight": "bold"
                }
              },
              "state": {}
            },
            {
              "id": "userFullName",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "{$state.userData.full_name}",
                "level": 2
              },
              "state": {}
            },
            {
              "id": "userDivider1",
              "type": "component",
              "componentType": "Divider",
              "props": {},
              "state": {}
            },
            {
              "id": "userEmailRow",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "✉ {$state.userData.email}"
              },
              "state": {}
            },
            {
              "id": "userPhoneRow",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "📞 {$state.userData.phone}"
              },
              "state": {}
            },
            {
              "id": "userCityRow",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "📍 {$state.userData.city}"
              },
              "state": {}
            }
          ]
        },
        {
          "id": "statusCard",
          "type": "block",
          "className": "col-12 md:col-6 lg:col-4",
          "wrapper": {
            "component": "Card",
            "props": {
              "header": "Статус"
            }
          },
          "components": [
            {
              "id": "blockStatusTag",
              "type": "component",
              "componentType": "Tag",
              "props": {
                "value": "{$state.userData.status_label}",
                "severity": "{$state.userData.status_severity}",
                "icon": "{$state.userData.status_icon}"
              },
              "state": {}
            },
            {
              "id": "blockReasonField",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "Причина: {$state.userData.block_reason}"
              },
              "visible": {
                "conditions": [
                  {
                    "path": "state.userData.is_blocked",
                    "operator": "==",
                    "value": true
                  }
                ],
                "defaultVisible": false
              },
              "state": {}
            },
            {
              "id": "userDivider2",
              "type": "component",
              "componentType": "Divider",
              "props": {},
              "state": {}
            },
            {
              "id": "groupsLabel",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "Группы:"
              },
              "state": {}
            },
            {
              "id": "groupsText",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "{$state.userData.groups_text}"
              },
              "state": {}
            }
          ]
        },
        {
          "id": "detailsCard",
          "type": "block",
          "className": "col-12 md:col-6 lg:col-4",
          "wrapper": {
            "component": "Card",
            "props": {
              "header": "Детали"
            }
          },
          "components": [
            {
              "id": "detailId",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "ID: {$state.userData.id}"
              },
              "state": {}
            },
            {
              "id": "detailBotId",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "Telegram ID: {$state.userData.bot_id}"
              },
              "state": {}
            },
            {
              "id": "detailReferral",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "Реферал: {$state.userData.referral}"
              },
              "state": {}
            },
            {
              "id": "detailIp",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "IP: {$state.userData.ip}"
              },
              "state": {}
            },
            {
              "id": "userDivider3",
              "type": "component",
              "componentType": "Divider",
              "props": {},
              "state": {}
            },
            {
              "id": "detailRegDate",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "Регистрация: {$state.userData.reg_date_formatted}"
              },
              "state": {}
            },
            {
              "id": "detailAuthDate",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "Авторизация: {$state.userData.auth_date_formatted}"
              },
              "state": {}
            }
          ]
        }
      ]
    },
    {
      "id": "userStatsSection",
      "type": "section",
      "className": "grid",
      "blocks": [
        {
          "id": "statsCard",
          "type": "block",
          "className": "col-12",
          "wrapper": {
            "component": "Card",
            "props": {
              "header": "Статистика"
            }
          },
          "components": [
            {
              "id": "statsContainer",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "Баллы: {$state.userData.points} | Призы: {$state.userData.prizes} | Чеки: {$state.userData.receipts} | Коды: {$state.userData.codes} | Коды ЧЗ: {$state.userData.gtins} | Продукты: {$state.userData.products} | Сообщения: {$state.userData.messages}"
              },
              "state": {}
            }
          ]
        },
        {
          "id": "statsGrid",
          "type": "block",
          "className": "col-12",
          "components": [
            {
              "id": "statPoints",
              "type": "component",
              "componentType": "Chip",
              "props": {
                "label": "Баллы: {$state.userData.points}",
                "icon": "pi pi-star"
              },
              "state": {}
            },
            {
              "id": "statPrizes",
              "type": "component",
              "componentType": "Chip",
              "props": {
                "label": "Призы: {$state.userData.prizes}",
                "icon": "pi pi-gift"
              },
              "state": {}
            },
            {
              "id": "statReceipts",
              "type": "component",
              "componentType": "Chip",
              "props": {
                "label": "Чеки: {$state.userData.receipts}",
                "icon": "pi pi-receipt"
              },
              "state": {}
            },
            {
              "id": "statCodes",
              "type": "component",
              "componentType": "Chip",
              "props": {
                "label": "Коды: {$state.userData.codes}",
                "icon": "pi pi-qrcode"
              },
              "state": {}
            },
            {
              "id": "statGtins",
              "type": "component",
              "componentType": "Chip",
              "props": {
                "label": "Коды ЧЗ: {$state.userData.gtins}",
                "icon": "pi pi-qrcode"
              },
              "state": {}
            },
            {
              "id": "statProducts",
              "type": "component",
              "componentType": "Chip",
              "props": {
                "label": "Продукты: {$state.userData.products}",
                "icon": "pi pi-box"
              },
              "state": {}
            },
            {
              "id": "statMessages",
              "type": "component",
              "componentType": "Chip",
              "props": {
                "label": "Сообщения: {$state.userData.messages}",
                "icon": "pi pi-comments"
              },
              "state": {}
            }
          ]
        }
      ]
    }
  ]
}
