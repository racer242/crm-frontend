{
  "id": "gtin",
  "type": "page",
  "route": "/gtins/[gtin_id]",
  "state": {
    "loading": false,
    "initialized": true,
    "gtinData": {
      "id": "",
      "user_id": "",
      "registration_date": "",
      "purchase_date": "",
      "retail_chain_name": "",
      "gtin": "",
      "product_name": "",
      "property1": "",
      "property2": "",
      "amount": 0,
      "moderation_status": "",
      "comment": "",
      "registrationDateFormatted": "",
      "purchaseDateFormatted": "",
      "moderationStatusLabel": "",
      "moderationStatusSeverity": ""
    }
  },
  "meta": {
    "title": "Код Честный Знак — CRM Platform"
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/gtins/{$location.routeParams.gtin_id}",
      "method": "GET",
      "target": "state.gtinData"
    }
  ],
  "shortcuts": {
    "deleteGtin": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "showConfirmDialog",
            "params": {
              "header": "Подтверждение удаления",
              "message": "Вы уверены, что хотите удалить этот код?",
              "icon": "pi pi-exclamation-triangle",
              "acceptLabel": "Удалить",
              "rejectLabel": "Отмена"
            },
            "onAccept": [
              {
                "type": "sendRequest",
                "params": {
                  "url": "/api/gtins/{$location.routeParams.gtin_id}",
                  "method": "DELETE",
                  "onSuccess": [
                    {
                      "type": "showToast",
                      "params": {
                        "severity": "success",
                        "summary": "Успешно",
                        "message": "Код удален"
                      }
                    },
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/gtins"
                      }
                    }
                  ],
                  "onError": [
                    {
                      "type": "showToast",
                      "params": {
                        "severity": "error",
                        "summary": "Ошибка",
                        "message": "Не удалось удалить код"
                      }
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    }
  },
  "sections": [
    {
      "id": "breadcrumbSection",
      "type": "section",
      "className": "",
      "blocks": [
        {
          "id": "breadcrumbBlock",
          "type": "block",
          "components": [
            {
              "id": "breadcrumb",
              "type": "component",
              "componentType": "Breadcrumb",
              "className": "border-none p-0",
              "props": {
                "home": { "icon": "pi pi-home", "url": "/" },
                "model": [
                  { "label": "Честный Знак", "route": "/gtins" },
                  { "label": "Код #@state.gtinData.id" }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "mainLayout",
      "type": "section",
      "className": "flex mb-5",
      "grid": {
        "cols": ["col-12"],
        "padding": "p-2"
      },
      "blocks": [
        {
          "id": "gtinDetailsBlock",
          "type": "block",
          "wrapper": {
            "component": "Panel",
            "props": {
              "header": "Информация о коде"
            }
          },
          "className": "flex flex-column gap-3",
          "components": [
            {
              "id": "userNameGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Участник",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "userNameLink",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg text-primary",
                    "props": {
                      "value": "@state.gtinData.user_name"
                    },
                    "events": [
                      {
                        "type": "onClick",
                        "commands": [
                          {
                            "type": "navigate",
                            "params": {
                              "url": "/users/{@state.gtinData.user_id}"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            {
              "id": "userEmailGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Email",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "userEmailLink",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg text-primary",
                    "props": {
                      "value": "@state.gtinData.user_email"
                    },
                    "events": [
                      {
                        "type": "onClick",
                        "commands": [
                          {
                            "type": "executeCommand",
                            "params": {
                              "command": "window.open('mailto:{@state.gtinData.user_email}', '_blank')"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            {
              "id": "registrationDateGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Дата регистрации",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "registrationDate",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.gtinData.registrationDateFormatted"
                    }
                  }
                ]
              }
            },
            {
              "id": "purchaseDateGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Дата покупки",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "purchaseDate",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.gtinData.purchaseDateFormatted"
                    }
                  }
                ]
              }
            },
            {
              "id": "retailChainGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Торговая сеть",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "retailChain",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.gtinData.retail_chain_name"
                    }
                  }
                ]
              }
            },
            {
              "id": "gtinGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Код GTIN",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "gtin",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg font-monospace",
                    "props": {
                      "value": "@state.gtinData.gtin"
                    }
                  }
                ]
              }
            },
            {
              "id": "productGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Продукт",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "product",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.gtinData.product_name"
                    }
                  }
                ]
              }
            },
            {
              "id": "amountGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Сумма",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "amount",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.gtinData.amount"
                    }
                  }
                ]
              }
            },
            {
              "id": "moderationStatusGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Статус модерации",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "moderationStatusTag",
                    "type": "component",
                    "componentType": "Tag",
                    "className": "text-sm px-2 py-1",
                    "props": {
                      "value": "@state.gtinData.moderationStatusLabel",
                      "severity": "@state.gtinData.moderationStatusSeverity"
                    }
                  }
                ]
              }
            },
            {
              "id": "commentGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-start mb-2",
              "props": {
                "label": "Комментарий",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "comment",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0",
                    "props": {
                      "value": "@state.gtinData.comment"
                    }
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "actionsSection",
      "type": "section",
      "blocks": [
        {
          "id": "actionsBlock",
          "type": "block",
          "className": "flex justify-content-center gap-3 mt-3",
          "components": [
            {
              "id": "btnEdit",
              "type": "component",
              "componentType": "Button",
              "props": {
                "icon": "pi pi-pencil",
                "label": "Модерировать",
                "size": "small",
                "severity": "info"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/gtins/{$location.routeParams.gtin_id}/edit"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "btnDelete",
              "type": "component",
              "componentType": "Button",
              "props": {
                "icon": "pi pi-trash",
                "label": "Удалить",
                "size": "small",
                "severity": "danger",
                "outlined": true
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": ["deleteGtin"]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
