{
  "id": "gtin",
  "type": "page",
  "route": "/gtins/[gtin_id]",
  "state": {
    "loading": false,
    "initialized": true,
    "gtinData": {
      "id": "",
      "user_id": "",
      "user_name": "",
      "user_email": "",
      "registration_date": "",
      "purchase_date": "",
      "retail_chain_name": "",
      "gtin": "",
      "product_name": "",
      "property1": "",
      "property2": "",
      "amount": 0,
      "moderation_status": "",
      "comment": "",
      "registrationDateFormatted": "",
      "purchaseDateFormatted": "",
      "moderationStatusLabel": "",
      "moderationStatusSeverity": ""
    }
  },
  "meta": {
    "title": "Код Честный Знак — CRM Platform"
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/gtins/{$location.routeParams.gtin_id}",
      "method": "GET",
      "target": "state.gtinData"
    }
  ],
  "shortcuts": {
    "deleteGtin": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "showConfirmDialog",
            "params": {
              "header": "Подтверждение удаления",
              "message": "Вы уверены, что хотите удалить этот код?",
              "icon": "pi pi-exclamation-triangle",
              "acceptLabel": "Удалить",
              "rejectLabel": "Отмена"
            },
            "onAccept": [
              {
                "type": "sendRequest",
                "params": {
                  "url": "/api/gtins/{$location.routeParams.gtin_id}",
                  "method": "DELETE",
                  "onSuccess": [
                    {
                      "type": "showToast",
                      "params": {
                        "severity": "success",
                        "summary": "Успешно",
                        "message": "Код удален"
                      }
                    },
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/gtins"
                      }
                    }
                  ],
                  "onError": [
                    {
                      "type": "showToast",
                      "params": {
                        "severity": "error",
                        "summary": "Ошибка",
                        "message": "Не удалось удалить код"
                      }
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    }
  },
  "sections": [
    {
      "id": "breadcrumbSection",
      "type": "section",
      "className": "",
      "blocks": [
        {
          "id": "breadcrumbBlock",
          "type": "block",
          "components": [
            {
              "id": "breadcrumb",
              "type": "component",
              "componentType": "Breadcrumb",
              "className": "border-none p-0",
              "props": {
                "home": { "icon": "pi pi-home", "url": "/" },
                "model": [
                  { "label": "Честный Знак", "route": "/gtins" },
                  { "label": "Код #@state.gtinData.id" }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "mainLayout",
      "type": "section",
      "className": "flex mb-5",
      "grid": {
        "cols": ["col-12 lg:col-8", "col-12 lg:col-4"],
        "padding": "p-2"
      },
      "blocks": [
        {
          "id": "gtinDetailsBlock",
          "type": "block",
          "wrapper": {
            "component": "Panel",
            "props": { "header": "Информация о коде" }
          },
          "className": "flex flex-column gap-3",
          "components": [
            {
              "id": "registrationDateGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Дата регистрации",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "registrationDate",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.gtinData.registrationDateFormatted"
                    }
                  }
                ]
              }
            },
            {
              "id": "purchaseDateGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Дата покупки",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "purchaseDate",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.gtinData.purchaseDateFormatted"
                    }
                  }
                ]
              }
            },
            {
              "id": "retailChainGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Торговая сеть",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "retailChain",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": { "value": "@state.gtinData.retail_chain_name" }
                  }
                ]
              }
            },
            {
              "id": "gtinGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Код GTIN",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "gtin",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg font-monospace",
                    "props": { "value": "@state.gtinData.gtin" }
                  }
                ]
              }
            },
            {
              "id": "amountGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Сумма",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "amount",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": { "value": "@state.gtinData.amount" }
                  }
                ]
              }
            },
            {
              "id": "moderationStatusGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Статус модерации",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "moderationStatusTag",
                    "type": "component",
                    "componentType": "Tag",
                    "className": "text-sm px-2 py-1",
                    "props": {
                      "value": "@state.gtinData.moderationStatusLabel",
                      "severity": "@state.gtinData.moderationStatusSeverity"
                    }
                  }
                ]
              }
            },
            {
              "id": "commentGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-start mb-2",
              "props": {
                "label": "Комментарий",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "comment",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0",
                    "props": { "value": "@state.gtinData.comment" }
                  }
                ]
              }
            }
          ]
        },
        {
          "id": "extraDetailsBlock",
          "type": "block",
          "className": "flex flex-column gap-3",
          "components": [
            {
              "id": "userInfoPanel",
              "type": "component",
              "componentType": "Panel",
              "className": "flex flex-column",
              "props": {
                "header": "Участник",
                "components": [
                  {
                    "id": "userNameGroup",
                    "type": "component",
                    "componentType": "LabelledGroup",
                    "className": "w-full grid align-items-center mb-2",
                    "props": {
                      "label": "Имя",
                      "labelClassName": "text-sm col-4 text-right",
                      "containerClassName": "col-8",
                      "components": [
                        {
                          "id": "userNameLink",
                          "type": "component",
                          "componentType": "Text",
                          "className": "m-0 font-bold text-lg text-primary",
                          "props": { "value": "@state.gtinData.user_name" },
                          "events": [
                            {
                              "type": "onClick",
                              "commands": [
                                {
                                  "type": "navigate",
                                  "params": {
                                    "url": "/users/{$state.gtinData.user_id}"
                                  }
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  },
                  {
                    "id": "userEmailGroup",
                    "type": "component",
                    "componentType": "LabelledGroup",
                    "className": "w-full grid align-items-center mb-2",
                    "props": {
                      "label": "Email",
                      "labelClassName": "text-sm col-4 text-right",
                      "containerClassName": "col-8",
                      "components": [
                        {
                          "id": "userEmailLink",
                          "type": "component",
                          "componentType": "Text",
                          "className": "m-0 font-bold text-lg text-primary",
                          "props": { "value": "@state.gtinData.user_email" }
                        }
                      ]
                    }
                  },
                  {
                    "id": "userLinkBtn",
                    "type": "component",
                    "componentType": "Button",
                    "props": {
                      "icon": "pi pi-user",
                      "label": "Перейти к участнику",
                      "size": "small",
                      "severity": "info",
                      "outlined": true,
                      "className": "w-full"
                    },
                    "events": [
                      {
                        "type": "onClick",
                        "commands": [
                          {
                            "type": "navigate",
                            "params": {
                              "url": "/users/{$state.gtinData.user_id}"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            {
              "id": "productInfoPanel",
              "type": "component",
              "componentType": "Panel",
              "className": "flex flex-column",
              "props": {
                "header": "Продукт",
                "components": [
                  {
                    "id": "productNameGroup",
                    "type": "component",
                    "componentType": "LabelledGroup",
                    "className": "w-full grid align-items-center mb-2",
                    "props": {
                      "label": "Название",
                      "labelClassName": "text-sm col-4 text-right",
                      "containerClassName": "col-8",
                      "components": [
                        {
                          "id": "productNameText",
                          "type": "component",
                          "componentType": "Text",
                          "className": "m-0 font-bold text-lg",
                          "props": { "value": "@state.gtinData.product_name" }
                        }
                      ]
                    }
                  },
                  {
                    "id": "gtinTextGroup",
                    "type": "component",
                    "componentType": "LabelledGroup",
                    "className": "w-full grid align-items-center mb-2",
                    "props": {
                      "label": "Код",
                      "labelClassName": "text-sm col-4 text-right",
                      "containerClassName": "col-8",
                      "components": [
                        {
                          "id": "gtinText",
                          "type": "component",
                          "componentType": "Text",
                          "className": "m-0 font-bold text-lg font-monospace",
                          "props": { "value": "@state.gtinData.gtin" }
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "actionsSection",
      "type": "section",
      "className": "flex justify-content-center",
      "blocks": [
        {
          "id": "actionsBlock",
          "type": "block",
          "wrapper": {
            "showHeader": false,
            "component": "Panel",
            "props": {
              "className": "flex-grow-1",
              "pt": {
                "content": {
                  "style": { "background": "var(--surface-50) !important" }
                }
              }
            }
          },
          "className": "flex flex-wrap gap-3 justify-content-center md:justify-content-start",
          "components": [
            {
              "id": "btnEdit",
              "type": "component",
              "componentType": "Button",
              "props": {
                "icon": "pi pi-pencil",
                "label": "Модерировать",
                "size": "small",
                "severity": "info"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/gtins/{$location.routeParams.gtin_id}/edit"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "btnDelete",
              "type": "component",
              "componentType": "Button",
              "props": {
                "icon": "pi pi-trash",
                "label": "Удалить",
                "size": "small",
                "severity": "danger",
                "outlined": true
              },
              "events": [{ "type": "onClick", "commands": ["deleteGtin"] }]
            }
          ]
        }
      ]
    }
  ]
}
