{
  "id": "user-points",
  "type": "page",
  "route": "/users/[user_id]/points",
  "state": {
    "loading": false,
    "initialized": true,
    "filtersVisible": false,
    "userData": {
      "id": "",
      "fullName": ""
    },
    "pointsData": {
      "points_current": 0,
      "points_spent": 0,
      "points_total_earned": 0
    },
    "pointsHistory": {
      "value": [],
      "columns": [],
      "totalRecords": 0,
      "rows": 10,
      "first": 0,
      "sortField": "",
      "sortOrder": 1,
      "filters": [],
      "search": ""
    }
  },
  "meta": {
    "title": "Баллы участника — CRM Platform"
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}",
      "method": "GET",
      "target": "state.userData"
    },
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}/points",
      "method": "GET",
      "target": "state.pointsData"
    },
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}/points/history",
      "data": {
        "first": "{$location.params.first}",
        "rows": "{$location.params.rows}",
        "sortField": "{$location.params.sortField}",
        "sortOrder": "{$location.params.sortOrder}",
        "search": "{$location.params.search}",
        "filters": "{$location.params.filters}"
      },
      "method": "GET",
      "target": "state.pointsHistory"
    }
  ],
  "shortcuts": {
    "requestUserPointsHistory": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "sendRequest",
            "params": {
              "url": "/api/users/{$location.routeParams.user_id}/points/history",
              "method": "GET",
              "target": "state.pointsHistory",
              "data": {
                "first": "{$state.pointsHistory.first}",
                "rows": "{$state.pointsHistory.rows}",
                "sortField": "{$state.pointsHistory.sortField}",
                "sortOrder": "{$state.pointsHistory.sortOrder}",
                "search": "{$state.pointsHistory.search}",
                "filters": "{$state.pointsHistory.filters}"
              }
            }
          },
          {
            "type": "mergeUrlParams",
            "params": {
              "values": {
                "first": "{$state.pointsHistory.first}",
                "rows": "{$state.pointsHistory.rows}",
                "sortField": "{$state.pointsHistory.sortField}",
                "sortOrder": "{$state.pointsHistory.sortOrder}",
                "search": "{$state.pointsHistory.search}",
                "filters": "{$state.pointsHistory.filters}"
              },
              "format": [
                {
                  "prop": "filters",
                  "type": "PopIfHasNullProps",
                  "params": { "props": ["value"] }
                },
                {
                  "prop": "filters",
                  "type": "RemoveProps",
                  "params": { "props": ["name", "type", "opts"] }
                }
              ]
            }
          }
        ]
      }
    }
  },
  "sections": [
    {
      "id": "breadcrumbSection",
      "type": "section",
      "className": "",
      "blocks": [
        {
          "id": "breadcrumbBlock",
          "type": "block",
          "components": [
            {
              "id": "breadcrumb",
              "type": "component",
              "componentType": "Breadcrumb",
              "className": "border-none p-0",
              "props": {
                "home": { "icon": "pi pi-home", "url": "/" },
                "model": [
                  { "label": "Участники", "route": "/users" },
                  {
                    "label": "@state.userData.fullName",
                    "route": "/users/{@state.userData.id}"
                  },
                  { "label": "Баллы" }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "menuSection",
      "type": "section",
      "blocks": [
        {
          "id": "menuBlock",
          "type": "block",
          "className": "w-full",
          "components": [
            {
              "id": "menubar",
              "type": "component",
              "componentType": "Menubar",
              "props": {
                "activeItemId": "achievements",
                "pt": { "menu": { "className": "gap-1" } },
                "$ref": "../menus/user.json"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "pointsStatsSection",
      "type": "section",
      "className": "flex flex-column",
      "blocks": [
        {
          "id": "pointsStatCardsBlock",
          "type": "block",
          "className": "mb-5",
          "grid": {
            "cols": [
              "col-12 sm:col-6 lg:col-4",
              "col-12 sm:col-6 lg:col-4",
              "col-12 sm:col-6 lg:col-4"
            ],
            "padding": "p-2"
          },
          "components": [
            {
              "id": "pointsCurrent",
              "type": "component",
              "componentType": "StatCard",
              "className": "h-full p-1",
              "style": {
                "backgroundColor": "var(--primary-color)",
                "color": "var(--primary-color-text)"
              },
              "props": {
                "titleClassName": "text-base",
                "valueClassName": "text-4xl font-bold mt-1",
                "iconClassName": "text-2xl text-primary",
                "title": "Текущее",
                "value": "@state.pointsData.points_current",
                "icon": "pi pi-trophy"
              },
              "state": {}
            },
            {
              "id": "pointsSpent",
              "type": "component",
              "componentType": "StatCard",
              "className": "h-full p-1",
              "props": {
                "titleClassName": "text-base",
                "valueClassName": "text-4xl font-bold mt-1",
                "title": "Потратил",
                "value": "@state.pointsData.points_spent",
                "icon": "pi pi-arrow-up"
              },
              "state": {}
            },
            {
              "id": "pointsTotalEarned",
              "type": "component",
              "componentType": "StatCard",
              "className": "h-full p-1",
              "props": {
                "titleClassName": "text-base",
                "valueClassName": "text-4xl font-bold mt-1",
                "title": "Всего",
                "value": "@state.pointsData.points_total_earned",
                "icon": "pi pi-star"
              },
              "state": {}
            }
          ]
        },
        {
          "id": "pointsBtnBlock",
          "type": "block",
          "className": "mb-3",
          "components": [
            {
              "id": "pointsBtnEdit",
              "type": "component",
              "componentType": "Button",
              "className": "min-w-max flex-grow-0 px-3",
              "props": {
                "icon": "pi pi-pencil",
                "severity": "info",
                "size": "small",
                "label": "Изменить"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "showMessage",
                      "params": {
                        "severity": "info",
                        "summary": "Заглушка",
                        "detail": "Функция изменения баллов ещё не реализована"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "pointsHistorySection",
      "type": "section",
      "blocks": [
        {
          "id": "pointsHistoryBlock",
          "type": "block",
          "components": [
            {
              "id": "pointsHistoryTitle",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "История начислений",
                "level": 2
              }
            }
          ]
        }
      ]
    },
    {
      "id": "pointsHistoryFilters",
      "type": "section",
      "className": "flex gap-3",
      "blocks": [
        {
          "id": "pointsHistorySearchBlock",
          "type": "block",
          "className": "w-full",
          "components": [
            {
              "id": "pointsHistorySearchInput",
              "type": "component",
              "className": "w-full p-inputtext-sm",
              "componentType": "InputTextWithThrottle",
              "props": {
                "placeholder": "Быстрый поиск...",
                "throttleDelay": 500,
                "value": "@state.pointsHistory.search"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.pointsHistory.search"
                      }
                    },
                    "requestUserPointsHistory"
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "pointsHistoryFilterBlock",
          "type": "block",
          "wrapper": {
            "className": "flex-initial"
          },
          "className": "flex flex-row gap-3 p-inputtext-sm justify-content-end",
          "components": [
            {
              "id": "pointsHistoryToggleFilters",
              "type": "component",
              "componentType": "Button",
              "className": "min-w-max flex-grow-0 px-3",
              "props": {
                "icon": "pi pi-filter",
                "severity": "primary",
                "outlined": true,
                "size": "small",
                "label": "Фильтры"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "pointsHistoryActiveFilterBlock",
          "type": "block",
          "wrapper": {
            "className": "w-full"
          },
          "components": [
            {
              "id": "pointsHistoryActiveFilterChips",
              "type": "component",
              "componentType": "ActiveFiltersBar",
              "props": {
                "value": "@state.pointsHistory.filters"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.pointsHistory.filters"
                      }
                    },
                    "requestUserPointsHistory"
                  ]
                }
              ]
            },
            {
              "id": "pointsHistoryFilterDrawer",
              "type": "component",
              "componentType": "FiltersPanel",
              "props": {
                "value": "@state.pointsHistory.filters",
                "visible": "@state.filtersVisible",
                "position": "right",
                "header": "Фильтры"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.pointsHistory.filters"
                      }
                    },
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    },
                    "requestUserPointsHistory"
                  ]
                },
                {
                  "type": "onHide",
                  "commands": [
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "pointsHistoryTableSection",
      "type": "section",
      "blocks": [
        {
          "id": "pointsHistoryTableBlock",
          "type": "block",
          "components": [
            {
              "id": "pointsHistoryTable",
              "type": "component",
              "componentType": "DataTable",
              "props": {
                "value": "@state.pointsHistory.value",
                "columns": "@state.pointsHistory.columns",
                "totalRecords": "@state.pointsHistory.totalRecords",
                "rows": "@state.pointsHistory.rows",
                "first": "@state.pointsHistory.first",
                "sortField": "@state.pointsHistory.sortField",
                "sortOrder": "@state.pointsHistory.sortOrder",
                "paginator": true,
                "lazy": true,
                "size": "normal",
                "rowsPerPageOptions": [5, 10, 25, 50]
              },
              "events": [
                {
                  "type": "onPage",
                  "commands": ["requestUserPointsHistory"]
                },
                {
                  "type": "onSort",
                  "commands": ["requestUserPointsHistory"]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
