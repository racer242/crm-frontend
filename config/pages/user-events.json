{
  "id": "user-events",
  "type": "page",
  "route": "/users/[user_id]/events",
  "state": {
    "loading": false,
    "initialized": true,
    "filtersVisible": false,
    "userData": {
      "id": "",
      "fullName": ""
    },
    "events": {
      "value": [],
      "columns": [],
      "totalRecords": 0,
      "rows": 10,
      "first": 0,
      "sortField": "",
      "sortOrder": 1,
      "filters": [],
      "search": ""
    }
  },
  "meta": {
    "title": "Действия участника — CRM Platform"
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}",
      "method": "GET",
      "target": "state.userData",
      "adapter": "user.response.js"
    },
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}/log/events",
      "data": {
        "first": "{$location.params.first}",
        "rows": "{$location.params.rows}",
        "sortField": "{$location.params.sortField}",
        "sortOrder": "{$location.params.sortOrder}",
        "search": "{$location.params.search}",
        "filters": "{$location.params.filters}"
      },
      "method": "GET",
      "target": "state.events"
    }
  ],
  "shortcuts": {
    "requestUserEvents": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "sendRequest",
            "params": {
              "url": "/api/users/{$location.routeParams.user_id}/log/events",
              "method": "GET",
              "target": "state.events",
              "data": {
                "first": "{$state.events.first}",
                "rows": "{$state.events.rows}",
                "sortField": "{$state.events.sortField}",
                "sortOrder": "{$state.events.sortOrder}",
                "search": "{$state.events.search}",
                "filters": "{$state.events.filters}"
              }
            }
          },
          {
            "type": "mergeUrlParams",
            "params": {
              "values": {
                "first": "{$state.events.first}",
                "rows": "{$state.events.rows}",
                "sortField": "{$state.events.sortField}",
                "sortOrder": "{$state.events.sortOrder}",
                "search": "{$state.events.search}",
                "filters": "{$state.events.filters}"
              },
              "format": [
                {
                  "prop": "filters",
                  "type": "PopIfHasNullProps",
                  "params": { "props": ["value"] }
                },
                {
                  "prop": "filters",
                  "type": "RemoveProps",
                  "params": { "props": ["name", "type", "opts"] }
                }
              ]
            }
          }
        ]
      }
    }
  },
  "sections": [
    {
      "id": "breadcrumbSection",
      "type": "section",
      "className": "",
      "blocks": [
        {
          "id": "breadcrumbBlock",
          "type": "block",
          "components": [
            {
              "id": "breadcrumb",
              "type": "component",
              "componentType": "Breadcrumb",
              "className": "border-none p-0",
              "props": {
                "home": { "icon": "pi pi-home", "url": "/" },
                "model": [
                  { "label": "Участники", "route": "/users" },
                  {
                    "label": "@state.userData.fullName",
                    "route": "/users/{@state.userData.id}"
                  },
                  { "label": "Действия" }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "menuSection",
      "type": "section",
      "blocks": [
        {
          "id": "menuBlock",
          "type": "block",
          "className": "w-full",
          "components": [
            {
              "id": "menubar",
              "type": "component",
              "componentType": "Menubar",
              "props": {
                "activeItemId": "activity",
                "pt": { "menu": { "className": "gap-1" } },
                "$ref": "../menus/user.json"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "eventsFilters",
      "type": "section",
      "className": "flex gap-3",
      "blocks": [
        {
          "id": "eventsSearchBlock",
          "type": "block",
          "className": "w-full",
          "components": [
            {
              "id": "eventsSearchInput",
              "type": "component",
              "className": "w-full p-inputtext-sm",
              "componentType": "InputTextWithThrottle",
              "props": {
                "placeholder": "Быстрый поиск...",
                "throttleDelay": 500,
                "value": "@state.events.search"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.events.search"
                      }
                    },
                    "requestUserEvents"
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "eventsFilterBlock",
          "type": "block",
          "wrapper": {
            "className": "flex-initial"
          },
          "className": "flex flex-row gap-3 p-inputtext-sm justify-content-end",
          "components": [
            {
              "id": "eventsToggleFilters",
              "type": "component",
              "componentType": "Button",
              "className": "min-w-max flex-grow-0 px-3",
              "props": {
                "icon": "pi pi-filter",
                "severity": "primary",
                "outlined": true,
                "size": "small",
                "label": "Фильтры"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "eventsActiveFilterBlock",
          "type": "block",
          "wrapper": {
            "className": "w-full"
          },
          "components": [
            {
              "id": "eventsActiveFilterChips",
              "type": "component",
              "componentType": "ActiveFiltersBar",
              "props": {
                "value": "@state.events.filters"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.events.filters"
                      }
                    },
                    "requestUserEvents"
                  ]
                }
              ]
            },
            {
              "id": "eventsFilterDrawer",
              "type": "component",
              "componentType": "FiltersPanel",
              "props": {
                "value": "@state.events.filters",
                "visible": "@state.filtersVisible",
                "position": "right",
                "header": "Фильтры"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.events.filters"
                      }
                    },
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    },
                    "requestUserEvents"
                  ]
                },
                {
                  "type": "onHide",
                  "commands": [
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "eventsTableSection",
      "type": "section",
      "blocks": [
        {
          "id": "eventsTableBlock",
          "type": "block",
          "components": [
            {
              "id": "eventsTable",
              "type": "component",
              "componentType": "DataTable",
              "props": {
                "value": "@state.events.value",
                "columns": "@state.events.columns",
                "totalRecords": "@state.events.totalRecords",
                "rows": "@state.events.rows",
                "first": "@state.events.first",
                "sortField": "@state.events.sortField",
                "sortOrder": "@state.events.sortOrder",
                "paginator": true,
                "lazy": true,
                "size": "normal",
                "rowsPerPageOptions": [5, 10, 25, 50]
              },
              "events": [
                {
                  "type": "onPage",
                  "commands": ["requestUserEvents"]
                },
                {
                  "type": "onSort",
                  "commands": ["requestUserEvents"]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
