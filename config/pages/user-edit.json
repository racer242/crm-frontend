{
  "id": "user-edit",
  "type": "page",
  "route": "/users/[user_id]/edit",
  "state": {
    "loading": false,
    "saving": false,
    "saved": false,
    "sentSuccessfully": false,
    "userData": {
      "id": "",
      "bot_id": "",
      "first_name": "",
      "last_name": "",
      "email": "",
      "phone": "",
      "delivery_address": "",
      "delivery_comment": "",
      "is_blocked": false,
      "block_reason": "",
      "groups": [],
      "groupOptions": [],
      "selectedGroups": [],
      "fullName": ""
    }
  },
  "meta": {
    "title": "Редактирование участника — CRM Platform"
  },
  "shortcuts": {
    "saveUserGroups": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "setProperty",
            "params": {
              "target": "state.saving",
              "value": true
            }
          },
          {
            "type": "setProperty",
            "params": {
              "target": "state.saveResult",
              "value": null
            }
          },
          {
            "type": "sendRequest",
            "params": {
              "url": "/api/users/{$location.routeParams.user_id}",
              "method": "PATCH",
              "data": "{$state.userData}",
              "target": "state.saveResult",
              "onError": [
                {
                  "type": "setProperty",
                  "params": {
                    "target": "state.saving",
                    "value": false
                  }
                },
                {
                  "type": "setProperty",
                  "params": {
                    "target": "state.sentSuccessfully",
                    "value": false
                  }
                },
                {
                  "type": "log",
                  "params": {
                    "message": "{$state.dataFeedErrors}"
                  }
                }
              ],
              "onSuccess": [
                {
                  "type": "sendRequest",
                  "params": {
                    "url": "/api/users/{$location.routeParams.user_id}/groups",
                    "method": "PUT",
                    "data": {
                      "ids": "{$state.userData.selectedGroups}"
                    },
                    "target": "state.groupsSaveResult",
                    "onError": [
                      {
                        "type": "setProperty",
                        "params": {
                          "target": "state.saving",
                          "value": false
                        }
                      },
                      {
                        "type": "showToast",
                        "params": {
                          "severity": "warning",
                          "summary": "Успешно",
                          "message": "Данные сохранены, но не удалось обновить группы"
                        }
                      }
                    ],
                    "onSuccess": [
                      {
                        "type": "setProperty",
                        "params": {
                          "target": "state.saving",
                          "value": false
                        }
                      },
                      {
                        "type": "setProperty",
                        "params": {
                          "target": "state.saved",
                          "value": true
                        }
                      },
                      {
                        "type": "setProperty",
                        "params": {
                          "target": "state.sentSuccessfully",
                          "value": true
                        }
                      }
                    ]
                  }
                }
              ]
            }
          }
        ]
      }
    }
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}",
      "method": "GET",
      "target": "state.userData"
    }
  ],
  "sections": [
    {
      "id": "breadcrumbSection",
      "type": "section",
      "className": "",
      "blocks": [
        {
          "id": "breadcrumbBlock",
          "type": "block",
          "components": [
            {
              "id": "breadcrumb",
              "type": "component",
              "componentType": "Breadcrumb",
              "className": "border-none p-0",
              "props": {
                "home": { "icon": "pi pi-home", "url": "/" },
                "model": [
                  { "label": "Участники", "route": "/users" },
                  {
                    "label": "@state.userData.fullName",
                    "route": "/users/{@state.userData.id}"
                  },
                  { "label": "Редактирование" }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "formMainSection",
      "type": "section",
      "className": "",
      "grid": {
        "cols": [
          "col-12 lg:col-6",
          "col-12 lg:col-6",
          "col-12 lg:col-6",
          "col-12 lg:col-6"
        ],
        "padding": "p-2"
      },
      "blocks": [
        {
          "id": "personalBlock",
          "type": "block",
          "wrapper": {
            "component": "Panel",
            "props": {
              "header": "Личные данные"
            }
          },
          "className": "flex flex-column",
          "components": [
            {
              "id": "firstNameGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "flex flex-column gap-1 mb-2",
              "props": {
                "label": "Имя",
                "labelClassName": "font-bold text-sm",
                "components": [
                  {
                    "id": "firstNameInput",
                    "type": "component",
                    "componentType": "InputText",
                    "className": "w-full",
                    "props": {
                      "value": "@state.userData.first_name",
                      "placeholder": "Введите имя"
                    },
                    "events": [
                      {
                        "type": "onChange",
                        "commands": [
                          {
                            "type": "setProperty",
                            "params": {
                              "source": "event.value",
                              "target": "state.userData.first_name"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            {
              "id": "lastNameGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "flex flex-column gap-1 mb-2",
              "props": {
                "label": "Фамилия",
                "labelClassName": "font-bold text-sm",
                "components": [
                  {
                    "id": "lastNameInput",
                    "type": "component",
                    "componentType": "InputText",
                    "props": {
                      "value": "@state.userData.last_name",
                      "placeholder": "Введите фамилию",
                      "className": "w-full"
                    },
                    "events": [
                      {
                        "type": "onChange",
                        "commands": [
                          {
                            "type": "setProperty",
                            "params": {
                              "source": "event.value",
                              "target": "state.userData.last_name"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            {
              "id": "emailGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "flex flex-column gap-1 mb-2",
              "props": {
                "label": "E-mail",
                "labelClassName": "font-bold text-sm",
                "components": [
                  {
                    "id": "emailInput",
                    "type": "component",
                    "componentType": "InputText",
                    "props": {
                      "value": "@state.userData.email",
                      "placeholder": "Введите e-mail",
                      "keyfilter": "email",
                      "className": "w-full"
                    },
                    "events": [
                      {
                        "type": "onChange",
                        "commands": [
                          {
                            "type": "setProperty",
                            "params": {
                              "source": "event.value",
                              "target": "state.userData.email"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            {
              "id": "phoneGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "flex flex-column gap-1 mb-2",
              "props": {
                "label": "Телефон",
                "labelClassName": "font-bold text-sm",
                "components": [
                  {
                    "id": "phoneInput",
                    "type": "component",
                    "componentType": "InputMask",
                    "props": {
                      "value": "@state.userData.phone",
                      "placeholder": "Введите телефон",
                      "mask": "+9 (999) 999-99-99",
                      "className": "w-full"
                    },
                    "events": [
                      {
                        "type": "onChange",
                        "commands": [
                          {
                            "type": "setProperty",
                            "params": {
                              "source": "event.value",
                              "target": "state.userData.phone"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            }
          ]
        },
        {
          "id": "deliveryBlock",
          "type": "block",
          "wrapper": {
            "component": "Panel",
            "props": {
              "header": "Адрес доставки"
            }
          },
          "className": "flex flex-column",
          "components": [
            {
              "id": "deliveryAddressGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "flex flex-column gap-1 mb-2",
              "props": {
                "label": "Адрес",
                "labelClassName": "font-bold text-sm",
                "components": [
                  {
                    "id": "deliveryAddressInput",
                    "type": "component",
                    "componentType": "InputText",
                    "props": {
                      "value": "@state.userData.delivery_address",
                      "placeholder": "Введите адрес доставки",
                      "className": "w-full"
                    },
                    "events": [
                      {
                        "type": "onChange",
                        "commands": [
                          {
                            "type": "setProperty",
                            "params": {
                              "source": "event.value",
                              "target": "state.userData.delivery_address"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            {
              "id": "deliveryCommentGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "flex flex-column gap-1 mb-2",
              "props": {
                "label": "Комментарий",
                "labelClassName": "font-bold text-sm",
                "components": [
                  {
                    "id": "deliveryCommentInput",
                    "type": "component",
                    "componentType": "InputTextarea",
                    "props": {
                      "value": "@state.userData.delivery_comment",
                      "placeholder": "Комментарий к доставке",
                      "rows": 3,
                      "autoResize": true,
                      "className": "w-full"
                    },
                    "events": [
                      {
                        "type": "onChange",
                        "commands": [
                          {
                            "type": "setProperty",
                            "params": {
                              "source": "event.value",
                              "target": "state.userData.delivery_comment"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            }
          ]
        },
        {
          "id": "statusBlock",
          "type": "block",
          "wrapper": {
            "component": "Panel",
            "props": {
              "header": "Статус"
            }
          },
          "className": "flex flex-column",
          "components": [
            {
              "id": "blockedSwitchGroup",
              "type": "component",
              "componentType": "LayoutGroup",
              "className": "flex align-items-center gap-3 mb-3",
              "props": {
                "components": [
                  {
                    "id": "blockedSwitch",
                    "type": "component",
                    "componentType": "InputSwitch",
                    "className": "mb-0",
                    "props": {
                      "value": "@state.userData.is_blocked"
                    },
                    "events": [
                      {
                        "type": "onChange",
                        "commands": [
                          {
                            "type": "setProperty",
                            "params": {
                              "source": "event.value",
                              "target": "state.userData.is_blocked"
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "id": "blockedLabel",
                    "type": "component",
                    "componentType": "Text",
                    "props": {
                      "value": "Заблокировать"
                    }
                  }
                ]
              }
            },
            {
              "id": "blockReasonGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "flex flex-column gap-1",
              "props": {
                "label": "Причина",
                "labelClassName": "font-bold text-sm",
                "components": [
                  {
                    "id": "blockReasonInput",
                    "type": "component",
                    "componentType": "InputTextarea",
                    "props": {
                      "value": "@state.userData.block_reason",
                      "placeholder": "Причина блокировки",
                      "rows": 3,
                      "autoResize": true,
                      "className": "w-full"
                    },
                    "events": [
                      {
                        "type": "onChange",
                        "commands": [
                          {
                            "type": "setProperty",
                            "params": {
                              "source": "event.value",
                              "target": "state.userData.block_reason"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            }
          ]
        },
        {
          "id": "groupsBlock",
          "type": "block",
          "wrapper": {
            "component": "Panel",
            "props": {
              "header": "Группа"
            }
          },
          "className": "flex flex-column",
          "components": [
            {
              "id": "groupsMultiSelect",
              "type": "component",
              "componentType": "MultiSelect",
              "props": {
                "options": "@state.userData.groupOptions",
                "value": "@state.userData.selectedGroups",
                "placeholder": "Выберите группы",
                "className": "w-full",
                "maxSelectedLabels": 5,
                "showClear": true
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.userData.selectedGroups"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "buttonsSection",
      "type": "section",
      "className": "flex justify-content-center",
      "blocks": [
        {
          "id": "buttonsBlock",
          "type": "block",
          "wrapper": {
            "showHeader": false,
            "component": "Panel",
            "props": {
              "className": "flex-grow-1",
              "pt": {
                "content": {
                  "style": { "background": "var(--surface-50) !important" }
                }
              }
            }
          },
          "className": "flex flex-wrap gap-3 justify-content-center md:justify-content-start",
          "components": [
            {
              "id": "btnSaveAndGo",
              "type": "component",
              "componentType": "Button",
              "props": {
                "label": "Сохранить",
                "icon": "pi pi-check",
                "severity": "success",
                "disabled": "@state.saving"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    "saveUserGroups",
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/users/{$location.routeParams.user_id}",
                        "condition": "{$state.sentSuccessfully}"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "btnApply",
              "type": "component",
              "componentType": "Button",
              "props": {
                "label": "Применить",
                "icon": "pi pi-check",
                "severity": "success",
                "outlined": true,
                "disabled": "@state.saving"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    "saveUserGroups",
                    {
                      "type": "showToast",
                      "params": {
                        "severity": "success",
                        "summary": "Успешно",
                        "message": "Данные участника сохранены"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "btnCancel",
              "type": "component",
              "componentType": "Button",
              "props": {
                "label": "Отменить изменения",
                "icon": "pi pi-times",
                "severity": "secondary",
                "outlined": true
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/users/{$location.routeParams.user_id}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
