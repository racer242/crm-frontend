{
  "id": "user-edit",
  "type": "page",
  "route": "/users/[user_id]/edit",
  "state": {
    "loading": false,
    "saving": false,
    "saved": false,
    "userData": {
      "id": "",
      "bot_id": "",
      "first_name": "",
      "last_name": "",
      "email": "",
      "phone": "",
      "delivery_address": "",
      "delivery_comment": "",
      "is_blocked": false,
      "block_reason": "",
      "groups": [],
      "groupOptions": [],
      "selectedGroups": [],
      "fullName": ""
    }
  },
  "meta": {
    "title": "Редактирование участника — CRM Platform"
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}",
      "method": "GET",
      "target": "state.userData",
      "adapter": "user.response.js"
    }
  ],
  "sections": [
    {
      "id": "breadcrumbSection",
      "type": "section",
      "className": "",
      "blocks": [
        {
          "id": "breadcrumbBlock",
          "type": "block",
          "components": [
            {
              "id": "breadcrumb",
              "type": "component",
              "componentType": "Breadcrumb",
              "className": "border-none p-0",
              "props": {
                "home": { "icon": "pi pi-home", "url": "/" },
                "model": [
                  { "label": "Участники", "route": "/users" },
                  {
                    "label": "@state.userData.fullName",
                    "route": "/users/{$location.routeParams.user_id}"
                  },
                  { "label": "Редактирование" }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "formMainSection",
      "type": "section",
      "className": "flex",
      "grid": {
        "cols": ["col-12 lg:col-6", "col-12 lg:col-6"],
        "padding": "p-2"
      },
      "blocks": [
        {
          "id": "leftColumnBlock",
          "type": "block",
          "className": "flex flex-column gap-3",
          "components": [
            {
              "id": "personalPanel",
              "type": "component",
              "componentType": "Panel",
              "props": {
                "header": "Личные данные"
              },
              "components": [
                {
                  "id": "firstNameGroup",
                  "type": "component",
                  "componentType": "LabelledGroup",
                  "className": "flex align-items-start gap-3 mb-2",
                  "props": {
                    "label": "Имя",
                    "labelClassName": "font-bold text-sm col-3",
                    "containerClassName": "col-9",
                    "components": [
                      {
                        "id": "firstNameInput",
                        "type": "component",
                        "componentType": "InputText",
                        "props": {
                          "value": "@state.userData.first_name",
                          "placeholder": "Введите имя",
                          "className": "w-full"
                        },
                        "events": [
                          {
                            "type": "onChange",
                            "commands": [
                              {
                                "type": "setProperty",
                                "params": {
                                  "source": "event.value",
                                  "target": "state.userData.first_name"
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                },
                {
                  "id": "lastNameGroup",
                  "type": "component",
                  "componentType": "LabelledGroup",
                  "className": "flex align-items-start gap-3 mb-2",
                  "props": {
                    "label": "Фамилия",
                    "labelClassName": "font-bold text-sm col-3",
                    "containerClassName": "col-9",
                    "components": [
                      {
                        "id": "lastNameInput",
                        "type": "component",
                        "componentType": "InputText",
                        "props": {
                          "value": "@state.userData.last_name",
                          "placeholder": "Введите фамилию",
                          "className": "w-full"
                        },
                        "events": [
                          {
                            "type": "onChange",
                            "commands": [
                              {
                                "type": "setProperty",
                                "params": {
                                  "source": "event.value",
                                  "target": "state.userData.last_name"
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                },
                {
                  "id": "emailGroup",
                  "type": "component",
                  "componentType": "LabelledGroup",
                  "className": "flex align-items-start gap-3 mb-2",
                  "props": {
                    "label": "E-mail",
                    "labelClassName": "font-bold text-sm col-3",
                    "containerClassName": "col-9",
                    "components": [
                      {
                        "id": "emailInput",
                        "type": "component",
                        "componentType": "InputText",
                        "props": {
                          "value": "@state.userData.email",
                          "placeholder": "Введите e-mail",
                          "keyfilter": "email",
                          "className": "w-full"
                        },
                        "events": [
                          {
                            "type": "onChange",
                            "commands": [
                              {
                                "type": "setProperty",
                                "params": {
                                  "source": "event.value",
                                  "target": "state.userData.email"
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                },
                {
                  "id": "phoneGroup",
                  "type": "component",
                  "componentType": "LabelledGroup",
                  "className": "flex align-items-start gap-3 mb-2",
                  "props": {
                    "label": "Телефон",
                    "labelClassName": "font-bold text-sm col-3",
                    "containerClassName": "col-9",
                    "components": [
                      {
                        "id": "phoneInput",
                        "type": "component",
                        "componentType": "InputText",
                        "props": {
                          "value": "@state.userData.phone",
                          "placeholder": "Введите телефон",
                          "keyfilter": "int",
                          "className": "w-full"
                        },
                        "events": [
                          {
                            "type": "onChange",
                            "commands": [
                              {
                                "type": "setProperty",
                                "params": {
                                  "source": "event.value",
                                  "target": "state.userData.phone"
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                }
              ]
            },
            {
              "id": "addressPanel",
              "type": "component",
              "componentType": "Panel",
              "props": {
                "header": "Адрес доставки"
              },
              "components": [
                {
                  "id": "deliveryAddressGroup",
                  "type": "component",
                  "componentType": "LabelledGroup",
                  "className": "flex align-items-start gap-3 mb-2",
                  "props": {
                    "label": "Адрес",
                    "labelClassName": "font-bold text-sm col-3",
                    "containerClassName": "col-9",
                    "components": [
                      {
                        "id": "deliveryAddressInput",
                        "type": "component",
                        "componentType": "InputText",
                        "props": {
                          "value": "@state.userData.delivery_address",
                          "placeholder": "Введите адрес доставки",
                          "className": "w-full"
                        },
                        "events": [
                          {
                            "type": "onChange",
                            "commands": [
                              {
                                "type": "setProperty",
                                "params": {
                                  "source": "event.value",
                                  "target": "state.userData.delivery_address"
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                },
                {
                  "id": "deliveryCommentGroup",
                  "type": "component",
                  "componentType": "LabelledGroup",
                  "className": "flex align-items-start gap-3 mb-2",
                  "props": {
                    "label": "Комментарий",
                    "labelClassName": "font-bold text-sm col-3",
                    "containerClassName": "col-9",
                    "components": [
                      {
                        "id": "deliveryCommentInput",
                        "type": "component",
                        "componentType": "InputTextarea",
                        "props": {
                          "value": "@state.userData.delivery_comment",
                          "placeholder": "Комментарий к доставке",
                          "rows": 3,
                          "autoResize": true,
                          "className": "w-full"
                        },
                        "events": [
                          {
                            "type": "onChange",
                            "commands": [
                              {
                                "type": "setProperty",
                                "params": {
                                  "source": "event.value",
                                  "target": "state.userData.delivery_comment"
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                }
              ]
            }
          ]
        },
        {
          "id": "rightColumnBlock",
          "type": "block",
          "className": "flex flex-column gap-3",
          "components": [
            {
              "id": "groupsPanel",
              "type": "component",
              "componentType": "Panel",
              "props": {
                "header": "Группа"
              },
              "components": [
                {
                  "id": "groupsMultiSelect",
                  "type": "component",
                  "componentType": "MultiSelect",
                  "props": {
                    "options": "@state.userData.groupOptions",
                    "value": "@state.userData.selectedGroups",
                    "placeholder": "Выберите группы",
                    "className": "w-full",
                    "maxSelectedLabels": 5,
                    "showClear": true
                  },
                  "events": [
                    {
                      "type": "onChange",
                      "commands": [
                        {
                          "type": "setProperty",
                          "params": {
                            "source": "event.value",
                            "target": "state.userData.selectedGroups"
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "id": "statusPanel",
              "type": "component",
              "componentType": "Panel",
              "props": {
                "header": "Статус"
              },
              "components": [
                {
                  "id": "blockedSwitchGroup",
                  "type": "component",
                  "componentType": "LabelledGroup",
                  "className": "flex align-items-start gap-3 mb-2",
                  "props": {
                    "label": "Заблокировать",
                    "labelClassName": "font-bold text-sm col-3",
                    "containerClassName": "col-9 flex align-items-center",
                    "components": [
                      {
                        "id": "blockedSwitch",
                        "type": "component",
                        "componentType": "InputSwitch",
                        "props": {
                          "value": "@state.userData.is_blocked"
                        },
                        "events": [
                          {
                            "type": "onChange",
                            "commands": [
                              {
                                "type": "setProperty",
                                "params": {
                                  "source": "event.value",
                                  "target": "state.userData.is_blocked"
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                },
                {
                  "id": "blockReasonGroup",
                  "type": "component",
                  "componentType": "LabelledGroup",
                  "className": "flex align-items-start gap-3",
                  "props": {
                    "label": "Причина",
                    "labelClassName": "font-bold text-sm col-3",
                    "containerClassName": "col-9",
                    "components": [
                      {
                        "id": "blockReasonInput",
                        "type": "component",
                        "componentType": "InputTextarea",
                        "props": {
                          "value": "@state.userData.block_reason",
                          "placeholder": "Причина блокировки",
                          "rows": 3,
                          "autoResize": true,
                          "className": "w-full"
                        },
                        "events": [
                          {
                            "type": "onChange",
                            "commands": [
                              {
                                "type": "setProperty",
                                "params": {
                                  "source": "event.value",
                                  "target": "state.userData.block_reason"
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "buttonsSection",
      "type": "section",
      "className": "flex justify-content-center mt-3",
      "blocks": [
        {
          "id": "buttonsBlock",
          "type": "block",
          "components": [
            {
              "id": "btnSave",
              "type": "component",
              "componentType": "Button",
              "className": "mr-2",
              "props": {
                "label": "Сохранить",
                "icon": "pi pi-check",
                "severity": "success",
                "disabled": "@state.saving"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "target": "state.saving",
                        "value": true
                      }
                    },
                    {
                      "type": "setProperty",
                      "params": {
                        "target": "state.saveResult",
                        "value": null
                      }
                    },
                    {
                      "type": "sendRequest",
                      "params": {
                        "url": "/api/users/{$location.routeParams.user_id}",
                        "method": "PATCH",
                        "data": "{$state.userData}",
                        "target": "state.saveResult",
                        "adapter": {
                          "request": "user-edit.request.js"
                        },
                        "onError": [
                          {
                            "type": "setProperty",
                            "params": {
                              "target": "state.saving",
                              "value": false
                            }
                          },
                          {
                            "type": "showToast",
                            "params": {
                              "severity": "error",
                              "summary": "Ошибка",
                              "detail": "Не удалось сохранить данные участника"
                            }
                          }
                        ],
                        "onSuccess": [
                          {
                            "type": "sendRequest",
                            "params": {
                              "url": "/api/users/{$location.routeParams.user_id}/groups",
                              "method": "PUT",
                              "data": {
                                "ids": "{$state.userData.selectedGroups}"
                              },
                              "target": "state.groupsSaveResult",
                              "onError": [
                                {
                                  "type": "setProperty",
                                  "params": {
                                    "target": "state.saving",
                                    "value": false
                                  }
                                },
                                {
                                  "type": "showToast",
                                  "params": {
                                    "severity": "error",
                                    "summary": "Ошибка",
                                    "detail": "Данные сохранены, но не удалось обновить группы"
                                  }
                                }
                              ],
                              "onSuccess": [
                                {
                                  "type": "setProperty",
                                  "params": {
                                    "target": "state.saving",
                                    "value": false
                                  }
                                },
                                {
                                  "type": "setProperty",
                                  "params": {
                                    "target": "state.saved",
                                    "value": true
                                  }
                                },
                                {
                                  "type": "showToast",
                                  "params": {
                                    "severity": "success",
                                    "summary": "Успешно",
                                    "detail": "Данные участника сохранены"
                                  }
                                }
                              ]
                            }
                          }
                        ]
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "btnCancel",
              "type": "component",
              "componentType": "Button",
              "props": {
                "label": "Отменить изменения",
                "icon": "pi pi-times",
                "severity": "secondary",
                "outlined": true
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/users/{$location.routeParams.user_id}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
