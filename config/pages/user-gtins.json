{
  "id": "user-gtins",
  "type": "page",
  "route": "/users/[user_id]/gtins",
  "state": {
    "loading": false,
    "initialized": true,
    "filtersVisible": false,
    "userData": {
      "id": "",
      "fullName": ""
    },
    "gtins": {
      "value": [],
      "columns": [],
      "totalRecords": 0,
      "rows": 10,
      "first": 0,
      "sortField": "",
      "sortOrder": 1,
      "filters": [],
      "search": ""
    }
  },
  "meta": {
    "title": "Коды ЧЗ участника — CRM Platform"
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}",
      "method": "GET",
      "target": "state.userData"
    },
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}/gtins",
      "data": {
        "first": "{$location.params.first}",
        "rows": "{$location.params.rows}",
        "sortField": "{$location.params.sortField}",
        "sortOrder": "{$location.params.sortOrder}",
        "search": "{$location.params.search}",
        "filters": "{$location.params.filters}"
      },
      "method": "GET",
      "target": "state.gtins"
    }
  ],
  "shortcuts": {
    "requestUserGtins": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "sendRequest",
            "params": {
              "url": "/api/users/{$location.routeParams.user_id}/gtins",
              "method": "GET",
              "target": "state.gtins",
              "data": {
                "event": "{$event}",
                "first": "{$state.gtins.first}",
                "rows": "{$state.gtins.rows}",
                "sortField": "{$state.gtins.sortField}",
                "sortOrder": "{$state.gtins.sortOrder}",
                "search": "{$state.gtins.search}",
                "filters": "{$state.gtins.filters}"
              },
              "format": { "$ref": "../system/list-request-format.json" }
            }
          },
          {
            "type": "mergeUrlParams",
            "params": {
              "values": {
                "first": "{$state.gtins.first}",
                "rows": "{$state.gtins.rows}",
                "sortField": "{$state.gtins.sortField}",
                "sortOrder": "{$state.gtins.sortOrder}",
                "search": "{$state.gtins.search}",
                "filters": "{$state.gtins.filters}"
              },
              "format": [
                {
                  "prop": "filters",
                  "type": "PopIfHasNullProps",
                  "params": { "props": ["value"] }
                },
                {
                  "prop": "filters",
                  "type": "RemoveProps",
                  "params": { "props": ["name", "type", "opts"] }
                }
              ]
            }
          }
        ]
      }
    }
  },
  "sections": [
    {
      "id": "breadcrumbSection",
      "type": "section",
      "className": "",
      "blocks": [
        {
          "id": "breadcrumbBlock",
          "type": "block",
          "components": [
            {
              "id": "breadcrumb",
              "type": "component",
              "componentType": "Breadcrumb",
              "className": "border-none p-0",
              "props": {
                "home": { "icon": "pi pi-home", "url": "/" },
                "model": [
                  { "label": "Участники", "route": "/users" },
                  {
                    "label": "@state.userData.fullName",
                    "route": "/users/{@state.userData.id}"
                  },
                  { "label": "Коды Честный Знак" }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "menuSection",
      "type": "section",
      "blocks": [
        {
          "id": "menuBlock",
          "type": "block",
          "className": "w-full",
          "components": [
            {
              "id": "menubar",
              "type": "component",
              "componentType": "Menubar",
              "props": {
                "activeItemId": "production",
                "activeSubitemId": "gtins",
                "pt": { "menu": { "className": "gap-1" } },
                "$ref": "../menus/user.json"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "gtinsFilters",
      "type": "section",
      "className": "flex flex-column gap-3 mb-3",
      "blocks": [
        {
          "id": "gtinsSearchBlock",
          "type": "block",
          "className": "w-full flex gap-3",
          "components": [
            {
              "id": "gtinsSearchInput",
              "type": "component",
              "className": "w-full p-inputtext-sm mb-0",
              "componentType": "InputTextWithThrottle",
              "props": {
                "placeholder": "Быстрый поиск...",
                "throttleDelay": 500,
                "value": "@state.gtins.search"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.gtins.search"
                      }
                    },
                    "requestUserGtins"
                  ]
                }
              ]
            },
            {
              "id": "gtinsToggleFilters",
              "type": "component",
              "componentType": "Button",
              "className": "min-w-max flex-grow-0 px-3",
              "props": {
                "icon": "pi pi-filter",
                "severity": "primary",
                "outlined": true,
                "size": "small",
                "label": "Фильтры"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "gtinsActiveFilterBlock",
          "type": "block",
          "wrapper": {
            "className": "w-full"
          },
          "components": [
            {
              "id": "gtinsActiveFilterChips",
              "type": "component",
              "componentType": "ActiveFiltersBar",
              "props": {
                "value": "@state.gtins.filters"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.gtins.filters"
                      }
                    },
                    "requestUserGtins"
                  ]
                }
              ]
            },
            {
              "id": "gtinsFilterDrawer",
              "type": "component",
              "componentType": "FiltersPanel",
              "props": {
                "value": "@state.gtins.filters",
                "visible": "@state.filtersVisible",
                "position": "right",
                "header": "Фильтры"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.gtins.filters"
                      }
                    },
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    },
                    "requestUserGtins"
                  ]
                },
                {
                  "type": "onHide",
                  "commands": [
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "gtinsTableSection",
      "type": "section",
      "blocks": [
        {
          "id": "gtinsTableBlock",
          "type": "block",
          "className": "w-full",
          "components": [
            {
              "id": "gtinsTable",
              "type": "component",
              "componentType": "DataTable",
              "props": {
                "value": "@state.gtins.value",
                "columns": "@state.gtins.columns",
                "totalRecords": "@state.gtins.totalRecords",
                "rows": "@state.gtins.rows",
                "first": "@state.gtins.first",
                "sortField": "@state.gtins.sortField",
                "sortOrder": "@state.gtins.sortOrder",
                "paginator": true,
                "lazy": true,
                "size": "normal",
                "selectionMode": "single",
                "rowsPerPageOptions": [5, 10, 25, 50]
              },
              "events": [
                {
                  "type": "onPage",
                  "commands": ["requestUserGtins"]
                },
                {
                  "type": "onSort",
                  "commands": ["requestUserGtins"]
                },
                {
                  "type": "onRowClick",
                  "commands": [
                    {
                      "type": "log",
                      "params": {
                        "message": "{$event.data}"
                      }
                    },
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/users/{$location.routeParams.user_id}/gtins/{$event.data._rowId}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
