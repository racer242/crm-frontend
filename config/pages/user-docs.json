{
  "id": "user-docs",
  "type": "page",
  "route": "/users/[user_id]/docs",
  "state": {
    "loading": false,
    "initialized": true,
    "userData": {
      "id": "",
      "fullName": "",
      "initials": "",
      "regDateFormatted": "",
      "authDateFormatted": "",
      "groupList": [],
      "groupsText": "",
      "statusLabel": "",
      "statusSeverity": ""
    },
    "docsData": {
      "passport_photo_first_page": "",
      "passport_photo_registration_page": "",
      "passport_first_name": "",
      "passport_last_name": "",
      "passport_middle_name": "",
      "passport_date_of_birth": "",
      "passport_date_of_birth_formatted": "",
      "passport_series_number": "",
      "passport_issued_by": "",
      "passport_issue_date": "",
      "passport_issue_date_formatted": "",
      "passport_registration_address": "",
      "passport_moderation_status": "",
      "passport_moderation_label": "",
      "passport_moderation_severity": "",
      "inn": "",
      "inn_photo": "",
      "inn_moderation_status": "",
      "inn_moderation_label": "",
      "inn_moderation_severity": "",
      "fullName": ""
    }
  },
  "meta": {
    "title": "Документы участника — CRM Platform"
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}",
      "method": "GET",
      "target": "state.userData",
      "adapter": "user.response.js"
    },
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}/docs",
      "method": "GET",
      "target": "state.docsData",
      "adapter": "user-docs.response.js"
    }
  ],
  "sections": [
    {
      "id": "breadcrumbSection",
      "type": "section",
      "className": "",
      "blocks": [
        {
          "id": "breadcrumbBlock",
          "type": "block",
          "components": [
            {
              "id": "breadcrumb",
              "type": "component",
              "componentType": "Breadcrumb",
              "className": "border-none p-0",
              "props": {
                "home": { "icon": "pi pi-home", "url": "/" },
                "model": [
                  { "label": "Участники", "route": "/users" },
                  { "label": "@state.docsData.fullName" },
                  { "label": "Документы" }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "menuSection",
      "type": "section",
      "blocks": [
        {
          "id": "menuBlock",
          "type": "block",
          "className": "w-full",
          "components": [
            {
              "id": "menubar",
              "type": "component",
              "componentType": "Menubar",
              "props": {
                "activeItemId": "docs",
                "pt": { "menu": { "className": "gap-1" } },
                "$ref": "../menus/user.json"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "docsLayout",
      "type": "section",
      "className": "flex mb-5",
      "grid": {
        "cols": ["col-12 lg:col-6", "col-12 lg:col-6"],
        "padding": "p-2"
      },
      "blocks": [
        {
          "id": "passportColumn",
          "type": "block",
          "wrapper": {
            "component": "Panel",
            "props": {
              "header": "Паспорт"
            }
          },
          "className": "flex flex-column gap-3",
          "components": [
            {
              "id": "passportPhotoFirstPageGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-start mb-2",
              "props": {
                "label": "Фото первой страницы",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "passportPhotoFirstPage",
                    "type": "component",
                    "componentType": "Image",
                    "props": {
                      "src": "@state.docsData.passport_photo_first_page",
                      "alt": "Фото первой страницы паспорта",
                      "preview": true,
                      "width": "250"
                    },
                    "state": {}
                  }
                ]
              }
            },
            {
              "id": "passportPhotoRegPageGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-start mb-2",
              "props": {
                "label": "Фото страницы регистрации",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "passportPhotoRegPage",
                    "type": "component",
                    "componentType": "Image",
                    "props": {
                      "src": "@state.docsData.passport_photo_registration_page",
                      "alt": "Фото страницы регистрации",
                      "preview": true,
                      "width": "250"
                    },
                    "state": {}
                  }
                ]
              }
            },
            {
              "id": "passportLastNameGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Фамилия",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "passportLastName",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.docsData.passport_last_name"
                    },
                    "state": {}
                  }
                ]
              }
            },
            {
              "id": "passportFirstNameGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Имя",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "passportFirstName",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.docsData.passport_first_name"
                    },
                    "state": {}
                  }
                ]
              }
            },
            {
              "id": "passportMiddleNameGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Отчество",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "passportMiddleName",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.docsData.passport_middle_name"
                    },
                    "state": {}
                  }
                ]
              }
            },
            {
              "id": "passportDateOfBirthGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Дата рождения",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "passportDateOfBirth",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.docsData.passport_date_of_birth_formatted"
                    },
                    "state": {}
                  }
                ]
              }
            },
            {
              "id": "passportSeriesNumberGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Серия и номер паспорта",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "passportSeriesNumber",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.docsData.passport_series_number"
                    },
                    "state": {}
                  }
                ]
              }
            },
            {
              "id": "passportIssuedByGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-start mb-2",
              "props": {
                "label": "Кем выдан",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "passportIssuedBy",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.docsData.passport_issued_by"
                    },
                    "state": {}
                  }
                ]
              }
            },
            {
              "id": "passportIssueDateGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Дата выдачи паспорта",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "passportIssueDate",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.docsData.passport_issue_date_formatted"
                    },
                    "state": {}
                  }
                ]
              }
            },
            {
              "id": "passportRegistrationAddressGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-start mb-2",
              "props": {
                "label": "Адрес регистрации",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "passportRegistrationAddress",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.docsData.passport_registration_address"
                    },
                    "state": {}
                  }
                ]
              }
            },
            {
              "id": "passportModerationStatusGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Статус модерации",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "passportModerationTag",
                    "type": "component",
                    "componentType": "Tag",
                    "className": "text-sm px-2 py-1",
                    "props": {
                      "value": "@state.docsData.passport_moderation_label",
                      "severity": "@state.docsData.passport_moderation_severity"
                    },
                    "state": {}
                  }
                ]
              }
            }
          ]
        },
        {
          "id": "innColumn",
          "type": "block",
          "wrapper": {
            "component": "Panel",
            "props": {
              "header": "ИНН"
            }
          },
          "className": "flex flex-column gap-3",
          "components": [
            {
              "id": "innPhotoGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-start mb-2",
              "props": {
                "label": "Фото ИНН",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "innPhoto",
                    "type": "component",
                    "componentType": "Image",
                    "props": {
                      "src": "@state.docsData.inn_photo",
                      "alt": "Фото ИНН",
                      "preview": true,
                      "width": "250"
                    },
                    "state": {}
                  }
                ]
              }
            },
            {
              "id": "innNumberGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Номер ИНН",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "innNumber",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.docsData.inn"
                    },
                    "state": {}
                  }
                ]
              }
            },
            {
              "id": "innModerationStatusGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Статус модерации",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "innModerationTag",
                    "type": "component",
                    "componentType": "Tag",
                    "className": "text-sm px-2 py-1",
                    "props": {
                      "value": "@state.docsData.inn_moderation_label",
                      "severity": "@state.docsData.inn_moderation_severity"
                    },
                    "state": {}
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "actionsSection",
      "type": "section",
      "blocks": [
        {
          "id": "actionsBlock",
          "type": "block",
          "className": "flex justify-content-center mt-3",
          "components": [
            {
              "id": "btnEditDocs",
              "type": "component",
              "componentType": "Button",
              "props": {
                "icon": "pi pi-pencil",
                "label": "Редактировать",
                "size": "small",
                "severity": "info"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "navigate",
                      "params": {
                        "url": "{$config.baseURL}/users/{$location.routeParams.user_id}/docs-edit"
                      }
                    }
                  ]
                }
              ],
              "state": {}
            }
          ]
        }
      ]
    }
  ]
}
