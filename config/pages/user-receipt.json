{
  "id": "user-receipt",
  "type": "page",
  "route": "/users/[user_id]/receipts/[receipt_id]",
  "state": {
    "loading": false,
    "initialized": true,
    "userData": {
      "id": "",
      "first_name": "",
      "last_name": "",
      "email": "",
      "fullName": ""
    },
    "receiptData": {
      "id": "",
      "user_id": "",
      "registration_date": "",
      "purchase_date": "",
      "retail_chain_name": "",
      "promo_products_amount": 0,
      "total_amount": 0,
      "fiscal_data": {},
      "receipt_status": "",
      "moderation_status": "",
      "comment": "",
      "registrationDateFormatted": "",
      "purchaseDateFormatted": "",
      "receiptStatusLabel": "",
      "receiptStatusSeverity": "",
      "moderationStatusLabel": "",
      "moderationStatusSeverity": ""
    },
    "products": {
      "value": [],
      "columns": [],
      "totalRecords": 0
    }
  },
  "meta": {
    "title": "Чек участника — CRM Platform"
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/users/{$location.routeParams.user_id}",
      "method": "GET",
      "target": "state.userData"
    },
    {
      "url": "{$config.baseURL}/api/receipts/{$location.routeParams.receipt_id}",
      "method": "GET",
      "target": "state.receiptData",
      "adapter": {
        "response": "receipt.response.js"
      }
    },
    {
      "url": "{$config.baseURL}/api/receipts/{$location.routeParams.receipt_id}/products",
      "method": "GET",
      "target": "state.products"
    }
  ],
  "shortcuts": {
    "deleteReceipt": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "showConfirmDialog",
            "params": {
              "header": "Подтверждение удаления",
              "message": "Вы уверены, что хотите удалить этот чек?",
              "icon": "pi pi-exclamation-triangle",
              "acceptLabel": "Удалить",
              "rejectLabel": "Отмена"
            },
            "onAccept": [
              {
                "type": "sendRequest",
                "params": {
                  "url": "/api/receipts/{$location.routeParams.receipt_id}",
                  "method": "DELETE",
                  "onSuccess": [
                    {
                      "type": "showToast",
                      "params": {
                        "severity": "success",
                        "summary": "Успешно",
                        "detail": "Чек удален"
                      }
                    },
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/users/{$location.routeParams.user_id}/receipts"
                      }
                    }
                  ],
                  "onError": [
                    {
                      "type": "showToast",
                      "params": {
                        "severity": "error",
                        "summary": "Ошибка",
                        "detail": "Не удалось удалить чек"
                      }
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    }
  },
  "sections": [
    {
      "id": "breadcrumbSection",
      "type": "section",
      "className": "",
      "blocks": [
        {
          "id": "breadcrumbBlock",
          "type": "block",
          "components": [
            {
              "id": "breadcrumb",
              "type": "component",
              "componentType": "Breadcrumb",
              "className": "border-none p-0",
              "props": {
                "home": { "icon": "pi pi-home", "url": "/" },
                "model": [
                  { "label": "Участники", "route": "/users" },
                  {
                    "label": "@state.userData.fullName",
                    "route": "/users/{@state.userData.id}"
                  },
                  {
                    "label": "Чеки",
                    "route": "/users/{@state.userData.id}/receipts"
                  },
                  { "label": "Чек №{@state.receiptData.id}" }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "menuSection",
      "type": "section",
      "blocks": [
        {
          "id": "menuBlock",
          "type": "block",
          "className": "w-full",
          "components": [
            {
              "id": "menubar",
              "type": "component",
              "componentType": "Menubar",
              "props": {
                "activeItemId": "production",
                "activeSubitemId": "receipts",
                "pt": { "menu": { "className": "gap-1" } },
                "$ref": "../menus/user.json"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "mainLayout",
      "type": "section",
      "className": "flex mb-5",
      "grid": {
        "cols": ["col-12"],
        "padding": "p-2"
      },
      "blocks": [
        {
          "id": "receiptDetailsBlock",
          "type": "block",
          "wrapper": {
            "component": "Panel",
            "props": {
              "header": "Информация о чеке"
            }
          },
          "className": "flex flex-column gap-3",
          "components": [
            {
              "id": "receiptIdGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "ID чека",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "receiptId",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.receiptData.id"
                    }
                  }
                ]
              }
            },
            {
              "id": "userNameGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Участник",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "userNameLink",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg cursor-pointer text-primary",
                    "props": {
                      "value": "@state.userData.fullName"
                    },
                    "events": [
                      {
                        "type": "onClick",
                        "commands": [
                          {
                            "type": "navigate",
                            "params": {
                              "url": "/users/{@state.receiptData.user_id}"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            {
              "id": "userEmailGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Email",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "userEmailLink",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg cursor-pointer text-primary",
                    "props": {
                      "value": "@state.userData.email"
                    },
                    "events": [
                      {
                        "type": "onClick",
                        "commands": [
                          {
                            "type": "executeCommand",
                            "params": {
                              "command": "window.open('mailto:{@state.userData.email}', '_blank')"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            },
            {
              "id": "registrationDateGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Дата регистрации",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "registrationDate",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.receiptData.registrationDateFormatted"
                    }
                  }
                ]
              }
            },
            {
              "id": "purchaseDateGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Дата покупки",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "purchaseDate",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.receiptData.purchaseDateFormatted"
                    }
                  }
                ]
              }
            },
            {
              "id": "retailChainGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Торговая сеть",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "retailChain",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.receiptData.retail_chain_name"
                    }
                  }
                ]
              }
            },
            {
              "id": "promoAmountGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Сумма акционных продуктов",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "promoAmount",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.receiptData.promo_products_amount"
                    }
                  }
                ]
              }
            },
            {
              "id": "totalAmountGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Сумма общая",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "totalAmount",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.receiptData.total_amount"
                    }
                  }
                ]
              }
            },
            {
              "id": "fiscalDataGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-start mb-2",
              "props": {
                "label": "Фискальные данные",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "fiscalData",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0",
                    "props": {
                      "value": "ФН: {@state.receiptData.fiscal_data.fiscal_number}, ФД: {@state.receiptData.fiscal_data.fiscal_document_number}, ФП: {@state.receiptData.fiscal_data.fiscal_sign}"
                    }
                  }
                ]
              }
            },
            {
              "id": "receiptStatusGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Статус чека",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "receiptStatusTag",
                    "type": "component",
                    "componentType": "Tag",
                    "className": "text-sm px-2 py-1",
                    "props": {
                      "value": "@state.receiptData.receiptStatusLabel",
                      "severity": "@state.receiptData.receiptStatusSeverity"
                    }
                  }
                ]
              }
            },
            {
              "id": "moderationStatusGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Статус модерации",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "moderationStatusTag",
                    "type": "component",
                    "componentType": "Tag",
                    "className": "text-sm px-2 py-1",
                    "props": {
                      "value": "@state.receiptData.moderationStatusLabel",
                      "severity": "@state.receiptData.moderationStatusSeverity"
                    }
                  }
                ]
              }
            },
            {
              "id": "commentGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-start mb-2",
              "props": {
                "label": "Комментарий",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "comment",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0",
                    "props": {
                      "value": "@state.receiptData.comment"
                    }
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "productsSection",
      "type": "section",
      "className": "flex mb-5",
      "grid": {
        "cols": ["col-12"],
        "padding": "p-2"
      },
      "blocks": [
        {
          "id": "productsBlock",
          "type": "block",
          "wrapper": {
            "component": "Panel",
            "props": {
              "header": "Список продуктов"
            }
          },
          "components": [
            {
              "id": "productsTable",
              "type": "component",
              "componentType": "DataTable",
              "props": {
                "value": "@state.products.value",
                "columns": "@state.products.columns",
                "totalRecords": "@state.products.totalRecords",
                "paginator": false,
                "size": "small"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "actionsSection",
      "type": "section",
      "blocks": [
        {
          "id": "actionsBlock",
          "type": "block",
          "className": "flex justify-content-center gap-3 mt-3",
          "components": [
            {
              "id": "btnEdit",
              "type": "component",
              "componentType": "Button",
              "props": {
                "icon": "pi pi-pencil",
                "label": "Модерировать",
                "size": "small",
                "severity": "info"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/users/{$location.routeParams.user_id}/receipts/{$location.routeParams.receipt_id}/edit"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "btnDelete",
              "type": "component",
              "componentType": "Button",
              "props": {
                "icon": "pi pi-trash",
                "label": "Удалить",
                "size": "small",
                "severity": "danger",
                "outlined": true
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": ["deleteReceipt"]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
