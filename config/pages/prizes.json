{
  "id": "prizes",
  "type": "page",
  "route": "/prizes",
  "state": {
    "loading": false,
    "initialized": true,
    "filtersVisible": false,
    "prizes": {
      "value": [],
      "columns": [],
      "totalRecords": 10,
      "rows": 10,
      "first": 0,
      "sortField": "",
      "sortOrder": 1,
      "filters": [],
      "search": ""
    }
  },
  "meta": {
    "title": "Призы — CRM Platform"
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/prizes",
      "data": {
        "first": "{$location.params.first}",
        "rows": "{$location.params.rows}",
        "sortField": "{$location.params.sortField}",
        "sortOrder": "{$location.params.sortOrder}",
        "search": "{$location.params.search}",
        "filters": "{$location.params.filters}"
      },
      "method": "GET",
      "target": "state.prizes"
    }
  ],
  "shortcuts": {
    "requestPrizes": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "sendRequest",
            "params": {
              "url": "/api/prizes",
              "method": "GET",
              "target": "state.prizes",
              "data": {
                "event": "{$event}",
                "first": "{$state.prizes.first}",
                "rows": "{$state.prizes.rows}",
                "sortField": "{$state.prizes.sortField}",
                "sortOrder": "{$state.prizes.sortOrder}",
                "search": "{$state.prizes.search}",
                "filters": "{$state.prizes.filters}"
              },
              "format": { "$ref": "../system/list-request-format.json" }
            }
          },
          {
            "type": "mergeUrlParams",
            "params": {
              "values": {
                "first": "{$state.prizes.first}",
                "rows": "{$state.prizes.rows}",
                "sortField": "{$state.prizes.sortField}",
                "sortOrder": "{$state.prizes.sortOrder}",
                "search": "{$state.prizes.search}",
                "filters": "{$state.prizes.filters}"
              },
              "format": [
                {
                  "prop": "filters",
                  "type": "PopIfHasNullProps",
                  "params": { "props": ["value"] }
                },
                {
                  "prop": "filters",
                  "type": "RemoveProps",
                  "params": { "props": ["name", "type", "opts"] }
                }
              ]
            }
          }
        ]
      }
    }
  },
  "sections": [
    {
      "id": "prizesHeader",
      "type": "section",
      "className": "flex",
      "blocks": [
        {
          "id": "prizesTitle",
          "type": "block",
          "components": [
            {
              "id": "prizesPageTitle",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "Призы",
                "level": 1
              }
            }
          ]
        }
      ]
    },
    {
      "id": "prizesFilters",
      "type": "section",
      "className": "flex flex-column gap-3 mb-3",
      "blocks": [
        {
          "id": "prizesSearchBlock",
          "type": "block",
          "className": "w-full flex gap-3",
          "components": [
            {
              "id": "prizesSearchInput",
              "type": "component",
              "className": "w-full p-inputtext-sm mb-0",
              "componentType": "InputTextWithThrottle",
              "props": {
                "placeholder": "Быстрый поиск...",
                "throttleDelay": 500,
                "value": "@state.prizes.search"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.prizes.search"
                      }
                    },
                    "requestPrizes"
                  ]
                }
              ]
            },
            {
              "id": "prizesToggleFilters",
              "type": "component",
              "componentType": "Button",
              "className": "min-w-max flex-grow-0 px-3",
              "props": {
                "icon": "pi pi-filter",
                "severity": "primary",
                "outlined": true,
                "size": "small",
                "label": "Фильтры"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "prizesActiveFilterBlock",
          "type": "block",
          "wrapper": {
            "className": "w-full"
          },
          "components": [
            {
              "id": "prizesActiveFilterChips",
              "type": "component",
              "componentType": "ActiveFiltersBar",
              "props": {
                "value": "@state.prizes.filters"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.prizes.filters"
                      }
                    },
                    "requestPrizes"
                  ]
                }
              ]
            },
            {
              "id": "prizesFilterDrawer",
              "type": "component",
              "componentType": "FiltersPanel",
              "props": {
                "value": "@state.prizes.filters",
                "visible": "@state.filtersVisible",
                "position": "right",
                "header": "Фильтры"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.prizes.filters"
                      }
                    },
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    },
                    "requestPrizes"
                  ]
                },
                {
                  "type": "onHide",
                  "commands": [
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "prizesTableSection",
      "type": "section",
      "blocks": [
        {
          "id": "prizesTableBlock",
          "type": "block",
          "className": "w-full",
          "components": [
            {
              "id": "prizesTable",
              "type": "component",
              "componentType": "DataTable",
              "props": {
                "value": "@state.prizes.value",
                "columns": "@state.prizes.columns",
                "totalRecords": "@state.prizes.totalRecords",
                "rows": "@state.prizes.rows",
                "first": "@state.prizes.first",
                "sortField": "@state.prizes.sortField",
                "sortOrder": "@state.prizes.sortOrder",
                "paginator": true,
                "lazy": true,
                "size": "normal",
                "selectionMode": "single",
                "rowsPerPageOptions": [5, 10, 25, 50],
                "customColumns": [
                  {
                    "field": "email",
                    "body": [
                      {
                        "id": "sendButton",
                        "componentType": "Button",
                        "props": {
                          "icon": "pi pi-envelope",
                          "label": "{#field}",
                          "link": true,
                          "size": "small",
                          "pt": {
                            "label": { "className": "font-normal" },
                            "root": { "className": "p-1" }
                          }
                        },
                        "events": [
                          {
                            "type": "onClick",
                            "commands": [
                              {
                                "type": "navigate",
                                "params": {
                                  "url": "mailto:{#field}"
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "field": "button",
                    "order": -1,
                    "body": [
                      {
                        "componentType": "Button",
                        "props": {
                          "icon": "pi pi-arrow-right",
                          "link": true,
                          "size": "small",
                          "pt": { "label": { "className": "font-normal" } }
                        },
                        "events": [
                          {
                            "type": "onClick",
                            "commands": [
                              {
                                "type": "navigate",
                                "params": {
                                  "url": "/prizes/{#row._rowId}"
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              "events": [
                {
                  "type": "onPage",
                  "commands": ["requestPrizes"]
                },
                {
                  "type": "onSort",
                  "commands": ["requestPrizes"]
                },
                {
                  "type": "onRowClick",
                  "commands": [
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/prizes/{$event.data._rowId}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
