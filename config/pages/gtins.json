{
  "id": "gtins",
  "type": "page",
  "route": "/gtins",
  "state": {
    "loading": false,
    "initialized": true,
    "filtersVisible": false,
    "gtins": {
      "value": [],
      "columns": [],
      "totalRecords": 10,
      "rows": 10,
      "first": 0,
      "sortField": "",
      "sortOrder": 1,
      "filters": [],
      "search": ""
    }
  },
  "meta": {
    "title": "Коды Честный Знак — CRM Platform"
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/gtins",
      "data": {
        "first": "{$location.params.first}",
        "rows": "{$location.params.rows}",
        "sortField": "{$location.params.sortField}",
        "sortOrder": "{$location.params.sortOrder}",
        "search": "{$location.params.search}",
        "filters": "{$location.params.filters}"
      },
      "method": "GET",
      "target": "state.gtins"
    }
  ],
  "shortcuts": {
    "requestGtins": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "sendRequest",
            "params": {
              "url": "/api/gtins",
              "method": "GET",
              "target": "state.gtins",
              "data": {
                "event": "{$event}",
                "first": "{$state.gtins.first}",
                "rows": "{$state.gtins.rows}",
                "sortField": "{$state.gtins.sortField}",
                "sortOrder": "{$state.gtins.sortOrder}",
                "search": "{$state.gtins.search}",
                "filters": "{$state.gtins.filters}"
              },
              "format": { "$ref": "../system/list-request-format.json" }
            }
          },
          {
            "type": "mergeUrlParams",
            "params": {
              "values": {
                "first": "{$state.gtins.first}",
                "rows": "{$state.gtins.rows}",
                "sortField": "{$state.gtins.sortField}",
                "sortOrder": "{$state.gtins.sortOrder}",
                "search": "{$state.gtins.search}",
                "filters": "{$state.gtins.filters}"
              },
              "format": [
                {
                  "prop": "filters",
                  "type": "PopIfHasNullProps",
                  "params": { "props": ["value"] }
                },
                {
                  "prop": "filters",
                  "type": "RemoveProps",
                  "params": { "props": ["name", "type", "opts"] }
                }
              ]
            }
          }
        ]
      }
    }
  },
  "sections": [
    {
      "id": "gtinsHeader",
      "type": "section",
      "className": "flex",
      "blocks": [
        {
          "id": "gtinsTitle",
          "type": "block",
          "components": [
            {
              "id": "gtinsPageTitle",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "Коды Честный Знак",
                "level": 1
              }
            }
          ]
        }
      ]
    },
    {
      "id": "gtinsFilters",
      "type": "section",
      "className": "flex flex-column gap-3 mb-3",
      "blocks": [
        {
          "id": "gtinsSearchBlock",
          "type": "block",
          "className": "w-full flex gap-3",
          "components": [
            {
              "id": "gtinsSearchInput",
              "type": "component",
              "className": "w-full p-inputtext-sm mb-0",
              "componentType": "InputTextWithThrottle",
              "props": {
                "placeholder": "Быстрый поиск...",
                "throttleDelay": 500,
                "value": "@state.gtins.search"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.gtins.search"
                      }
                    },
                    "requestGtins"
                  ]
                }
              ]
            },
            {
              "id": "gtinsToggleFilters",
              "type": "component",
              "componentType": "Button",
              "className": "min-w-max flex-grow-0 px-3",
              "props": {
                "icon": "pi pi-filter",
                "severity": "primary",
                "outlined": true,
                "size": "small",
                "label": "Фильтры"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "gtinsActiveFilterBlock",
          "type": "block",
          "wrapper": {
            "className": "w-full"
          },
          "components": [
            {
              "id": "gtinsActiveFilterChips",
              "type": "component",
              "componentType": "ActiveFiltersBar",
              "props": {
                "value": "@state.gtins.filters"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.gtins.filters"
                      }
                    },
                    "requestGtins"
                  ]
                }
              ]
            },
            {
              "id": "gtinsFilterDrawer",
              "type": "component",
              "componentType": "FiltersPanel",
              "props": {
                "value": "@state.gtins.filters",
                "visible": "@state.filtersVisible",
                "position": "right",
                "header": "Фильтры"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.gtins.filters"
                      }
                    },
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    },
                    "requestGtins"
                  ]
                },
                {
                  "type": "onHide",
                  "commands": [
                    {
                      "type": "toggleProperty",
                      "params": {
                        "target": "state.filtersVisible"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "gtinsTableSection",
      "type": "section",
      "blocks": [
        {
          "id": "gtinsTableBlock",
          "type": "block",
          "className": "w-full",
          "components": [
            {
              "id": "gtinsTable",
              "type": "component",
              "componentType": "DataTable",
              "props": {
                "value": "@state.gtins.value",
                "columns": "@state.gtins.columns",
                "totalRecords": "@state.gtins.totalRecords",
                "rows": "@state.gtins.rows",
                "first": "@state.gtins.first",
                "sortField": "@state.gtins.sortField",
                "sortOrder": "@state.gtins.sortOrder",
                "paginator": true,
                "lazy": true,
                "size": "normal",
                "selectionMode": "single",
                "rowsPerPageOptions": [5, 10, 25, 50],
                "customColumns": [
                  {
                    "field": "email",
                    "body": [
                      {
                        "id": "sendButton",
                        "componentType": "Button",
                        "props": {
                          "icon": "pi pi-envelope",
                          "label": "{#field}",
                          "link": true,
                          "size": "small",
                          "pt": {
                            "label": { "className": "font-normal" },
                            "root": { "className": "p-1" }
                          }
                        },
                        "events": [
                          {
                            "type": "onClick",
                            "commands": [
                              {
                                "type": "navigate",
                                "params": {
                                  "url": "mailto:{#field}"
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "field": "actions",
                    "order": -1,
                    "body": [
                      {
                        "componentType": "Button",
                        "props": {
                          "icon": "pi pi-chevron-right",
                          "link": true,
                          "size": "small",
                          "pt": { "label": { "className": "font-normal" } }
                        },
                        "events": [
                          {
                            "type": "onClick",
                            "commands": [
                              {
                                "type": "navigate",
                                "params": {
                                  "url": "/gtins/{#row._rowId}"
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              "events": [
                {
                  "type": "onPage",
                  "commands": ["requestGtins"]
                },
                {
                  "type": "onSort",
                  "commands": ["requestGtins"]
                },
                {
                  "type": "onRowClick",
                  "commands": [
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/gtins/{$event.data._rowId}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
