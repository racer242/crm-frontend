{
  "id": "receipt",
  "type": "page",
  "route": "/receipts/[receipt_id]",
  "state": {
    "loading": false,
    "initialized": true,
    "filtersVisible": false,
    "receiptData": {
      "id": "",
      "user_id": "",
      "user_name": "",
      "user_email": "",
      "registration_date": "",
      "purchase_date": "",
      "retail_chain_id": "",
      "retail_chain_name": "",
      "promo_products_amount": 0,
      "total_amount": 0,
      "fiscal_data": {},
      "receipt_status": "",
      "moderation_status": "",
      "comment": "",
      "registrationDateFormatted": "",
      "purchaseDateFormatted": "",
      "receiptStatusLabel": "",
      "receiptStatusSeverity": "",
      "moderationStatusLabel": "",
      "moderationStatusSeverity": "",
      "retail_chains": [],
      "statuses": []
    },
    "products": {
      "value": [],
      "columns": [],
      "totalRecords": 0,
      "rows": 10,
      "first": 0,
      "sortField": "",
      "sortOrder": 1,
      "filters": [],
      "search": ""
    },
    "saveResult": null
  },
  "meta": { "title": "Чек — CRM Platform" },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/api/receipts/{$location.routeParams.receipt_id}",
      "method": "GET",
      "target": "state.receiptData"
    },
    {
      "url": "{$config.baseURL}/api/receipts/{$location.routeParams.receipt_id}/products",
      "data": {
        "first": "{$location.params.first}",
        "rows": "{$location.params.rows}",
        "sortField": "{$location.params.sortField}",
        "sortOrder": "{$location.params.sortOrder}",
        "search": "{$location.params.search}",
        "filters": "{$location.params.filters}"
      },
      "method": "GET",
      "target": "state.products"
    }
  ],
  "shortcuts": {
    "requestProducts": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "sendRequest",
            "params": {
              "url": "/api/receipts/{$location.routeParams.receipt_id}/products",
              "method": "GET",
              "target": "state.products",
              "data": {
                "event": "{$event}",
                "first": "{$state.products.first}",
                "rows": "{$state.products.rows}",
                "sortField": "{$state.products.sortField}",
                "sortOrder": "{$state.products.sortOrder}",
                "search": "{$state.products.search}",
                "filters": "{$state.products.filters}"
              },
              "format": { "$ref": "../system/list-request-format.json" }
            }
          },
          {
            "type": "mergeUrlParams",
            "params": {
              "values": {
                "first": "{$state.products.first}",
                "rows": "{$state.products.rows}",
                "sortField": "{$state.products.sortField}",
                "sortOrder": "{$state.products.sortOrder}",
                "search": "{$state.products.search}",
                "filters": "{$state.products.filters}"
              },
              "format": [
                {
                  "prop": "filters",
                  "type": "PopIfHasNullProps",
                  "params": { "props": ["value"] }
                },
                {
                  "prop": "filters",
                  "type": "RemoveProps",
                  "params": { "props": ["name", "type", "opts"] }
                }
              ]
            }
          }
        ]
      }
    },
    "deleteReceipt": {
      "type": "sequence",
      "params": {
        "commands": [
          {
            "type": "setProperty",
            "params": { "target": "state.saveResult", "value": null }
          },
          {
            "type": "confirm",
            "params": {
              "message": "Вы уверены, что хотите удалить этот чек?",
              "onConfirm": [
                {
                  "type": "sendRequest",
                  "params": {
                    "url": "/api/receipts/{$location.routeParams.receipt_id}",
                    "method": "DELETE",
                    "target": "state.saveResult",
                    "onSuccess": [
                      {
                        "type": "showToast",
                        "params": {
                          "severity": "success",
                          "summary": "Успешно",
                          "message": "Чек удален"
                        }
                      },
                      {
                        "type": "navigate",
                        "params": { "url": "/receipts" }
                      }
                    ],
                    "onError": [
                      {
                        "type": "showToast",
                        "params": {
                          "severity": "error",
                          "summary": "Ошибка",
                          "message": "Не удалось удалить чек"
                        }
                      }
                    ]
                  }
                }
              ],
              "onCancel": []
            }
          }
        ]
      }
    }
  },
  "sections": [
    {
      "id": "breadcrumbSection",
      "type": "section",
      "className": "",
      "blocks": [
        {
          "id": "breadcrumbBlock",
          "type": "block",
          "components": [
            {
              "id": "breadcrumb",
              "type": "component",
              "componentType": "Breadcrumb",
              "className": "border-none p-0",
              "props": {
                "home": { "icon": "pi pi-home", "url": "/" },
                "model": [
                  { "label": "Чеки", "route": "/receipts" },
                  {
                    "label": "Чек от {@state.receiptData.registrationDateFormatted}"
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "mainLayout",
      "type": "section",
      "className": "flex mb-5",
      "grid": {
        "cols": ["col-12 lg:col-8", "col-12 lg:col-4"],
        "padding": "p-2"
      },
      "blocks": [
        {
          "id": "receiptDetailsBlock",
          "type": "block",
          "wrapper": {
            "component": "Panel",
            "props": { "header": "Информация о чеке" }
          },
          "className": "flex flex-column gap-3",
          "components": [
            {
              "id": "registrationDateGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Дата регистрации",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "registrationDate",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.receiptData.registrationDateFormatted"
                    }
                  }
                ]
              }
            },
            {
              "id": "purchaseDateGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Дата покупки",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "purchaseDate",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.receiptData.purchaseDateFormatted"
                    }
                  }
                ]
              }
            },
            {
              "id": "retailChainGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Торговая сеть",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "retailChain",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": { "value": "@state.receiptData.retail_chain_name" }
                  }
                ]
              }
            },
            {
              "id": "promoAmountGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Сумма акционных продуктов",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "promoAmount",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": {
                      "value": "@state.receiptData.promo_products_amount"
                    }
                  }
                ]
              }
            },
            {
              "id": "totalAmountGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Сумма общая",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "totalAmount",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0 font-bold text-lg",
                    "props": { "value": "@state.receiptData.total_amount" }
                  }
                ]
              }
            },
            {
              "id": "fiscalDataGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-start mb-2",
              "props": {
                "label": "Фискальные данные",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "fiscalData",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0",
                    "props": {
                      "value": "ФН: {@state.receiptData.fiscal_data.fiscal_number}, ФД: {@state.receiptData.fiscal_data.fiscal_document_number}, ФП: {@state.receiptData.fiscal_data.fiscal_sign}"
                    }
                  }
                ]
              }
            },
            {
              "id": "moderationStatusGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-center mb-2",
              "props": {
                "label": "Статус модерации",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "moderationStatusTag",
                    "type": "component",
                    "componentType": "Tag",
                    "className": "text-sm px-2 py-1",
                    "props": {
                      "value": "@state.receiptData.moderationStatusLabel",
                      "severity": "@state.receiptData.moderationStatusSeverity"
                    }
                  }
                ]
              }
            },
            {
              "id": "commentGroup",
              "type": "component",
              "componentType": "LabelledGroup",
              "className": "w-full grid align-items-start mb-2",
              "props": {
                "label": "Комментарий",
                "labelClassName": "text-sm col-4 text-right",
                "containerClassName": "col-8",
                "components": [
                  {
                    "id": "comment",
                    "type": "component",
                    "componentType": "Text",
                    "className": "m-0",
                    "props": { "value": "@state.receiptData.comment" }
                  }
                ]
              }
            }
          ]
        },
        {
          "id": "extraDetailsBlock",
          "type": "block",
          "className": "flex flex-column gap-3",
          "components": [
            {
              "id": "userInfoPanel",
              "type": "component",
              "componentType": "Panel",
              "className": "flex flex-column",
              "props": {
                "header": "Участник",
                "components": [
                  {
                    "id": "userNameGroup",
                    "type": "component",
                    "componentType": "LabelledGroup",
                    "className": "w-full grid align-items-center mb-2",
                    "props": {
                      "label": "Имя",
                      "labelClassName": "text-sm col-4 text-right",
                      "containerClassName": "col-8",
                      "components": [
                        {
                          "id": "userNameLink",
                          "type": "component",
                          "componentType": "Text",
                          "className": "m-0 font-bold text-lg text-primary",
                          "props": { "value": "@state.receiptData.user_name" },
                          "events": [
                            {
                              "type": "onClick",
                              "commands": [
                                {
                                  "type": "navigate",
                                  "params": {
                                    "url": "/users/{$state.receiptData.user_id}"
                                  }
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  },
                  {
                    "id": "userEmailGroup",
                    "type": "component",
                    "componentType": "LabelledGroup",
                    "className": "w-full grid align-items-center mb-2",
                    "props": {
                      "label": "Email",
                      "labelClassName": "text-sm col-4 text-right",
                      "containerClassName": "col-8",
                      "components": [
                        {
                          "id": "userEmailLink",
                          "type": "component",
                          "componentType": "Text",
                          "className": "m-0 font-bold text-lg text-primary",
                          "props": { "value": "@state.receiptData.user_email" }
                        }
                      ]
                    }
                  },
                  {
                    "id": "userLinkBtn",
                    "type": "component",
                    "componentType": "Button",
                    "props": {
                      "icon": "pi pi-user",
                      "label": "Перейти к участнику",
                      "size": "small",
                      "severity": "info",
                      "outlined": true,
                      "className": "w-full"
                    },
                    "events": [
                      {
                        "type": "onClick",
                        "commands": [
                          {
                            "type": "navigate",
                            "params": {
                              "url": "/users/{$state.receiptData.user_id}"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "productsFilters",
      "type": "section",
      "className": "flex flex-column gap-3 mb-3",
      "blocks": [
        {
          "id": "productsSearchBlock",
          "type": "block",
          "className": "w-full flex gap-3",
          "components": [
            {
              "id": "productsSearchInput",
              "type": "component",
              "className": "w-full p-inputtext-sm mb-0",
              "componentType": "InputTextWithThrottle",
              "props": {
                "placeholder": "Быстрый поиск...",
                "throttleDelay": 500,
                "value": "@state.products.search"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.products.search"
                      }
                    },
                    "requestProducts"
                  ]
                }
              ]
            },
            {
              "id": "productsToggleFilters",
              "type": "component",
              "componentType": "Button",
              "className": "min-w-max flex-grow-0 px-3",
              "props": {
                "icon": "pi pi-filter",
                "severity": "primary",
                "outlined": true,
                "size": "small",
                "label": "Фильтры"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "toggleProperty",
                      "params": { "target": "state.filtersVisible" }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "productsActiveFilterBlock",
          "type": "block",
          "wrapper": { "className": "w-full" },
          "components": [
            {
              "id": "productsActiveFilterChips",
              "type": "component",
              "componentType": "ActiveFiltersBar",
              "props": { "value": "@state.products.filters" },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.products.filters"
                      }
                    },
                    "requestProducts"
                  ]
                }
              ]
            },
            {
              "id": "productsFilterDrawer",
              "type": "component",
              "componentType": "FiltersPanel",
              "props": {
                "value": "@state.products.filters",
                "visible": "@state.filtersVisible",
                "position": "right",
                "header": "Фильтры"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.products.filters"
                      }
                    },
                    {
                      "type": "toggleProperty",
                      "params": { "target": "state.filtersVisible" }
                    },
                    "requestProducts"
                  ]
                },
                {
                  "type": "onHide",
                  "commands": [
                    {
                      "type": "toggleProperty",
                      "params": { "target": "state.filtersVisible" }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "productsTableSection",
      "type": "section",
      "blocks": [
        {
          "id": "productsTableBlock",
          "type": "block",
          "className": "w-full",
          "components": [
            {
              "id": "productsTable",
              "type": "component",
              "componentType": "DataTable",
              "props": {
                "value": "@state.products.value",
                "columns": "@state.products.columns",
                "totalRecords": "@state.products.totalRecords",
                "rows": "@state.products.rows",
                "first": "@state.products.first",
                "sortField": "@state.products.sortField",
                "sortOrder": "@state.products.sortOrder",
                "paginator": true,
                "lazy": true,
                "size": "normal",
                "rowsPerPageOptions": [5, 10, 25, 50],
                "customColumns": [
                  {
                    "field": "is_promo",
                    "body": [
                      {
                        "componentType": "Button",
                        "props": {
                          "icon": "{#field.is_promo_icon}",
                          "severity": "{#field.is_promo_severity}",
                          "text": true,
                          "disabled": true,
                          "rounded": true
                        }
                      }
                    ]
                  }
                ]
              },
              "events": [
                { "type": "onPage", "commands": ["requestProducts"] },
                { "type": "onSort", "commands": ["requestProducts"] }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "buttonsSection",
      "type": "section",
      "className": "flex justify-content-center",
      "blocks": [
        {
          "id": "buttonsBlock",
          "type": "block",
          "wrapper": {
            "showHeader": false,
            "component": "Panel",
            "props": {
              "className": "flex-grow-1",
              "pt": {
                "content": {
                  "style": { "background": "var(--surface-50) !important" }
                }
              }
            }
          },
          "className": "flex flex-wrap gap-3 justify-content-center md:justify-content-start",
          "components": [
            {
              "id": "btnEdit",
              "type": "component",
              "componentType": "Button",
              "props": {
                "icon": "pi pi-pencil",
                "label": "Модерировать",
                "size": "small",
                "severity": "info"
              },
              "events": [
                {
                  "type": "onClick",
                  "commands": [
                    {
                      "type": "navigate",
                      "params": {
                        "url": "/receipts/{$location.routeParams.receipt_id}/edit"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "btnDelete",
              "type": "component",
              "componentType": "Button",
              "props": {
                "icon": "pi pi-trash",
                "label": "Удалить",
                "size": "small",
                "severity": "danger",
                "outlined": true
              },
              "events": [{ "type": "onClick", "commands": ["deleteReceipt"] }]
            }
          ]
        }
      ]
    }
  ]
}
