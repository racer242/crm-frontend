{
  "id": "statistics",
  "type": "page",
  "route": "/statistics",
  "state": {
    "loading": false,
    "start": "",
    "end": "",
    "dynamicData": {
      "title": "Текст"
    },
    "analytics": [],
    "review": ""
  },
  "meta": {
    "title": "Статистика — CRM Platform"
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/mocks/api/get-stats.json",
      "method": "GET",
      "target": "state"
    },
    {
      "url": "{$config.baseURL}/mocks/api/stats/analytics.json",
      "method": "GET",
      "target": "state.analytics",
      "adapter": "stats.analytics.js"
    },
    {
      "url": "{$config.baseURL}/mocks/api/stats/review.json",
      "method": "GET",
      "target": "state.review",
      "adapter": "stats.review.js"
    }
  ],
  "events": [
    {
      "type": "onLoad",
      "commands": [
        {
          "type": "log",
          "params": {
            "level": "info",
            "message": "Statistics page loaded"
          }
        },
        {
          "type": "setProperty",
          "params": {
            "value": "Simply Text",
            "target": "filtersSection.state.textData.input"
          }
        }
      ]
    }
  ],
  "sections": [
    {
      "id": "statsTitleSection",
      "type": "section",
      "state": {},
      "blocks": [
        {
          "id": "statsHeaderBlock",
          "type": "block",
          "state": {},
          "components": [
            {
              "id": "pageTitle",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "Статистика",
                "level": 1
              },
              "state": {}
            }
          ]
        }
      ]
    },
    {
      "id": "filtersSection",
      "type": "section",
      "className": "flex flex-column lg:flex-row gap-3",
      "state": {},
      "blocks": [
        {
          "id": "weekFilterBlock",
          "type": "block",
          "state": {},
          "className": "w-full",
          "wrapper": {
            "component": "Panel",
            "props": {
              "header": "Выбор недели"
            }
          },
          "components": [
            {
              "id": "weekDropdown",
              "type": "component",
              "componentType": "Dropdown",
              "className": "w-full",
              "props": {
                "options": [
                  {
                    "label": "Неделя 11 - 16.03.2026 - 23.03.2026",
                    "value": {
                      "week": 11,
                      "start": "16.03.2026",
                      "end": "23.03.2026"
                    }
                  },
                  {
                    "label": "Неделя 12 - 23.03.2026 - 30.03.2026",
                    "value": {
                      "week": 12,
                      "start": "23.03.2026",
                      "end": "30.03.2026"
                    }
                  },
                  {
                    "label": "Неделя 13 - 30.03.2026 - 06.04.2026",
                    "value": {
                      "week": 13,
                      "start": "30.03.2026",
                      "end": "06.04.2026"
                    }
                  },
                  {
                    "label": "Неделя 14 - 06.04.2026 - 13.04.2026",
                    "value": {
                      "week": 14,
                      "start": "06.04.2026",
                      "end": "13.04.2026"
                    }
                  },
                  {
                    "label": "Неделя 15 - 13.04.2026 - 20.04.2026",
                    "value": {
                      "week": 15,
                      "start": "13.04.2026",
                      "end": "20.04.2026"
                    }
                  },
                  {
                    "label": "Неделя 16 - 20.04.2026 - 27.04.2026",
                    "value": {
                      "week": 16,
                      "start": "20.04.2026",
                      "end": "27.04.2026"
                    }
                  }
                ],
                "placeholder": "Выберите неделю",
                "showClear": true,
                "value": "@state.week"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.week"
                      }
                    },
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value.start",
                        "target": "state.start"
                      }
                    },
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value.end",
                        "target": "state.end"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "dateRangeBlock",
          "type": "block",
          "className": "w-full flex flex-column xl:flex-row gap-3",
          "state": {},
          "wrapper": {
            "component": "Panel",
            "props": {
              "header": "Диапазон дат"
            }
          },
          "components": [
            {
              "id": "startDatePicker",
              "type": "component",
              "componentType": "Calendar",
              "props": {
                "placeholder": "Дата начала",
                "showIcon": true,
                "icondisplay": "input",
                "dateFormat": "dd.mm.yy",
                "value": "@state.start"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.start"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "endDatePicker",
              "type": "component",
              "componentType": "Calendar",
              "props": {
                "placeholder": "Дата окончания",
                "showIcon": true,
                "icondisplay": "input",
                "dateFormat": "dd.mm.yy",
                "value": "@state.end"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value",
                        "target": "state.end"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "menuBarSection",
      "type": "section",
      "state": {
        "visible": true
      },
      "layout": {
        "type": "flex",
        "direction": "column",
        "gap": 20
      },
      "blocks": [
        {
          "id": "menuBarBlock",
          "type": "block",
          "state": {},
          "components": [
            {
              "id": "downloadMenuBar",
              "type": "component",
              "componentType": "Menubar",
              "props": {
                "model": "@state.analytics"
              },
              "state": {},
              "events": [
                {
                  "type": "onNavigate",
                  "commands": []
                }
              ]
            }
          ]
        }
      ]
    },

    {
      "id": "reviewSection",
      "type": "section",
      "state": {
        "visible": true
      },
      "blocks": [
        {
          "id": "reviewBlock",
          "type": "block",
          "state": {},
          "components": [
            {
              "id": "reviewTabView",
              "type": "component",
              "componentType": "TabView",
              "props": "@state.review"
            }
          ]
        }
      ]
    }
  ]
}
