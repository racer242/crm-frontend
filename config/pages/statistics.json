{
  "id": "statistics",
  "type": "page",
  "route": "/statistics",
  "state": {
    "loading": false,
    "week": "{$location.params.week}",
    "start": "{$location.params.start}",
    "end": "{$location.params.end}",
    "dynamicData": {
      "title": "Текст"
    },
    "analytics": [],
    "weeks": [],
    "review": ""
  },
  "meta": {
    "title": "Статистика — CRM Platform"
  },
  "dataFeed": [
    {
      "url": "{$config.baseURL}/mocks/api/get-stats.json",
      "method": "GET",
      "target": "state"
    },
    {
      "url": "{$config.baseURL}/mocks/api/stats/analytics.json",
      "method": "GET",
      "target": "state.analytics",
      "adapter": "stats.analytics.js"
    },
    {
      "url": "{$config.baseURL}/mocks/api/stats/review.json",
      "method": "GET",
      "target": "state.review",
      "adapter": "stats.review.js"
    },
    {
      "url": "{$config.baseURL}/mocks/api/stats/weeks.json",
      "method": "GET",
      "target": "state.weeks",
      "adapter": "stats.week.js"
    }
  ],
  "events": [
    {
      "type": "onLoad",
      "commands": [
        {
          "type": "log",
          "params": {
            "level": "info",
            "message": "Statistics page loaded"
          }
        },
        {
          "type": "setProperty",
          "params": {
            "value": "Simply Text",
            "target": "filtersSection.state.textData.input"
          }
        }
      ]
    }
  ],
  "sections": [
    {
      "id": "statsTitleSection",
      "type": "section",
      "state": {},
      "blocks": [
        {
          "id": "statsHeaderBlock",
          "type": "block",
          "state": {},
          "components": [
            {
              "id": "pageTitle",
              "type": "component",
              "componentType": "Text",
              "props": {
                "value": "Статистика",
                "level": 1
              },
              "state": {}
            }
          ]
        }
      ]
    },
    {
      "id": "filtersSection",
      "type": "section",
      "className": "flex flex-column lg:flex-row gap-3",
      "state": {},
      "blocks": [
        {
          "id": "weekFilterBlock",
          "type": "block",
          "state": {},
          "className": "w-full",
          "wrapper": {
            "component": "Panel",
            "className": "w-full",
            "props": {
              "header": "Выбор недели"
            }
          },
          "components": [
            {
              "id": "weekDropdown",
              "type": "component",
              "componentType": "Dropdown",
              "className": "w-full",
              "props": {
                "placeholder": "Выберите неделю",
                "showClear": true,
                "value": "@state.week",
                "options": "@state.weeks"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value.id",
                        "target": "state.week"
                      }
                    },
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value.start",
                        "target": "state.start"
                      }
                    },
                    {
                      "type": "setProperty",
                      "params": {
                        "source": "event.value.end",
                        "target": "state.end"
                      }
                    },
                    {
                      "type": "setUrlParams",
                      "params": {
                        "values": {
                          "week": "{$event.value.id}",
                          "start": "{$event.value.start}",
                          "end": "{$event.value.end}"
                        }
                      }
                    },
                    { "type": "refresh" }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "dateRangeBlock",
          "type": "block",
          "className": "w-full flex flex-column xl:flex-row gap-3",
          "state": {},
          "wrapper": {
            "component": "Panel",
            "className": "w-full",
            "props": {
              "header": "Диапазон дат"
            }
          },
          "components": [
            {
              "id": "startDatePicker",
              "type": "component",
              "componentType": "Calendar",
              "props": {
                "placeholder": "Дата начала",
                "showIcon": true,
                "icondisplay": "input",
                "dateFormat": "dd.mm.yy",
                "value": "@state.start"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "mergeState",
                      "params": {
                        "source": { "start": "{$event.value}", "week": null },
                        "target": "state"
                      }
                    },
                    {
                      "type": "mergeUrlParams",
                      "params": {
                        "values": {
                          "week": null,
                          "start": "{$event.value}"
                        },
                        "format": [
                          {
                            "prop": "values.start",
                            "type": "Date"
                          }
                        ]
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "endDatePicker",
              "type": "component",
              "componentType": "Calendar",
              "props": {
                "placeholder": "Дата окончания",
                "showIcon": true,
                "icondisplay": "input",
                "dateFormat": "dd.mm.yy",
                "value": "@state.end"
              },
              "events": [
                {
                  "type": "onChange",
                  "commands": [
                    {
                      "type": "mergeState",
                      "params": {
                        "source": { "end": "{$event.value}", "week": null },
                        "target": "state"
                      }
                    },
                    {
                      "type": "mergeUrlParams",
                      "params": {
                        "values": {
                          "week": null,
                          "end": "{$event.value}"
                        },
                        "format": [
                          {
                            "prop": "values.end",
                            "type": "Date"
                          }
                        ]
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "menuBarSection",
      "type": "section",
      "state": {
        "visible": true
      },
      "blocks": [
        {
          "id": "menuBarBlock",
          "type": "block",
          "state": {},
          "components": [
            {
              "id": "downloadMenuBar",
              "type": "component",
              "componentType": "Menubar",
              "props": {
                "model": "@state.analytics"
              },
              "state": {},
              "events": [
                {
                  "type": "onNavigate",
                  "commands": []
                }
              ]
            }
          ]
        }
      ]
    },

    {
      "id": "reviewSection",
      "type": "section",
      "state": {
        "visible": true
      },
      "blocks": [
        {
          "id": "reviewBlock",
          "type": "block",
          "state": {},
          "components": [
            {
              "id": "reviewTabView",
              "type": "component",
              "componentType": "TabView",
              "props": "@state.review"
            }
          ]
        }
      ]
    }
  ]
}
