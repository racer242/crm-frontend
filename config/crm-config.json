{
  "id": "crm",
  "type": "app",
  "title": "CRM Platform",
  "state": {},
  "navbar": {
    "id": "mainNavbar",
    "items": [
      {
        "label": "Dashboard",
        "icon": "pi pi-home",
        "route": "/"
      },
      {
        "label": "Users",
        "icon": "pi pi-users",
        "route": "/users"
      },
      {
        "label": "Orders",
        "icon": "pi pi-shopping-cart",
        "route": "/orders"
      },
      {
        "label": "Products",
        "icon": "pi pi-box",
        "route": "/products"
      },
      {
        "label": "Reports",
        "icon": "pi pi-chart-bar",
        "route": "/reports"
      },
      {
        "label": "Settings",
        "icon": "pi pi-cog",
        "route": "/settings"
      },
      {
        "label": "Components",
        "icon": "pi pi-th-large",
        "route": "/components"
      }
    ]
  },
  "userMenu": {
    "loginLabel": "Войти",
    "userName": "e.simonov",
    "userRole": "администратор",
    "items": [
      {
        "label": "Профиль",
        "icon": "pi pi-user",
        "route": "/profile"
      },
      {
        "separator": true
      },
      {
        "label": "Выйти",
        "icon": "pi pi-sign-out",
        "route": "/"
      }
    ]
  },
  "pages": [
    {
      "$ref": "./pages/dashboard.json"
    },
    {
      "$ref": "./pages/users.json"
    },
    {
      "$ref": "./pages/orders.json"
    },
    {
      "$ref": "./pages/products.json"
    },
    {
      "$ref": "./pages/reports.json"
    },
    {
      "$ref": "./pages/settings.json"
    },
    {
      "$ref": "./pages/components.json"
    }
  ],
  "globalState": {
    "user": {
      "id": "1",
      "name": "Admin User",
      "email": "admin@crm.com",
      "role": "admin",
      "permissions": [
        "read",
        "write",
        "delete"
      ],
      "avatar": "👤"
    },
    "auth": {
      "isAuthenticated": true,
      "token": "mock-jwt-token",
      "expiresAt": 1735689600000
    },
    "cache": {}
  },
  "config": {
    "name": "CRM Platform",
    "version": "1.0.0",
    "api": {
      "baseURL": "http://localhost:3001/api",
      "timeout": 10000,
      "endpoints": {
        "getUsers": {
          "path": "/users",
          "method": "GET",
          "cache": true,
          "cacheTTL": 60000
        },
        "getOrders": {
          "path": "/orders",
          "method": "GET",
          "cache": false
        },
        "getProducts": {
          "path": "/products",
          "method": "GET",
          "cache": true,
          "cacheTTL": 300000
        },
        "createOrder": {
          "path": "/orders",
          "method": "POST"
        }
      }
    },
    "features": {
      "darkMode": true,
      "apiAccess": true,
      "exportData": true,
      "twoFactorAuth": false
    }
  }
}