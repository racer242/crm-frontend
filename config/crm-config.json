{
  "id": "crm",
  "type": "app",
  "title": "CRM Platform",
  "state": {},
  "navbar": {
    "id": "mainNavbar",
    "items": [
      {
        "label": "Dashboard",
        "icon": "pi pi-home",
        "route": "/"
      },
      {
        "label": "Статистика",
        "icon": "pi pi-chart-bar",
        "route": "/statistics"
      },
      {
        "label": "Участники",
        "icon": "pi pi-users",
        "route": "/users"
      },
      {
        "label": "Orders",
        "icon": "pi pi-shopping-cart",
        "route": "/orders"
      },
      {
        "label": "Products",
        "icon": "pi pi-box",
        "route": "/products"
      },
      {
        "label": "Reports",
        "icon": "pi pi-chart-bar",
        "route": "/reports"
      },
      {
        "label": "Settings",
        "icon": "pi pi-cog",
        "route": "/settings"
      },
      {
        "label": "Components",
        "icon": "pi pi-th-large",
        "route": "/components"
      },
      {
        "label": "Testing",
        "icon": "pi pi-th-large",
        "route": "/stats/testing"
      }
    ]
  },
  "userMenu": {
    "loginLabel": "Войти",
    "items": [
      {
        "label": "Профиль",
        "icon": "pi pi-user",
        "route": "/profile"
      },
      {
        "separator": true
      },
      {
        "label": "Выйти",
        "icon": "pi pi-sign-out",
        "action": "logout"
      }
    ]
  },
  "pages": [
    { "$ref": "./pages/dashboard.json" },
    { "$ref": "./pages/statistics.json" },
    { "$ref": "./pages/users.json" },
    { "$ref": "./pages/orders.json" },
    { "$ref": "./pages/products.json" },
    { "$ref": "./pages/reports.json" },
    { "$ref": "./pages/settings.json" },
    { "$ref": "./pages/components.json" },
    { "$ref": "./pages/testing.json" },
    { "$ref": "./pages/user.json" }
  ],
  "adapters": {
    "stats.analytics.replace": {
      "type": "replace",
      "rules": {
        "title": {
          "name": "label"
        },
        "url": {
          "name": "commands",
          "value": [
            {
              "type": "navigate",
              "params": {
                "url": "$value$"
              }
            }
          ]
        }
      }
    },
    "stats.analytics.js": {
      "type": "js",
      "script": "./config/adapters/analytics2menu.js"
    },
    "stats.review.js": {
      "type": "js",
      "script": "./config/adapters/stats-review-2-tabview.js"
    },
    "stats.week.js": {
      "type": "js",
      "script": "./config/adapters/weeks-2-select-list.js"
    },
    "users.request.js": {
      "type": "js",
      "script": "./config/adapters/users-params.js"
    },
    "users.response.js": {
      "type": "js",
      "script": "./config/adapters/users-2-tabview.js"
    }
  },
  "config": {
    "name": "CRM Platform",
    "version": "1.0.0",
    "indexPageId": "dashboard",
    "baseURL": "{$env.NEXT_PUBLIC_BASE_URL}",
    "timeout": 10000,
    "features": {
      "darkMode": true,
      "apiAccess": true,
      "exportData": true,
      "twoFactorAuth": false
    }
  },
  "apiRoutes": [
    {
      "path": "get-dynamic-data",
      "url": "{$config.baseURL}/mocks/api/get-dynamic-data.json"
    },
    {
      "path": "get-users",
      "url": "{$config.baseURL}/mocks/api/users/users.json",
      "adapter": {
        "request": "users.request.js",
        "response": "users.response.js"
      }
    },
    {
      "path": "get-file",
      "type": "file",
      "url": "{$config.baseURL}/mocks/api/file/default_12_5_2026_14_26_10.xlsx"
    }
  ]
}
